<Window x:Class="CMS5000.Views.Admin.DbConnectView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Database Connect"
        Width="360" Height="310"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F0F3">
    <Window.Resources>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Fld" TargetType="Control">
            <Setter Property="Height" Value="26"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Padding" Value="22,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="#FFFFFF" CornerRadius="4" BorderBrush="#9AA7BD" BorderThickness="1" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="#EAF1FB"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/><RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/><RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/><RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="86"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Server"   Style="{StaticResource Lbl}"/>
        <TextBox   Grid.Row="0" Grid.Column="1" Style="{StaticResource Fld}"
                   Text="{Binding Server, UpdateSourceTrigger=PropertyChanged}"/>
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Database" Style="{StaticResource Lbl}"/>
        <TextBox   Grid.Row="2" Grid.Column="1" Style="{StaticResource Fld}"
                   Text="{Binding Database, UpdateSourceTrigger=PropertyChanged}"/>
        <TextBlock Grid.Row="4" Grid.Column="0" Text="User"     Style="{StaticResource Lbl}"/>
        <TextBox   Grid.Row="4" Grid.Column="1" Style="{StaticResource Fld}"
                   Text="{Binding User, UpdateSourceTrigger=PropertyChanged}"/>
        <TextBlock Grid.Row="6" Grid.Column="0" Text="Password" Style="{StaticResource Lbl}"/>
        <PasswordBox x:Name="PwBox" Grid.Row="6" Grid.Column="1" Style="{StaticResource Fld}"
                     PasswordChanged="PwBox_PasswordChanged"/>

        <TextBlock Grid.Row="8" Grid.ColumnSpan="2" Text="{Binding Status}"
                   FontSize="11" Foreground="#C0392B" Margin="0,2,0,8"/>

        <!-- 사용 DB 표시: PostgreSQL 공식 로고 -->
        <Image Grid.Row="9" Grid.ColumnSpan="2" HorizontalAlignment="Left" VerticalAlignment="Center"
               Height="45" Stretch="Uniform"
               Source="/Images/postgresql.png"
               RenderOptions.BitmapScalingMode="HighQuality"
               ToolTip="이 프로그램은 PostgreSQL 데이터베이스를 사용합니다."/>

        <StackPanel Grid.Row="9" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Command="{Binding OkCommand}" Style="{StaticResource Btn}" Margin="0,0,10,0" IsDefault="True">
                <TextBlock Text="OK" FontSize="12" FontWeight="SemiBold" Foreground="#1565C0"/>
            </Button>
            <Button Command="{Binding CancelCommand}" Style="{StaticResource Btn}" IsCancel="True">
                <TextBlock Text="Cancel" FontSize="12" FontWeight="SemiBold" Foreground="#C0392B"/>
            </Button>
        </StackPanel>
    </Grid>
</Window>
