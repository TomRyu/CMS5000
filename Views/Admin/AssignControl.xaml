<UserControl x:Class="CMS5000.Views.Admin.AssignControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="Hdr" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="Margin"     Value="2,0,0,4"/>
        </Style>

        <Style x:Key="DG" TargetType="DataGrid">
            <Setter Property="Background"               Value="#FFFFFF"/>
            <Setter Property="Foreground"               Value="#1F2937"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="BorderBrush"              Value="#C7CED9"/>
            <Setter Property="GridLinesVisibility"      Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E5E9F0"/>
            <Setter Property="VerticalGridLinesBrush"   Value="#E5E9F0"/>
            <Setter Property="RowBackground"            Value="#FFFFFF"/>
            <Setter Property="AlternatingRowBackground" Value="#F7F9FC"/>
            <Setter Property="SelectionMode"            Value="Single"/>
            <Setter Property="FontSize"                 Value="12"/>
            <Setter Property="ColumnHeaderHeight"       Value="28"/>
            <Setter Property="RowHeight"                Value="26"/>
            <Setter Property="AutoGenerateColumns"      Value="False"/>
            <Setter Property="CanUserAddRows"           Value="False"/>
            <Setter Property="CanUserResizeRows"        Value="False"/>
            <Setter Property="IsReadOnly"               Value="True"/>
            <Setter Property="HeadersVisibility"        Value="Column"/>
        </Style>

        <Style x:Key="PhysHdr" TargetType="DataGridColumnHeader">
            <Setter Property="Background"           Value="#EEF2F8"/>
            <Setter Property="Foreground"           Value="#475569"/>
            <Setter Property="FontWeight"           Value="Normal"/>
            <Setter Property="FontSize"             Value="10"/>
            <Setter Property="Padding"              Value="6,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush"          Value="#C7CED9"/>
            <Setter Property="BorderThickness"      Value="0,0,1,1"/>
        </Style>

        <!-- 셀: 수직 가운데 정렬 + 여백으로 글자 잘림 방지. 헤더와 동일하게 폰트 12 명시 -->
        <Style TargetType="DataGridCell">
            <Setter Property="FontSize"                 Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding"                  Value="6,2"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Padding" Value="20,7"/>
            <Setter Property="Cursor"  Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="#FFFFFF" CornerRadius="4" BorderBrush="#9AA7BD" BorderThickness="1" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="#EAF1FB"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bg" Property="Background"  Value="#F1F2F4"/>
                                <Setter TargetName="bg" Property="BorderBrush" Value="#D5D8DE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Logical(논리) 구조 그리드: 녹색 계열로 구분 -->
        <Style x:Key="DGLogical" TargetType="DataGrid" BasedOn="{StaticResource DG}">
            <Setter Property="RowBackground"            Value="#EAF7EE"/>
            <Setter Property="AlternatingRowBackground" Value="#D8EFDF"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#CDE8D5"/>
            <Setter Property="VerticalGridLinesBrush"   Value="#CDE8D5"/>
        </Style>
        <Style x:Key="LogHdr" TargetType="DataGridColumnHeader" BasedOn="{StaticResource PhysHdr}">
            <Setter Property="Background" Value="#DCEFE2"/>
            <Setter Property="Foreground" Value="#1E7D34"/>
        </Style>

        <!-- 구조 구분 라벨 -->
        <Style x:Key="StructLabel" TargetType="TextBlock">
            <Setter Property="FontSize"            Value="13"/>
            <Setter Property="FontWeight"          Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="150"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="Bold" Foreground="#1F2937" VerticalAlignment="Center"/>
            <TextBlock Text="  ..." FontSize="12" Foreground="#2563EB" VerticalAlignment="Center"
                       Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 좌측: Physical Structure -->
            <DockPanel Grid.Column="0">
                <Border DockPanel.Dock="Top" Background="#EAF0F8" BorderBrush="#C7CED9" BorderThickness="1"
                        Margin="0,0,0,6" Padding="0,6">
                    <TextBlock Text="Physical Structure" Style="{StaticResource StructLabel}" Foreground="#1565C0"/>
                </Border>
                <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/><RowDefinition Height="8"/>
                    <RowDefinition Height="*"/><RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0">
                    <TextBlock DockPanel.Dock="Top" Text="RACK" Style="{StaticResource Hdr}"/>
                    <DataGrid Style="{StaticResource DG}" ColumnHeaderStyle="{StaticResource PhysHdr}" ItemsSource="{Binding Racks}"
                              SelectedItem="{Binding SelectedRack, Mode=TwoWay}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="RackID"   Binding="{Binding RackId}"   Width="Auto" MinWidth="60"/>
                            <DataGridTextColumn Header="Name"     Binding="{Binding Name}"     Width="*"/>
                            <DataGridTextColumn Header="Activity" Binding="{Binding Activity}" Width="Auto" MinWidth="56"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>

                <DockPanel Grid.Row="2">
                    <TextBlock DockPanel.Dock="Top" Text="MODULE" Style="{StaticResource Hdr}"/>
                    <DataGrid Style="{StaticResource DG}" ColumnHeaderStyle="{StaticResource PhysHdr}" ItemsSource="{Binding Modules}"
                              SelectedItem="{Binding SelectedModule, Mode=TwoWay}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ModuleID"   Binding="{Binding ModuleId}"   Width="Auto" MinWidth="60"/>
                            <DataGridTextColumn Header="Name"       Binding="{Binding Name}"       Width="*"/>
                            <DataGridTextColumn Header="Activity"   Binding="{Binding Activity}"   Width="Auto" MinWidth="56"/>
                            <DataGridTextColumn Header="ModuleType" Binding="{Binding ModuleType}" Width="Auto" MinWidth="88"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>

                <DockPanel Grid.Row="4">
                    <TextBlock DockPanel.Dock="Top" Text="CHANNEL" Style="{StaticResource Hdr}"/>
                    <DataGrid Style="{StaticResource DG}" ColumnHeaderStyle="{StaticResource PhysHdr}" ItemsSource="{Binding Channels}"
                              SelectedItem="{Binding SelectedChannel, Mode=TwoWay}">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAssigned}" Value="True">
                                        <Setter Property="Foreground" Value="#2563EB"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ChannelID"   Binding="{Binding ChannelId}"   Width="Auto" MinWidth="60"/>
                            <DataGridTextColumn Header="Name"        Binding="{Binding Name}"        Width="*"/>
                            <DataGridTextColumn Header="Activity"    Binding="{Binding Activity}"    Width="Auto" MinWidth="56"/>
                            <DataGridTextColumn Header="ChannelType" Binding="{Binding ChannelType}" Width="Auto" MinWidth="88"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
                </Grid>
            </DockPanel>

            <!-- 우측: Logical Structure -->
            <DockPanel Grid.Column="2">
                <Border DockPanel.Dock="Top" Background="#E1F0E6" BorderBrush="#B6D7C0" BorderThickness="1"
                        Margin="0,0,0,6" Padding="0,6">
                    <TextBlock Text="Logical Structure" Style="{StaticResource StructLabel}" Foreground="#1E7D34"/>
                </Border>
                <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/><RowDefinition Height="8"/>
                    <RowDefinition Height="*"/><RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0">
                    <TextBlock DockPanel.Dock="Top" Text="TRAIN" Style="{StaticResource Hdr}"/>
                    <DataGrid Style="{StaticResource DGLogical}" ColumnHeaderStyle="{StaticResource LogHdr}" ItemsSource="{Binding Trains}"
                              SelectedItem="{Binding SelectedTrain, Mode=TwoWay}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="TrainID"  Binding="{Binding TrainId}"  Width="Auto" MinWidth="60"/>
                            <DataGridTextColumn Header="Name"     Binding="{Binding Name}"     Width="*"/>
                            <DataGridTextColumn Header="Activity" Binding="{Binding Activity}" Width="Auto" MinWidth="56"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>

                <DockPanel Grid.Row="2">
                    <TextBlock DockPanel.Dock="Top" Text="COMPONENT" Style="{StaticResource Hdr}"/>
                    <DataGrid Style="{StaticResource DGLogical}" ColumnHeaderStyle="{StaticResource LogHdr}" ItemsSource="{Binding Components}"
                              SelectedItem="{Binding SelectedComponent, Mode=TwoWay}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ComponentID" Binding="{Binding ComponentId}" Width="Auto" MinWidth="80"/>
                            <DataGridTextColumn Header="Name"        Binding="{Binding Name}"        Width="*"/>
                            <DataGridTextColumn Header="Activity"    Binding="{Binding Activity}"    Width="Auto" MinWidth="56"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>

                <DockPanel Grid.Row="4">
                    <TextBlock DockPanel.Dock="Top" Text="POINT" Style="{StaticResource Hdr}"/>
                    <DataGrid Style="{StaticResource DGLogical}" ColumnHeaderStyle="{StaticResource LogHdr}" ItemsSource="{Binding Points}"
                              SelectedItem="{Binding SelectedPoint, Mode=TwoWay}">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAssigned}" Value="True">
                                        <Setter Property="Foreground" Value="#2563EB"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="PointID"  Binding="{Binding PointId}"  Width="Auto" MinWidth="60"/>
                            <DataGridTextColumn Header="Name"     Binding="{Binding Name}"     Width="*"/>
                            <DataGridTextColumn Header="Activity" Binding="{Binding Activity}" Width="Auto" MinWidth="56"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
                </Grid>
            </DockPanel>
        </Grid>

        <!-- ASSIGN 목록 -->
        <DockPanel Grid.Row="2" Margin="0,10,0,0">
            <TextBlock DockPanel.Dock="Top" Text="ASSIGN LIST" Style="{StaticResource Hdr}"/>
            <DataGrid Style="{StaticResource DG}" ColumnHeaderStyle="{StaticResource PhysHdr}" ItemsSource="{Binding AssignList}"
                      SelectedItem="{Binding SelectedAssign, Mode=TwoWay}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="StationID"   Binding="{Binding StationId}"   Width="Auto" MinWidth="60"/>
                    <DataGridTextColumn Header="RackID"      Binding="{Binding RackId}"      Width="Auto" MinWidth="56"/>
                    <DataGridTextColumn Header="ModuleID"    Binding="{Binding ModuleId}"    Width="Auto" MinWidth="60"/>
                    <DataGridTextColumn Header="ChannelID"   Binding="{Binding ChannelId}"   Width="Auto" MinWidth="60"/>
                    <DataGridTextColumn Header="ChannelName" Binding="{Binding ChannelName}" Width="*"/>
                    <DataGridTextColumn Header="TrainID"     Binding="{Binding TrainId}"     Width="Auto" MinWidth="56"/>
                    <DataGridTextColumn Header="ComponentID" Binding="{Binding ComponentId}" Width="Auto" MinWidth="80"/>
                    <DataGridTextColumn Header="PointID"     Binding="{Binding PointId}"     Width="Auto" MinWidth="56"/>
                    <DataGridTextColumn Header="PointName"   Binding="{Binding PointName}"   Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <!-- 선택 + 버튼 -->
        <Border Grid.Row="3" Background="#FFFFFF" BorderBrush="#D5DAE2" BorderThickness="1"
                CornerRadius="4" Padding="14,8" Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="34"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="선택 채널 : " FontSize="12" Foreground="#64748B"/>
                    <TextBlock Text="{Binding SelectedChannelText}" FontSize="12" FontWeight="SemiBold" Foreground="#1F2937"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="&#x2194;" FontSize="15" Foreground="#2563EB"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="선택 포인트 : " FontSize="12" Foreground="#64748B"/>
                    <TextBlock Text="{Binding SelectedPointText}" FontSize="12" FontWeight="SemiBold" Foreground="#1F2937"/>
                </StackPanel>
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding AssignCommand}" Style="{StaticResource Btn}" IsEnabled="{Binding CanAssign}" Margin="0,0,8,0">
                        <TextBlock Text="ASSIGN" FontSize="12" FontWeight="SemiBold" Foreground="#1565C0"/>
                    </Button>
                    <Button Command="{Binding UnAssignCommand}" Style="{StaticResource Btn}" IsEnabled="{Binding CanUnAssign}">
                        <TextBlock Text="UN-ASSIGN" FontSize="12" FontWeight="SemiBold" Foreground="#C0392B"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <TextBlock Grid.Row="4" Text="{Binding Status}" FontSize="12" Foreground="#64748B"
                   Margin="2,8,0,0" TextTrimming="CharacterEllipsis"/>
    </Grid>
</UserControl>
