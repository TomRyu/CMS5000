<UserControl x:Class="CMS5000.Views.Admin.RackModifyControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CMS5000.ViewModels.Admin"
             xmlns:ctl="clr-namespace:CMS5000.Controls"
             Background="#F0F0F3">
    <UserControl.Resources>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Input" TargetType="TextBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="BorderBrush" Value="#B8C0CC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Combo" TargetType="ComboBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="BorderBrush" Value="#B8C0CC"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Grp" TargetType="GroupBox">
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#B8C0CC"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="BluBtn" TargetType="Button">
            <Setter Property="Padding" Value="22,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="#FFFFFF" CornerRadius="4" BorderBrush="#9AA7BD" BorderThickness="1" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#EAF1FB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RedBtn" TargetType="Button" BasedOn="{StaticResource BluBtn}"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="56"/>
        </Grid.RowDefinitions>

        <!-- ══ 상단 헤더 ═══════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#F4F5F7" Padding="20,14" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="STATION ID :" Style="{StaticResource Lbl}" Margin="0,0,8,0"/>
                <ctl:NumericUpDown Grid.Column="1" Value="{Binding StationId}" Minimum="0" Maximum="255" IsEnabled="False"/>

                <TextBlock Grid.Column="3" Text="RACK ID :" Style="{StaticResource Lbl}" Margin="0,0,8,0"/>
                <ctl:NumericUpDown Grid.Column="4" Value="{Binding RackId}" Minimum="0" Maximum="255" IsEnabled="False"/>

                <CheckBox Grid.Column="6" IsChecked="{Binding Activity}" Content="Activity"
                          Foreground="#1F2937" FontSize="12" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ══ 탭 콘텐츠 ══════════════════════════════════════ -->
        <TabControl Grid.Row="1" Background="#F0F0F3" BorderBrush="#C8CDD6" Margin="0" Padding="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="#E1E4E8"/>
                    <Setter Property="Foreground" Value="#333333"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="Padding" Value="14,6"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#F0F0F3"/>
                            <Setter Property="Foreground" Value="#1565C0"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Resources>

            <!-- ════════════ Tab 1: INFO ════════════ -->
            <TabItem Header="INFO...">
                <Grid Margin="16,14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="270"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Name" Style="{StaticResource Lbl}" HorizontalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource Input}" HorizontalContentAlignment="Center"/>
                            </Grid>

                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Plant" Style="{StaticResource Lbl}" HorizontalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding Location, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource Input}" Height="44"
                                         AcceptsReturn="True" TextWrapping="Wrap"
                                         VerticalContentAlignment="Top" VerticalScrollBarVisibility="Auto"/>
                            </Grid>

                            <GroupBox Header="TCP/IP" Style="{StaticResource Grp}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="90"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="IP Addr" Style="{StaticResource Lbl}"/>
                                    <TextBox Grid.Column="1" Text="{Binding LocalIp, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource Input}" Margin="0,0,12,0" HorizontalContentAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="Port" Style="{StaticResource Lbl}"/>
                                    <ctl:NumericUpDown Grid.Column="3" Value="{Binding LocalPort}" Minimum="0" Maximum="65535"/>
                                </Grid>
                            </GroupBox>

                            <GroupBox Header="Serial Port" Style="{StaticResource Grp}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Port Num." Style="{StaticResource Lbl}"/>
                                    <ComboBox Grid.Row="0" Grid.Column="1" IsEditable="True"
                                              ItemsSource="{Binding Source={x:Static vm:RackModifyViewModel.ComPorts}}"
                                              Text="{Binding LocalComPort}" Style="{StaticResource Combo}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="DataBit" Style="{StaticResource Lbl}"/>
                                    <ComboBox Grid.Row="0" Grid.Column="4"
                                              ItemsSource="{Binding Source={x:Static vm:RackModifyViewModel.DataBits}}"
                                              SelectedIndex="{Binding DataBit}" Style="{StaticResource Combo}"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Baudrate" Style="{StaticResource Lbl}"/>
                                    <ComboBox Grid.Row="2" Grid.Column="1" IsEditable="True"
                                              ItemsSource="{Binding Source={x:Static vm:RackModifyViewModel.BaudRates}}"
                                              Text="{Binding BaudRate}" Style="{StaticResource Combo}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="3" Text="ParityBit" Style="{StaticResource Lbl}"/>
                                    <ComboBox Grid.Row="2" Grid.Column="4"
                                              ItemsSource="{Binding Source={x:Static vm:RackModifyViewModel.ParityBits}}"
                                              SelectedIndex="{Binding ParityBit}" Style="{StaticResource Combo}"/>

                                    <TextBlock Grid.Row="4" Grid.Column="3" Text="StopBit" Style="{StaticResource Lbl}"/>
                                    <ComboBox Grid.Row="4" Grid.Column="4"
                                              ItemsSource="{Binding Source={x:Static vm:RackModifyViewModel.StopBits}}"
                                              SelectedIndex="{Binding StopBit}" Style="{StaticResource Combo}"/>
                                </Grid>
                            </GroupBox>
                        </StackPanel>

                        <GroupBox Grid.Column="2" Header="Waveform" Style="{StaticResource Grp}" VerticalAlignment="Top" Margin="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="64"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Interval" Style="{StaticResource Lbl}"/>
                                <ctl:NumericUpDown Grid.Column="1" Value="{Binding WaveformInterval}" Minimum="0" Maximum="3600"/>
                                <TextBlock Grid.Column="2" Text="[sec]" Style="{StaticResource Lbl}" Margin="8,0,0,0"/>
                            </Grid>
                        </GroupBox>
                    </Grid>

                    <Border Grid.Row="1" Margin="0,16,0,0" Padding="10,12" Background="#F4F5F7"
                            BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="3">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <CheckBox IsChecked="{Binding Trend}" Content="Trend"
                                      Foreground="#1F2937" FontSize="12" VerticalAlignment="Center" Margin="6,0,40,0"/>
                            <TextBlock Text="STATIC(sec)" Style="{StaticResource Lbl}" Margin="0,0,10,0"/>
                            <ctl:NumericUpDown Width="100" Value="{Binding StaticTrend}" Minimum="0" Maximum="86400"
                                               IsEnabled="{Binding TrendEnabled}"/>
                            <TextBlock Text="DYNAMIC(sec)" Style="{StaticResource Lbl}" Margin="40,0,10,0"/>
                            <ctl:NumericUpDown Width="100" Value="{Binding DynamicTrend}" Minimum="0" Maximum="86400"
                                               IsEnabled="{Binding TrendEnabled}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ════════════ Tab 2: Modbus ════════════ -->
            <TabItem Header="Modbus">
                <StackPanel Margin="16,16">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="320"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Communication Mode" Style="{StaticResource Lbl}"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding Source={x:Static vm:RackModifyViewModel.ModbusModes}}"
                                  SelectedIndex="{Binding ModbusModeIndex}" Style="{StaticResource Combo}"/>
                    </Grid>

                    <GroupBox Header="TCP/IP" Style="{StaticResource Grp}" HorizontalAlignment="Left" Width="470">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="IP Addr" Style="{StaticResource Lbl}"/>
                            <TextBox Grid.Column="1" Text="{Binding ModbusIp, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource Input}" Margin="0,0,12,0" HorizontalContentAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="PORT" Style="{StaticResource Lbl}"/>
                            <ctl:NumericUpDown Grid.Column="3" Value="{Binding ModbusPort}" Minimum="0" Maximum="65535"/>
                        </Grid>
                    </GroupBox>
                </StackPanel>
            </TabItem>

            <!-- ════════════ Tab 3: Server Connect ════════════ -->
            <TabItem Header="Server Connect.">
                <StackPanel Margin="16,16">
                    <GroupBox Header="TCP/IP" Style="{StaticResource Grp}" HorizontalAlignment="Left" Width="420" Margin="0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="IP" Style="{StaticResource Lbl}"/>
                            <TextBox Grid.Column="1" Text="{Binding ServerIp, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource Input}" Margin="0,0,12,0" HorizontalContentAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="PORT" Style="{StaticResource Lbl}"/>
                            <ctl:NumericUpDown Grid.Column="3" Value="{Binding ServerPort}" Minimum="0" Maximum="65535"/>
                        </Grid>
                    </GroupBox>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- ══ 버튼 ═══════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="#F4F5F7" BorderBrush="#D0D0D0" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,12">
                <Button Command="{Binding ModifyCommand}" Style="{StaticResource BluBtn}" Margin="0,0,10,0">
                    <TextBlock Text="MODIFY" FontSize="12" FontWeight="SemiBold" Foreground="#1565C0"/>
                </Button>
                <Button Command="{Binding CancelCommand}" Style="{StaticResource RedBtn}">
                    <TextBlock Text="CANCEL" FontSize="12" FontWeight="SemiBold" Foreground="#C0392B"/>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
