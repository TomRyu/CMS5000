<UserControl x:Class="CMS5000.Views.Log.LogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource ContentBgBrush}">

    <UserControl.Resources>
        <!-- 필터 토글 버튼 베이스. 활성 표시는 각 버튼의 DataTrigger가 Background/Foreground를 바꿔 처리 -->
        <Style x:Key="FilterChipStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Background" Value="{StaticResource InputBgBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="14" Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <DockPanel Margin="24,20">

        <!-- 페이지 제목 + 통계 -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="로그" FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Text="{Binding TotalCount, StringFormat='전체 {0}건'}"
                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="14,4,0,0"/>
                <Border Style="{StaticResource BadgeWarningStyle}" Margin="10,2,0,0"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding WarningCount, StringFormat='경고 {0}'}"
                               FontSize="11" Foreground="White"/>
                </Border>
                <Border Style="{StaticResource BadgeDangerStyle}" Margin="6,2,0,0"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding ErrorCount, StringFormat='오류 {0}'}"
                               FontSize="11" Foreground="White"/>
                </Border>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="로그 폴더 열기" Command="{Binding OpenLogFolderCommand}"
                        Style="{StaticResource FlatButtonStyle}" Padding="12,7" Margin="0,0,8,0" Cursor="Hand"/>
                <Button Content="로그 비우기" Command="{Binding ClearCommand}"
                        Style="{StaticResource FlatButtonStyle}" Padding="12,7" Cursor="Hand"/>
            </StackPanel>
        </Grid>

        <!-- 필터 줄: 레벨 칩 + 검색 -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="전체" CommandParameter="All" Command="{Binding SetLevelFilterCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource FilterChipStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsAll}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource AccentBlueBrush}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="정보" CommandParameter="Info" Command="{Binding SetLevelFilterCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource FilterChipStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsInfo}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource AccentBlueBrush}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="성공" CommandParameter="Success" Command="{Binding SetLevelFilterCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource FilterChipStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource StatusGoodBrush}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource StatusGoodBrush}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="경고" CommandParameter="Warning" Command="{Binding SetLevelFilterCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource FilterChipStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsWarning}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource StatusWarningBrush}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource StatusWarningBrush}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="오류" CommandParameter="Error" Command="{Binding SetLevelFilterCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource FilterChipStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsError}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource StatusDangerBrush}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource StatusDangerBrush}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <Border HorizontalAlignment="Right" Width="280"
                    BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1"
                    CornerRadius="4" Background="{StaticResource InputBgBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="🔍" FontSize="12"
                               VerticalAlignment="Center" Margin="8,0,4,0"
                               Foreground="{StaticResource TextDisabledBrush}"/>
                    <TextBox Grid.Column="1" BorderThickness="0" FontSize="12"
                             Background="Transparent" Padding="0,6,8,6"
                             VerticalContentAlignment="Center"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=150}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- 로그 테이블 -->
        <Border Style="{StaticResource CardStyle}" Padding="0">
            <DockPanel>
                <!-- 컬럼 헤더 -->
                <Border DockPanel.Dock="Top" Background="{StaticResource TreePanelHeaderBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,0,1"
                        Padding="16,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="64"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="시각"   FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="수준"   FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="2" Text="분류"   FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="3" Text="내용"   FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="4" Text="사용자" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Grid>
                </Border>

                <!-- 빈 상태 안내 -->
                <TextBlock DockPanel.Dock="Top" Text="표시할 로그가 없습니다."
                           Foreground="{StaticResource TextDisabledBrush}" FontSize="13"
                           HorizontalAlignment="Center" Margin="0,40">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding TotalCount}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- 로그 행 -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding LogView}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource CardBorderBrush}"
                                        BorderThickness="0,0,0,1" Padding="16,7">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="64"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding TimeDisplay}"
                                                   FontFamily="Consolas" FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"/>

                                        <!-- 수준 점 + 라벨 (색은 Level 트리거로) -->
                                        <Border Grid.Column="1" CornerRadius="9" Padding="7,1"
                                                HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource TextSecondaryBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Level}" Value="Success">
                                                            <Setter Property="Background" Value="{StaticResource StatusGoodBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                            <Setter Property="Background" Value="{StaticResource StatusWarningBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Level}" Value="Error">
                                                            <Setter Property="Background" Value="{StaticResource StatusDangerBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding LevelLabel}" FontSize="10"
                                                       Foreground="White" HorizontalAlignment="Center"/>
                                        </Border>

                                        <TextBlock Grid.Column="2" Text="{Binding Category}"
                                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Message}"
                                                   FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <TextBlock Grid.Column="4" Text="{Binding User}"
                                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </DockPanel>
</UserControl>
