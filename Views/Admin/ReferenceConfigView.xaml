<Window x:Class="CMS5000.Views.Admin.ReferenceConfigView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CMS5000.ViewModels.Admin"
        xmlns:ctl="clr-namespace:CMS5000.Controls"
        Title="{Binding DialogTitle}"
        Width="812" Height="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F0F3">

    <Window.Resources>
        <Style x:Key="L" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#222222"/>
        </Style>
        <Style x:Key="Cap" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#333333"/>
        </Style>
        <Style x:Key="Input" TargetType="TextBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="BorderBrush" Value="#B8C0CC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Combo" TargetType="ComboBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="BorderBrush" Value="#B8C0CC"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Rad" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <!-- 그룹 프레임 -->
        <Style x:Key="GrpFrame" TargetType="Border">
            <Setter Property="BorderBrush" Value="#AFB6C0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="2"/>
        </Style>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="#FFFFFF" CornerRadius="4" BorderBrush="#9AA7BD" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="#EAF1FB"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SmallBtn" TargetType="Button" BasedOn="{StaticResource Btn}"/>
    </Window.Resources>

    <!-- 원본 폼 좌표(클라이언트 기준)로 절대 배치 -->
    <Canvas Width="792" Height="575">

        <!-- ════════ 헤더 (UltraPanel1 @12,12 768x68) ════════ -->
        <Canvas Canvas.Left="12" Canvas.Top="12" Width="768" Height="68">
            <Border Width="768" Height="68" Background="#F7F8FA" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="2"/>
            <TextBlock Style="{StaticResource L}" Text="STATION ID" Canvas.Left="17" Canvas.Top="13"/>
            <ctl:NumericUpDown Canvas.Left="93"  Canvas.Top="9"  Width="100" Height="21" Value="{Binding StationId, Mode=OneWay}" IsEnabled="False"/>
            <TextBlock Style="{StaticResource L}" Text="RACK ID" Canvas.Left="209" Canvas.Top="14"/>
            <ctl:NumericUpDown Canvas.Left="284" Canvas.Top="10" Width="101" Height="21" Value="{Binding RackId, Mode=OneWay}" IsEnabled="False"/>
            <TextBlock Style="{StaticResource L}" Text="MODULE ID" Canvas.Left="400" Canvas.Top="14"/>
            <ctl:NumericUpDown Canvas.Left="476" Canvas.Top="9"  Width="99"  Height="21" Value="{Binding ModuleId, Mode=OneWay}" IsEnabled="False"/>
            <TextBlock Style="{StaticResource L}" Text="ID" Canvas.Left="582" Canvas.Top="13"/>
            <ctl:NumericUpDown Canvas.Left="644" Canvas.Top="8"  Width="100" Height="21" Value="{Binding ChannelId, Mode=OneWay}" IsEnabled="False"/>

            <TextBlock Style="{StaticResource L}" Text="Name" Canvas.Left="17" Canvas.Top="39"/>
            <TextBox Style="{StaticResource Input}" Canvas.Left="93" Canvas.Top="35" Width="100" Height="21"
                     Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBlock Style="{StaticResource L}" Text="Activity" Canvas.Left="209" Canvas.Top="42"/>
            <ComboBox Style="{StaticResource Combo}" FontSize="12" Canvas.Left="285" Canvas.Top="40" Width="100" Height="21"
                      ItemsSource="{Binding Source={x:Static vm:ReferenceConfigViewModel.ActivityModes}}"
                      SelectedIndex="{Binding ActivityMode}"/>
            <TextBlock Style="{StaticResource L}" Text="ChannelType" Canvas.Left="394" Canvas.Top="43"/>
            <ComboBox Style="{StaticResource Combo}" FontSize="12" Canvas.Left="475" Canvas.Top="39" Width="100" Height="21"
                      ItemsSource="{Binding ChannelTypes}" DisplayMemberPath="DisplayName" SelectedIndex="{Binding ChannelTypeIndex}"/>
            <CheckBox Content="Assign" Foreground="#1F2937" FontSize="12" Canvas.Left="683" Canvas.Top="42" IsChecked="{Binding Assign}"/>
        </Canvas>

        <!-- ════════ TabControl1 @12,86 768x390 ════════ -->
        <TabControl Canvas.Left="12" Canvas.Top="86" Width="768" Height="424" Background="#F0F0F3" BorderBrush="#C8CDD6">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="#E1E4E8"/>
                    <Setter Property="Foreground" Value="#333333"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="Padding" Value="14,5"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#F0F0F3"/>
                            <Setter Property="Foreground" Value="#1565C0"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Resources>

            <!-- ─────────── Tab1: INFO. ─────────── -->
            <TabItem Header="INFO.">
                <Canvas Background="#F0F0F3">
                    <!-- 좌상단 : WaveForm Interval / EpRevolution -->
                    <TextBlock Style="{StaticResource L}" Text="Rpm WaveForm Interval" Canvas.Left="28" Canvas.Top="44"/>
                    <ctl:NumericUpDown Canvas.Left="170" Canvas.Top="40" Width="125" Height="21" Maximum="100000" Value="{Binding WaveFormInterval}"/>
                    <TextBlock Style="{StaticResource L}" Text="Event Per Revolution" Canvas.Left="41" Canvas.Top="68"/>
                    <ctl:NumericUpDown Canvas.Left="170" Canvas.Top="64" Width="125" Height="21" Maximum="100000" Value="{Binding EpRevolution}"/>
                    <TextBlock Style="{StaticResource Cap}" Text="(1~255)" Canvas.Left="299" Canvas.Top="44"/>
                    <TextBlock Style="{StaticResource Cap}" Text="(1~255)" Canvas.Left="299" Canvas.Top="68"/>

                    <!-- Rotation Direction @22,122 274x39 -->
                    <Canvas Canvas.Left="22" Canvas.Top="122" Width="274" Height="39">
                        <Border Style="{StaticResource GrpFrame}" Width="274" Height="39"/>
                        <Border Canvas.Left="8" Canvas.Top="-8" Background="#F0F0F3" Padding="3,0"><TextBlock Style="{StaticResource Cap}" Text="Rotation Direction"/></Border>
                        <RadioButton Style="{StaticResource Rad}" Content="CW"  Canvas.Left="100" Canvas.Top="15" IsChecked="{Binding RotationCw}"/>
                        <RadioButton Style="{StaticResource Rad}" Content="CCW" Canvas.Left="185" Canvas.Top="15" IsChecked="{Binding RotationCcw}"/>
                    </Canvas>

                    <!-- Signal Polarity @22,169 274x39 -->
                    <Canvas Canvas.Left="22" Canvas.Top="169" Width="274" Height="39">
                        <Border Style="{StaticResource GrpFrame}" Width="274" Height="39"/>
                        <Border Canvas.Left="8" Canvas.Top="-8" Background="#F0F0F3" Padding="3,0"><TextBlock Style="{StaticResource Cap}" Text="Signal Polarity"/></Border>
                        <RadioButton Style="{StaticResource Rad}" Content="Notch"      Canvas.Left="100" Canvas.Top="15" IsChecked="{Binding PolarityNotch}"/>
                        <RadioButton Style="{StaticResource Rad}" Content="Projection" Canvas.Left="185" Canvas.Top="15" IsChecked="{Binding PolarityProjection}"/>
                    </Canvas>

                    <!-- Hysteresis @22,218 274x46 -->
                    <Canvas Canvas.Left="22" Canvas.Top="218" Width="274" Height="46">
                        <Border Style="{StaticResource GrpFrame}" Width="274" Height="46"/>
                        <Border Canvas.Left="8" Canvas.Top="-8" Background="#F0F0F3" Padding="3,0"><TextBlock Style="{StaticResource Cap}" Text="Hysteresis Level (0.2 ~ 2.5 V)"/></Border>
                        <ctl:NumericUpDown Canvas.Left="158" Canvas.Top="19" Width="104" Height="21" Maximum="10" DecimalPlaces="1" Value="{Binding HysteresisLevel}"/>
                    </Canvas>

                    <!-- Reference Reassignment @22,278 274x73 -->
                    <Canvas Canvas.Left="22" Canvas.Top="278" Width="274" Height="73">
                        <Border Style="{StaticResource GrpFrame}" Width="274" Height="73"/>
                        <Border Canvas.Left="8" Canvas.Top="-8" Background="#F0F0F3" Padding="3,0"><TextBlock Style="{StaticResource Cap}" Text="Reference Reassignment"/></Border>
                        <RadioButton Style="{StaticResource Rad}" Content="Simulated Speed"     Canvas.Left="20" Canvas.Top="23" IsChecked="{Binding ReassignSimulated}" IsEnabled="{Binding ReassignEnabled}"/>
                        <RadioButton Style="{StaticResource Rad}" Content="Alternate Reference" Canvas.Left="20" Canvas.Top="45" IsChecked="{Binding ReassignAlternate}" IsEnabled="{Binding ReassignEnabled}"/>
                        <ctl:NumericUpDown Canvas.Left="158" Canvas.Top="20" Width="105" Height="21" Maximum="100000" Value="{Binding Speed}" IsEnabled="{Binding SpeedEnabled}"/>
                        <ComboBox Style="{StaticResource Combo}" Canvas.Left="158" Canvas.Top="44" Width="105" Height="21"
                                  ItemsSource="{Binding Source={x:Static vm:ReferenceConfigViewModel.AlternateIds}}" SelectedIndex="{Binding AlternateId}" IsEnabled="{Binding AltEnabled}"/>
                    </Canvas>

                    <!-- Threshold @440,9 265x107 -->
                    <Canvas Canvas.Left="440" Canvas.Top="9" Width="265" Height="107">
                        <Border Style="{StaticResource GrpFrame}" Width="265" Height="107"/>
                        <Border Canvas.Left="8" Canvas.Top="-8" Background="#F0F0F3" Padding="3,0"><TextBlock Style="{StaticResource Cap}" Text="Threshold"/></Border>
                        <!-- Type @9,19 90x75 -->
                        <Canvas Canvas.Left="9" Canvas.Top="19" Width="90" Height="75">
                            <Border Style="{StaticResource GrpFrame}" Width="90" Height="75"/>
                            <Border Canvas.Left="8" Canvas.Top="-8" Background="#F0F0F3" Padding="3,0"><TextBlock Style="{StaticResource Cap}" Text="Type"/></Border>
                            <RadioButton Style="{StaticResource Rad}" Content="Auto"   Canvas.Left="11" Canvas.Top="20" IsChecked="{Binding ThresholdAuto}"/>
                            <RadioButton Style="{StaticResource Rad}" Content="Manual" Canvas.Left="11" Canvas.Top="42" IsChecked="{Binding ThresholdManual}"/>
                        </Canvas>
                        <!-- Value @115,18 122x76 -->
                        <Canvas Canvas.Left="115" Canvas.Top="18" Width="122" Height="76">
                            <Border Style="{StaticResource GrpFrame}" Width="122" Height="76"/>
                            <Border Canvas.Left="8" Canvas.Top="-8" Background="#F0F0F3" Padding="3,0"><TextBlock Style="{StaticResource Cap}" Text="Value(-20~0.0V)"/></Border>
                            <ctl:NumericUpDown Canvas.Left="12" Canvas.Top="20" Width="97" Height="21" Minimum="-20" Maximum="20" DecimalPlaces="1" Value="{Binding ThresholdLevel}"/>
                            <Button Style="{StaticResource SmallBtn}" Content="Adjust" Canvas.Left="12" Canvas.Top="47" Width="94" Height="22"/>
                        </Canvas>
                    </Canvas>

                    <!-- Steady State @440,123 265x69 -->
                    <Canvas Canvas.Left="440" Canvas.Top="123" Width="265" Height="69">
                        <Border Style="{StaticResource GrpFrame}" Width="265" Height="69"/>
                        <Border Canvas.Left="8" Canvas.Top="-8" Background="#F0F0F3" Padding="3,0"><TextBlock Style="{StaticResource Cap}" Text="Steady State"/></Border>
                        <TextBlock Style="{StaticResource Cap}" Text="Fluctuation Range" Canvas.Left="7" Canvas.Top="20"/>
                        <ctl:NumericUpDown Canvas.Left="117" Canvas.Top="15" Width="99" Height="21" Maximum="100000" Value="{Binding FluctuationRange}"/>
                        <TextBlock Style="{StaticResource Cap}" Text="(rpm)" Canvas.Left="218" Canvas.Top="20"/>
                        <TextBlock Style="{StaticResource Cap}" Text="Unaltered Time" Canvas.Left="17" Canvas.Top="42"/>
                        <ctl:NumericUpDown Canvas.Left="117" Canvas.Top="37" Width="99" Height="21" Maximum="100000" Value="{Binding UnalteredTime}"/>
                        <TextBlock Style="{StaticResource Cap}" Text="(sec)" Canvas.Left="218" Canvas.Top="42"/>
                    </Canvas>

                    <!-- RPM @440,200 265x62 -->
                    <Canvas Canvas.Left="440" Canvas.Top="200" Width="265" Height="62">
                        <Border Style="{StaticResource GrpFrame}" Width="265" Height="62"/>
                        <Border Canvas.Left="8" Canvas.Top="-8" Background="#F0F0F3" Padding="3,0"><TextBlock Style="{StaticResource Cap}" Text="RPM"/></Border>
                        <TextBlock Style="{StaticResource Cap}" Text="Upper Limit" Canvas.Left="62" Canvas.Top="17"/>
                        <ctl:NumericUpDown Canvas.Left="144" Canvas.Top="13" Width="100" Height="21" Maximum="100000" Value="{Binding UpperLimit}"/>
                        <TextBlock Style="{StaticResource Cap}" Text="Clamp Value" Canvas.Left="62" Canvas.Top="40"/>
                        <ctl:NumericUpDown Canvas.Left="144" Canvas.Top="35" Width="100" Height="21" Maximum="100000" Value="{Binding ClampValue}"/>
                    </Canvas>

                    <!-- Orientation @441,270 264x37 -->
                    <Canvas Canvas.Left="441" Canvas.Top="270" Width="264" Height="37">
                        <Border Style="{StaticResource GrpFrame}" Width="264" Height="37"/>
                        <Border Canvas.Left="8" Canvas.Top="-8" Background="#F0F0F3" Padding="3,0"><TextBlock Style="{StaticResource Cap}" Text="Orientation"/></Border>
                        <RadioButton Style="{StaticResource Rad}" Content="Left"  Canvas.Left="34"  Canvas.Top="14" IsChecked="{Binding OrientationLeft}"/>
                        <RadioButton Style="{StaticResource Rad}" Content="Right" Canvas.Left="136" Canvas.Top="14" IsChecked="{Binding OrientationRight}"/>
                    </Canvas>

                    <!-- Orientation Angle @441,315 264x41 -->
                    <Canvas Canvas.Left="441" Canvas.Top="315" Width="264" Height="41">
                        <Border Style="{StaticResource GrpFrame}" Width="264" Height="41"/>
                        <Border Canvas.Left="8" Canvas.Top="-8" Background="#F0F0F3" Padding="3,0"><TextBlock Style="{StaticResource Cap}" Text="Orientation Angle (0~360 °)"/></Border>
                        <ctl:NumericUpDown Canvas.Left="136" Canvas.Top="14" Width="100" Height="21" Maximum="360" Value="{Binding OrientationAngle}"/>
                    </Canvas>
                </Canvas>
            </TabItem>

            <!-- ─────────── Tab2: Sensor & Auto Upload ─────────── -->
            <TabItem Header="Sensor &amp;  Auto Upload">
                <Canvas Background="#F0F0F3">
                    <!-- UltraPanel2 @16,11 366x348 -->
                    <Canvas Canvas.Left="16" Canvas.Top="11" Width="366" Height="348">
                        <TextBlock Style="{StaticResource Cap}" Text="Sensor Info." Canvas.Left="40" Canvas.Top="14" FontWeight="SemiBold"/>
                        <ComboBox Style="{StaticResource Combo}" Canvas.Left="40" Canvas.Top="33" Width="289" Height="21"
                                  IsEditable="True" ItemsSource="{Binding SensorNames}" Text="{Binding SensorName}"/>

                        <!-- Signal Type @40,59 289x38 -->
                        <Canvas Canvas.Left="40" Canvas.Top="59" Width="289" Height="38">
                            <Border Style="{StaticResource GrpFrame}" Width="289" Height="38"/>
                            <Border Canvas.Left="8" Canvas.Top="-8" Background="#F0F0F3" Padding="3,0"><TextBlock Style="{StaticResource Cap}" Text="Signal Type"/></Border>
                            <RadioButton Style="{StaticResource Rad}" Content="Proximitor" Canvas.Left="56"  Canvas.Top="16" IsChecked="{Binding SignalProximitor}"/>
                            <RadioButton Style="{StaticResource Rad}" Content="Magnetic"   Canvas.Left="182" Canvas.Top="16" IsChecked="{Binding SignalMagnetic}"/>
                        </Canvas>

                        <!-- Proximitor Power @40,104 289x39 -->
                        <Canvas Canvas.Left="40" Canvas.Top="104" Width="289" Height="39">
                            <Border Style="{StaticResource GrpFrame}" Width="289" Height="39"/>
                            <Border Canvas.Left="8" Canvas.Top="-8" Background="#F0F0F3" Padding="3,0"><TextBlock Style="{StaticResource Cap}" Text="Proximitor Power"/></Border>
                            <RadioButton Style="{StaticResource Rad}" Content="-24V" Canvas.Left="56"  Canvas.Top="17" IsChecked="{Binding Power24}"/>
                            <RadioButton Style="{StaticResource Rad}" Content="-18V" Canvas.Left="182" Canvas.Top="17" IsChecked="{Binding Power18}"/>
                        </Canvas>

                        <!-- Power OK Limit @40,150 289x52 -->
                        <Canvas Canvas.Left="40" Canvas.Top="150" Width="289" Height="52">
                            <Border Style="{StaticResource GrpFrame}" Width="289" Height="52"/>
                            <Border Canvas.Left="8" Canvas.Top="-8" Background="#F0F0F3" Padding="3,0"><TextBlock Style="{StaticResource Cap}" Text="Power OK Limit"/></Border>
                            <TextBlock Style="{StaticResource Cap}" Text="High" Canvas.Left="22" Canvas.Top="25"/>
                            <ctl:NumericUpDown Canvas.Left="56"  Canvas.Top="21" Width="77" Height="21" Minimum="-100000" Maximum="100000" DecimalPlaces="1" IsReadOnly="True" Value="{Binding PowerHigh}"/>
                            <TextBlock Style="{StaticResource Cap}" Text="Low" Canvas.Left="151" Canvas.Top="25"/>
                            <ctl:NumericUpDown Canvas.Left="184" Canvas.Top="21" Width="77" Height="21" Minimum="-100000" Maximum="100000" DecimalPlaces="1" IsReadOnly="True" Value="{Binding PowerLow}"/>
                        </Canvas>

                        <!-- ICP @40,209 289x36 (원본과 동일하게 비활성) -->
                        <Canvas Canvas.Left="40" Canvas.Top="209" Width="289" Height="36" IsEnabled="False">
                            <Border Style="{StaticResource GrpFrame}" Width="289" Height="36"/>
                            <Border Canvas.Left="8" Canvas.Top="-8" Background="#F0F0F3" Padding="3,0"><TextBlock Style="{StaticResource Cap}" Text="ICP"/></Border>
                            <RadioButton Style="{StaticResource Rad}" Content="OFF" Canvas.Left="56"  Canvas.Top="13" IsChecked="{Binding IcpOff}"/>
                            <RadioButton Style="{StaticResource Rad}" Content="ON"  Canvas.Left="182" Canvas.Top="13" IsChecked="{Binding IcpOn}"/>
                        </Canvas>
                    </Canvas>

                    <!-- TabControl2 @410,6 331x353 -->
                    <TabControl Canvas.Left="410" Canvas.Top="6" Width="331" Height="353" Background="#F0F0F3" BorderBrush="#C8CDD6">
                        <TabControl.Resources>
                            <Style TargetType="TabItem">
                                <Setter Property="Background" Value="#E1E4E8"/>
                                <Setter Property="Foreground" Value="#333333"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="Padding" Value="12,4"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#F0F0F3"/>
                                        <Setter Property="Foreground" Value="#1565C0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TabControl.Resources>

                        <TabItem Header="Auto Upload">
                            <Canvas Background="#F0F0F3">
                                <TextBlock Style="{StaticResource Cap}" Text="Upload Condition" Canvas.Left="17" Canvas.Top="19"/>
                                <ComboBox Style="{StaticResource Combo}" Canvas.Left="124" Canvas.Top="16" Width="121" Height="21"
                                          ItemsSource="{Binding Source={x:Static vm:ReferenceConfigViewModel.Conditions}}" SelectedIndex="{Binding UploadCondition}"/>
                                <TextBlock Style="{StaticResource Cap}" Text="Start Up RPM" Canvas.Left="17" Canvas.Top="47"/>
                                <ctl:NumericUpDown Canvas.Left="124" Canvas.Top="42" Width="120" Height="21" Maximum="100000" Value="{Binding StartUpRpm}"/>
                                <TextBlock Style="{StaticResource Cap}" Text="Shut Down RPM" Canvas.Left="17" Canvas.Top="69"/>
                                <ctl:NumericUpDown Canvas.Left="124" Canvas.Top="64" Width="120" Height="21" Maximum="100000" Value="{Binding ShutDownRpm}"/>
                            </Canvas>
                        </TabItem>

                        <TabItem Header="Min/Max/Delta">
                            <Canvas Background="#F0F0F3">
                                <!-- Start Up @6,6 311x100 -->
                                <Canvas Canvas.Left="6" Canvas.Top="6" Width="311" Height="100">
                                    <Border Style="{StaticResource GrpFrame}" Width="311" Height="100"/>
                                    <Border Canvas.Left="8" Canvas.Top="-8" Background="#F0F0F3" Padding="3,0"><TextBlock Style="{StaticResource Cap}" Text="Start Up"/></Border>
                                    <TextBlock Style="{StaticResource Cap}" Text="Min (60~60000)" Canvas.Left="31" Canvas.Top="22"/>
                                    <ctl:NumericUpDown Canvas.Left="150" Canvas.Top="16" Width="120" Height="21" Maximum="60000" Value="{Binding SuMin}"/>
                                    <TextBlock Style="{StaticResource Cap}" Text="Max (60~60000)" Canvas.Left="31" Canvas.Top="44"/>
                                    <ctl:NumericUpDown Canvas.Left="150" Canvas.Top="38" Width="120" Height="21" Maximum="60000" Value="{Binding SuMax}"/>
                                    <TextBlock Style="{StaticResource Cap}" Text="Delta (1~60000)" Canvas.Left="31" Canvas.Top="67"/>
                                    <ctl:NumericUpDown Canvas.Left="150" Canvas.Top="61" Width="120" Height="21" Maximum="60000" Value="{Binding SuDelta}"/>
                                </Canvas>
                                <!-- Shut Down @6,112 311x100 -->
                                <Canvas Canvas.Left="6" Canvas.Top="112" Width="311" Height="100">
                                    <Border Style="{StaticResource GrpFrame}" Width="311" Height="100"/>
                                    <Border Canvas.Left="8" Canvas.Top="-8" Background="#F0F0F3" Padding="3,0"><TextBlock Style="{StaticResource Cap}" Text="Shut Down"/></Border>
                                    <TextBlock Style="{StaticResource Cap}" Text="Min (60~60000)" Canvas.Left="41" Canvas.Top="23"/>
                                    <ctl:NumericUpDown Canvas.Left="149" Canvas.Top="17" Width="120" Height="21" Maximum="60000" Value="{Binding SdMin}"/>
                                    <TextBlock Style="{StaticResource Cap}" Text="Max (60~60000)" Canvas.Left="41" Canvas.Top="47"/>
                                    <ctl:NumericUpDown Canvas.Left="149" Canvas.Top="39" Width="120" Height="21" Maximum="60000" Value="{Binding SdMax}"/>
                                    <TextBlock Style="{StaticResource Cap}" Text="Delta (1~60000)" Canvas.Left="41" Canvas.Top="67"/>
                                    <ctl:NumericUpDown Canvas.Left="149" Canvas.Top="62" Width="120" Height="21" Maximum="60000" Value="{Binding SdDelta}"/>
                                </Canvas>
                                <!-- Slow Roll @9,231 311x100 -->
                                <Canvas Canvas.Left="9" Canvas.Top="231" Width="311" Height="100">
                                    <Border Style="{StaticResource GrpFrame}" Width="311" Height="100"/>
                                    <Border Canvas.Left="8" Canvas.Top="-8" Background="#F0F0F3" Padding="3,0"><TextBlock Style="{StaticResource Cap}" Text="Slow Roll"/></Border>
                                    <TextBlock Style="{StaticResource Cap}" Text="Begin (60~60000)" Canvas.Left="40" Canvas.Top="17"/>
                                    <ctl:NumericUpDown Canvas.Left="150" Canvas.Top="18" Width="120" Height="21" Maximum="60000" Value="{Binding SrBegin}"/>
                                    <TextBlock Style="{StaticResource Cap}" Text="End (60~60000)" Canvas.Left="40" Canvas.Top="42"/>
                                    <ctl:NumericUpDown Canvas.Left="150" Canvas.Top="40" Width="120" Height="21" Maximum="60000" Value="{Binding SrEnd}"/>
                                    <TextBlock Style="{StaticResource Cap}" Text="Delta (1~60000)" Canvas.Left="40" Canvas.Top="69"/>
                                    <ctl:NumericUpDown Canvas.Left="150" Canvas.Top="63" Width="120" Height="21" Maximum="60000" Value="{Binding SrDelta}"/>
                                </Canvas>
                            </Canvas>
                        </TabItem>
                    </TabControl>
                </Canvas>
            </TabItem>
        </TabControl>

        <!-- ════════ 버튼 (UltraPanel3 @12,482; OK 412,-6 / Cancel 574,-6) ════════ -->
        <Button Style="{StaticResource Btn}" Canvas.Left="424" Canvas.Top="524" Width="115" Height="32" Command="{Binding OkCommand}">
            <TextBlock Text="OK" FontSize="12" FontWeight="SemiBold" Foreground="#1565C0"/>
        </Button>
        <Button Style="{StaticResource Btn}" Canvas.Left="586" Canvas.Top="524" Width="115" Height="32" Command="{Binding CancelCommand}">
            <TextBlock Text="CANCEL" FontSize="12" FontWeight="SemiBold" Foreground="#C0392B"/>
        </Button>
    </Canvas>
</Window>
