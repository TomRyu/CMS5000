                                        <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{StaticResource InputBgBrush}" Width="260" Padding="4,0">
                                            <ComboBox ItemsSource="{Binding AllCtForJunction}" SelectedItem="{Binding CtJunction_SelectedCt}" DisplayMemberPath="Name" BorderThickness="0" Padding="6,5" FontSize="12" Background="Transparent"/>
