<Window x:Class="CMS5000.Views.Admin.ModuleInsertView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctl="clr-namespace:CMS5000.Controls"
        Title="{Binding DialogTitle}"
        Width="440" Height="280"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F0F3">
    <Window.Resources>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/><Setter Property="Foreground" Value="#333333"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Input" TargetType="TextBox">
            <Setter Property="Background" Value="#FFFFFF"/><Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="BorderBrush" Value="#B8C0CC"/><Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5,4"/><Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Combo" TargetType="ComboBox">
            <Setter Property="Background" Value="#FFFFFF"/><Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="BorderBrush" Value="#B8C0CC"/><Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="24"/><Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Padding" Value="22,7"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="#FFFFFF" CornerRadius="4" BorderBrush="#9AA7BD" BorderThickness="1" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="#EAF1FB"/></Trigger></ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/><RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/><RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90"/>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="STATION ID" Style="{StaticResource Lbl}"/>
        <ctl:NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding StationId, Mode=OneWay}" IsEnabled="False"/>
        <TextBlock Grid.Row="0" Grid.Column="3" Text="RACK ID" Style="{StaticResource Lbl}" Margin="0,0,8,0"/>
        <ctl:NumericUpDown Grid.Row="0" Grid.Column="4" Value="{Binding RackId, Mode=OneWay}" IsEnabled="False" HorizontalAlignment="Left" Width="100"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="MODULE ID" Style="{StaticResource Lbl}"/>
        <ctl:NumericUpDown Grid.Row="2" Grid.Column="1" Value="{Binding ModuleId}" Minimum="1" Maximum="255"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="NAME" Style="{StaticResource Lbl}"/>
        <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="4" Style="{StaticResource Input}"
                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Grid.Row="6" Grid.Column="0" Text="TYPE" Style="{StaticResource Lbl}"/>
        <ComboBox Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="1" Style="{StaticResource Combo}"
                  ItemsSource="{Binding ModuleTypes}" SelectedItem="{Binding SelectedModuleType}" DisplayMemberPath="NicName"/>
        <CheckBox Grid.Row="6" Grid.Column="3" Grid.ColumnSpan="2" Content="Activity" IsChecked="{Binding Activity}"
                  Foreground="#1F2937" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"/>

        <StackPanel Grid.Row="8" Grid.ColumnSpan="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Command="{Binding InsertCommand}" Style="{StaticResource Btn}" Margin="0,0,10,0">
                <TextBlock Text="INSERT" FontSize="12" FontWeight="SemiBold" Foreground="#1565C0"/>
            </Button>
            <Button Command="{Binding CancelCommand}" Style="{StaticResource Btn}">
                <TextBlock Text="CANCEL" FontSize="12" FontWeight="SemiBold" Foreground="#C0392B"/>
            </Button>
        </StackPanel>
    </Grid>
</Window>
