                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="16"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Name" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{StaticResource InputBgBrush}">
                                                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                             BorderThickness="0" Padding="7,5" FontSize="12"
                                                             Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                </Border>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Plant (Location)" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{StaticResource InputBgBrush}">
                                                    <TextBox Text="{Binding Location, UpdateSourceTrigger=PropertyChanged}"
                                                             BorderThickness="0" Padding="7,5" FontSize="12"
                                                             Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                        <!-- TCP/IP -->
                                        <Border BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="12,10" Margin="0,0,0,10">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="8"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Grid.Row="0" Text="TCP/IP" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                                <Grid Grid.Row="2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="16"/>
                                                        <ColumnDefinition Width="100"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="IP Addr" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,0,4"/>
                                                        <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{StaticResource InputBgBrush}">
                                                            <TextBox Text="{Binding LocalIp, UpdateSourceTrigger=PropertyChanged}"
                                                                     BorderThickness="0" Padding="7,5" FontSize="12"
                                                                     Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Port" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,0,4"/>
                                                        <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{StaticResource InputBgBrush}">
                                                            <TextBox Text="{Binding LocalPort, UpdateSourceTrigger=PropertyChanged}"
                                                                     BorderThickness="0" Padding="7,5" FontSize="12"
                                                                     Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                        </Border>
                                                    </StackPanel>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                        <!-- Serial Port -->
                                        <Border BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="12,10" Margin="0,0,0,10">
                                            <StackPanel>
                                                <TextBlock Text="Serial Port" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="16"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Port Num." FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                        <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{StaticResource InputBgBrush}">
                                                            <TextBox Text="{Binding SerialPort, UpdateSourceTrigger=PropertyChanged}"
                                                                     BorderThickness="0" Padding="7,5" FontSize="12"
                                                                     Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Baudrate" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                        <ComboBox ItemsSource="{Binding Source={x:Static vm:RackInsertViewModel.BaudRates}}"
                                                                  SelectedItem="{Binding BaudRate}"
                                                                  Background="{StaticResource InputBgBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                                                                  BorderBrush="{StaticResource InputBorderBrush}" FontSize="12" Height="28"/>
                                                    </StackPanel>
                                                </Grid>
                                                <Grid Margin="0,8,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="16"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="16"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="DataBit" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                        <ComboBox ItemsSource="{Binding Source={x:Static vm:RackInsertViewModel.DataBits}}"
                                                                  SelectedIndex="{Binding DataBit}"
                                                                  Background="{StaticResource InputBgBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                                                                  BorderBrush="{StaticResource InputBorderBrush}" FontSize="12" Height="28"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="ParityBit" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                        <ComboBox ItemsSource="{Binding Source={x:Static vm:RackInsertViewModel.ParityBits}}"
                                                                  SelectedIndex="{Binding ParityBit}"
                                                                  Background="{StaticResource InputBgBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                                                                  BorderBrush="{StaticResource InputBorderBrush}" FontSize="12" Height="28"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="4">
                                                        <TextBlock Text="StopBit" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                        <ComboBox ItemsSource="{Binding Source={x:Static vm:RackInsertViewModel.StopBits}}"
                                                                  SelectedIndex="{Binding StopBit}"
                                                                  Background="{StaticResource InputBgBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                                                                  BorderBrush="{StaticResource InputBorderBrush}" FontSize="12" Height="28"/>
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                        <!-- Waveform / Trend -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="160"/>
                                                <ColumnDefinition Width="24"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Waveform Interval" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{StaticResource InputBgBrush}">
                                                        <TextBox Text="{Binding WaveformInterval, UpdateSourceTrigger=PropertyChanged}"
                                                                 Width="70" BorderThickness="0" Padding="7,5" FontSize="12"
                                                                 Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    </Border>
                                                    <TextBlock Text="[sec]" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <CheckBox IsChecked="{Binding Trend}" Content="Trend"
                                                          Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" Margin="0,0,0,8"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="STATIC(sec)" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{StaticResource InputBgBrush}">
                                                        <TextBox Text="{Binding StaticTrend, UpdateSourceTrigger=PropertyChanged}"
                                                                 Width="60" IsEnabled="{Binding TrendEnabled}"
                                                                 BorderThickness="0" Padding="7,5" FontSize="12"
                                                                 Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    </Border>
                                                    <TextBlock Text="DYNAMIC(sec)" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="16,0,8,0" VerticalAlignment="Center"/>
                                                    <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{StaticResource InputBgBrush}">
                                                        <TextBox Text="{Binding DynamicTrend, UpdateSourceTrigger=PropertyChanged}"
                                                                 Width="60" IsEnabled="{Binding TrendEnabled}"
                                                                 BorderThickness="0" Padding="7,5" FontSize="12"
                                                                 Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    </Border>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>

                            <!-- Modbus 탭 -->
                            <TabItem Header="Modbus">
                                <StackPanel Margin="16,12">
                                    <TextBlock Text="Communication Mode" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                    <ComboBox ItemsSource="{Binding Source={x:Static vm:RackInsertViewModel.ModbusModes}}"
                                              SelectedIndex="{Binding ModbusModeIndex}"
                                              Background="{StaticResource InputBgBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                                              BorderBrush="{StaticResource InputBorderBrush}" FontSize="12" Height="28"
                                              Width="260" HorizontalAlignment="Left" Margin="0,0,0,16"/>
                                    <!-- TCP/IP (원본 frmRack1: 항상 표시) -->
                                    <StackPanel>
                                        <TextBlock Text="TCP/IP" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="16"/>
                                                <ColumnDefinition Width="100"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="IP Addr" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                                <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{StaticResource InputBgBrush}">
                                                    <TextBox Text="{Binding ModbusIp, UpdateSourceTrigger=PropertyChanged}"
                                                             BorderThickness="0" Padding="7,5" FontSize="12"
                                                             Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                </Border>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Port" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                                <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{StaticResource InputBgBrush}">
                                                    <TextBox Text="{Binding ModbusPort, UpdateSourceTrigger=PropertyChanged}"
                                                             BorderThickness="0" Padding="7,5" FontSize="12"
                                                             Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                    <!-- Serial -->
                                    <StackPanel Visibility="{Binding IsModbusSerial, Converter={StaticResource BoolToVis}}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="16"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Port Num." FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                                <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{StaticResource InputBgBrush}">
                                                    <TextBox Text="{Binding ModSerialPort, UpdateSourceTrigger=PropertyChanged}"
                                                             BorderThickness="0" Padding="7,5" FontSize="12"
                                                             Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                </Border>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Baudrate" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                                <ComboBox ItemsSource="{Binding Source={x:Static vm:RackInsertViewModel.BaudRates}}"
                                                          SelectedItem="{Binding ModBaudRate}"
                                                          Background="{StaticResource InputBgBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                                                          BorderBrush="{StaticResource InputBorderBrush}" FontSize="12" Height="28"/>
                                            </StackPanel>
                                        </Grid>
                                        <Grid Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="16"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="16"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="DataBit" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                                <ComboBox ItemsSource="{Binding Source={x:Static vm:RackInsertViewModel.DataBits}}"
                                                          SelectedIndex="{Binding ModDataBit}"
                                                          Background="{StaticResource InputBgBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                                                          BorderBrush="{StaticResource InputBorderBrush}" FontSize="12" Height="28"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="ParityBit" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                                <ComboBox ItemsSource="{Binding Source={x:Static vm:RackInsertViewModel.ParityBits}}"
                                                          SelectedIndex="{Binding ModParityBit}"
                                                          Background="{StaticResource InputBgBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                                                          BorderBrush="{StaticResource InputBorderBrush}" FontSize="12" Height="28"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="4">
                                                <TextBlock Text="StopBit" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                                <ComboBox ItemsSource="{Binding Source={x:Static vm:RackInsertViewModel.StopBits}}"
                                                          SelectedIndex="{Binding ModStopBit}"
                                                          Background="{StaticResource InputBgBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                                                          BorderBrush="{StaticResource InputBorderBrush}" FontSize="12" Height="28"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </TabItem>

                            <!-- Server Connect 탭 -->
                            <TabItem Header="Server Connect.">
                                <StackPanel Margin="16,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="IP Addr" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                            <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{StaticResource InputBgBrush}">
                                                <TextBox Text="{Binding ServerIp, UpdateSourceTrigger=PropertyChanged}"
                                                         BorderThickness="0" Padding="7,5" FontSize="12"
                                                         Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"/>
                                            </Border>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Port" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                            <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{StaticResource InputBgBrush}">
                                                <TextBox Text="{Binding ServerPort, UpdateSourceTrigger=PropertyChanged}"
                                                         BorderThickness="0" Padding="7,5" FontSize="12"
                                                         Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </TabItem>
                        </TabControl>

                        <!-- 하단 버튼 -->
                        <Border Grid.Row="3" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,1,0,0" Padding="16,10">
                            <Grid>
                                <Button Command="{Binding SaveCommand}" HorizontalAlignment="Left" Padding="20,7" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg" Background="{StaticResource AccentBlueBrush}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="#155FAD"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <TextBlock Text="INSERT" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                </Button>
                                <Button Command="{Binding CancelCommand}" HorizontalAlignment="Right"
                                        Style="{StaticResource FlatButtonStyle}" Padding="16,7"
                                        BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1">
                                    <TextBlock Text="CANCEL" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- ─── TRAIN Insert 탭 패널 ────────────────────────── -->
                <Border Background="{StaticResource CardBgBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                        CornerRadius="8"
                        Visibility="{Binding IsTrainInsertVisible, Converter={StaticResource BoolToVis}}">
                    <Grid DataContext="{Binding TrainInsertTab}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 헤더 -->
                        <Border Grid.Row="0" Background="{StaticResource TreePanelHeaderBrush}"
                                BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,0,1"
                                Padding="16,10" CornerRadius="8,8,0,0">
                            <TextBlock Text="TRAIN INSERT" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Border>

                        <!-- 폼 -->
                        <StackPanel Grid.Row="1" Margin="16,14,16,0">
                            <!-- Station ID -->
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="STATION ID" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{StaticResource InputBgBrush}">
                                    <TextBox Text="{Binding StationId, Mode=OneWay}" IsReadOnly="True" Opacity="0.55"
                                             BorderThickness="0" Padding="7,5" FontSize="12"
                                             Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </Border>
                            </StackPanel>
                            <!-- Train ID -->
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="TRAIN ID" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{StaticResource InputBgBrush}">
                                    <TextBox Text="{Binding NodeId, UpdateSourceTrigger=PropertyChanged}"
                                             BorderThickness="0" Padding="7,5" FontSize="12"
                                             Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </Border>
                            </StackPanel>
                            <!-- Name -->
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Name" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{StaticResource InputBgBrush}">
                                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                             BorderThickness="0" Padding="7,5" FontSize="12"
                                             Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </Border>
                            </StackPanel>
                            <!-- Activity -->
                            <CheckBox IsChecked="{Binding Activity}" Content="Activity"
                                      Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>
                        </StackPanel>

                        <!-- 하단 버튼 -->
                        <Border Grid.Row="2" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,1,0,0" Padding="16,10">
                            <Grid>
                                <Button Command="{Binding SaveCommand}" HorizontalAlignment="Left" Padding="20,7" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg" Background="{StaticResource AccentBlueBrush}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="#155FAD"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <TextBlock Text="INSERT" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                </Button>
                                <Button Command="{Binding CancelCommand}" HorizontalAlignment="Right"
                                        Style="{StaticResource FlatButtonStyle}" Padding="16,7"
                                        BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1">
                                    <TextBlock Text="CANCEL" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                </Grid><!-- 콘텐츠 패널들 닫기 -->
            </Grid><!-- 우측 패널 닫기 -->
        </Grid>

        <!-- ══ Row 3: 상태 메시지 ════════════════════════════════════ -->
        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}"
                   FontSize="12" Foreground="{StaticResource AccentBlueBrush}"
                   Margin="20,6,20,8" TextWrapping="Wrap"
                   Visibility="{Binding HasStatus, Converter={StaticResource BoolToVis}}"/>
    </Grid>
</UserControl>
