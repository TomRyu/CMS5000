<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <!-- Velopack: WPF 자동생성 Main 대신 Program.cs의 Main 사용 -->
    <StartupObject>CMS5000.Program</StartupObject>
    <ApplicationIcon>CMS5000.ico</ApplicationIcon>
    <Version>1.0.0</Version>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Velopack" Version="0.*"/>
    <PackageReference Include="System.Drawing.Common" Version="10.*"/>
    <PackageReference Include="supabase-csharp" Version="0.*"/>
    <PackageReference Include="BCrypt.Net-Next" Version="4.*"/>
    <PackageReference Include="Microsoft.Win32.SystemEvents" Version="10.*"/>
    <PackageReference Include="System.Text.Json" Version="10.*"/>
    <PackageReference Include="System.Security.Cryptography.ProtectedData" Version="9.*"/>
  </ItemGroup>

  <ItemGroup>
    <Reference Include="LightningChart.DirectX">
      <HintPath>$(ProgramW6432)\LightningChart\LightningChart .NET SDK v.12\LibNET\LightningChart.DirectX.dll</HintPath>
      <Private>True</Private>
    </Reference>
    <Reference Include="LightningChart.WPF.ChartingMVVM.NET8">
      <HintPath>$(ProgramW6432)\LightningChart\LightningChart .NET SDK v.12\LibNET\LightningChart.WPF.ChartingMVVM.NET8.dll</HintPath>
      <Private>True</Private>
    </Reference>
    <Reference Include="LightningChart.MathCoreNET">
      <HintPath>$(ProgramW6432)\LightningChart\LightningChart .NET SDK v.12\LibNET\LightningChart.MathCoreNET.dll</HintPath>
      <Private>True</Private>
    </Reference>
    <Reference Include="WpfToolkit">
      <HintPath>$(ProgramW6432)\LightningChart\LightningChart .NET SDK v.12\LibNET\WpfToolkit.dll</HintPath>
      <Private>True</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <Resource Include="CMS5000.ico"/>
    <Resource Include="Images\autosyslogo.png"/>
    <Resource Include="Images\eye_icon.png"/>
    <Content Include="appsettings.json">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

</Project>
