                                            <TextBox Text="{Binding EditSrName, UpdateSourceTrigger=PropertyChanged}"
                                                     BorderThickness="0" Padding="7,5" FontSize="12" Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="Min" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,3"/>
