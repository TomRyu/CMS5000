<UserControl x:Class="CMS5000.Controls.NumericUpDown"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CMS5000.Converters"
             x:Name="Root" Height="24">
    <UserControl.Resources>
        <conv:InverseBoolConverter x:Key="Inv"/>
        <Style x:Key="SpinBtn" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background" Value="#ECECEC"/>
            <Setter Property="BorderBrush" Value="#B8C0CC"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="#D6DCE5"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="bd" Property="Background" Value="#C2CAD6"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="bd" Property="Background" Value="#F0F0F0"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border BorderBrush="#B8C0CC" BorderThickness="1" Background="White" SnapsToDevicePixels="True">
        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsEnabled, ElementName=Root}" Value="False">
                        <Setter Property="Background" Value="#ECECEC"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="PART_Text" Grid.Column="0" BorderThickness="0" Background="Transparent"
                     VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                     FontSize="12" Foreground="#1F2937" Padding="2,0"
                     IsEnabled="{Binding IsEnabled, ElementName=Root}"
                     IsReadOnly="{Binding IsReadOnly, ElementName=Root}"
                     LostFocus="Text_LostFocus" KeyDown="Text_KeyDown"/>

            <Grid Grid.Column="1" IsEnabled="{Binding IsReadOnly, ElementName=Root, Converter={StaticResource Inv}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <RepeatButton x:Name="PART_Up" Grid.Row="0" Style="{StaticResource SpinBtn}"
                              BorderThickness="1,0,0,1" Click="Up_Click">
                    <Path Data="M 0,3.5 L 4,0 L 8,3.5 Z" Fill="#555555" SnapsToDevicePixels="True"/>
                </RepeatButton>
                <RepeatButton x:Name="PART_Down" Grid.Row="1" Style="{StaticResource SpinBtn}"
                              BorderThickness="1,1,0,0" Click="Down_Click">
                    <Path Data="M 0,0 L 4,3.5 L 8,0 Z" Fill="#555555" SnapsToDevicePixels="True"/>
                </RepeatButton>
            </Grid>
        </Grid>
    </Border>
</UserControl>
