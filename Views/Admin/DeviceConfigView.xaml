                                <Style TargetType="TabItem">
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TabItem">
                                                <Border x:Name="bd" Background="{StaticResource TreePanelHeaderBrush}"
                                                        BorderBrush="{StaticResource CardBorderBrush}"
                                                        BorderThickness="0,0,1,1" Padding="16,8"
                                                        TextElement.Foreground="{StaticResource TextSecondaryBrush}">
                                                    <ContentPresenter ContentSource="Header"
                                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="{StaticResource CardBgBrush}"/>
                                                        <Setter TargetName="bd" Property="BorderThickness" Value="0,2,1,0"/>
                                                        <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
                                                        <Setter TargetName="bd" Property="TextElement.Foreground" Value="{StaticResource AccentBlueBrush}"/>
                                                    </Trigger>
                                                    <MultiTrigger>
                                                        <MultiTrigger.Conditions>
                                                            <Condition Property="IsMouseOver" Value="True"/>
                                                            <Condition Property="IsSelected" Value="False"/>
                                                        </MultiTrigger.Conditions>
                                                        <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentBluePaleBrush}"/>
                                                    </MultiTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TabControl.Resources>

