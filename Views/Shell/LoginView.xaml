<UserControl x:Class="CMS5000.Views.Shell.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource ContentBgBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!-- 좌측: 다크 브랜드 패널 -->
        <Border Grid.Column="0" Background="#FFFDF0">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Image Source="pack://application:,,,/Images/autosyslogo.png"
                       MaxWidth="240" MaxHeight="100"
                       HorizontalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Run Text="CMS" FontSize="42" FontWeight="Bold" Foreground="{StaticResource NavIconActiveFgBrush}"/>
                    <Run Text="-5000" FontSize="42" FontWeight="Bold" Foreground="{StaticResource NavIconActiveFgBrush}"/>
                </TextBlock>

                <StackPanel Margin="0,48,0,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="✓" Foreground="{StaticResource AccentBlueLightBrush}"
                                   FontSize="14" Margin="0,0,10,0"/>
                        <TextBlock Text="실시간 설비 상태 모니터링" FontSize="13"
                                   Foreground="{StaticResource NavIconFgBrush}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="✓" Foreground="{StaticResource AccentBlueLightBrush}"
                                   FontSize="14" Margin="0,0,10,0"/>
                        <TextBlock Text="Trend / Spectrum / Waterfall 분석" FontSize="13"
                                   Foreground="{StaticResource NavIconFgBrush}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✓" Foreground="{StaticResource AccentBlueLightBrush}"
                                   FontSize="14" Margin="0,0,10,0"/>
                        <TextBlock Text="역할별 맞춤 화면 제공" FontSize="13"
                                   Foreground="{StaticResource NavIconFgBrush}"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 우측: 로그인 폼 -->
        <Border Grid.Column="1" Background="{StaticResource ContentBgBrush}">
            <StackPanel Width="360" VerticalAlignment="Center" HorizontalAlignment="Center">

                <TextBlock Text="로그인" FontSize="26" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="아이디와 비밀번호를 입력하세요"
                           FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,6,0,32"/>

                <!-- 아이디 + 비밀번호 통합 입력 박스 (카카오 스타일) -->
                <Grid Margin="0,0,0,16">
                    <Border x:Name="UsernameBorder"
                            BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1"
                            CornerRadius="8" Background="{StaticResource InputBgBrush}">
                        <StackPanel>
                            <!-- 아이디 행 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="UsernameBox" Grid.Column="0"
                                         Text="{Binding LoginUsername, UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0" Padding="12,10" FontSize="14"
                                         Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"
                                         PreviewKeyDown="Input_KeyDown"
                                         TextChanged="UsernameBox_TextChanged"/>
                                <Button x:Name="UsernameDropdownBtn" Grid.Column="1"
                                        Width="34" BorderThickness="0" Background="Transparent"
                                        Cursor="Hand" ToolTip="이전 로그인 계정 선택"
                                        Click="UsernameDropdownBtn_Click">
                                    <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </Button>
                            </Grid>

                            <!-- 구분선 -->
                            <Rectangle Height="1" Fill="{StaticResource InputBorderBrush}"/>

                            <!-- 비밀번호 행 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <!-- 비밀번호 숨김 -->
                                <PasswordBox x:Name="PwdBox" Grid.Column="0"
                                             BorderThickness="0" Padding="12,10" FontSize="14"
                                             Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"
                                             PasswordChanged="PwdBox_PasswordChanged"
                                             KeyDown="Input_KeyDown"
                                             Visibility="{Binding IsPasswordHidden, Converter={StaticResource BoolToVis}}"/>
                                <!-- 비밀번호 표시 -->
                                <TextBox x:Name="PwdTextBox" Grid.Column="0"
                                         Text="{Binding LoginPassword, UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0" Padding="12,10" FontSize="14"
                                         Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"
                                         KeyDown="Input_KeyDown"
                                         Visibility="{Binding IsPasswordVisible, Converter={StaticResource BoolToVis}}"/>
                                <!-- 눈 아이콘 토글 (비밀번호 입력 시만 표시) -->
                                <Button Grid.Column="1" Width="38"
                                        Command="{Binding TogglePasswordVisibilityCommand}"
                                        BorderThickness="0" Background="Transparent" Cursor="Hand"
                                        ToolTip="비밀번호 표시/숨기기">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding LoginPassword}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <Image Source="pack://application:,,,/Images/eye_icon.png"
                                           Width="20" Height="18" Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Opacity" Value="0.55"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPasswordVisible}" Value="True">
                                                        <Setter Property="Opacity" Value="1.0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 이전 로그인 계정 드롭다운 -->
                    <Popup x:Name="UsernamePopup"
                           PlacementTarget="{Binding ElementName=UsernameBorder}"
                           Placement="Bottom"
                           StaysOpen="False"
                           AllowsTransparency="True">
                        <Border Background="{StaticResource CardBgBrush}"
                                BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                                CornerRadius="6" Margin="0,3,0,0">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" Opacity="0.15"
                                                  BlurRadius="10" ShadowDepth="2"/>
                            </Border.Effect>
                            <ListBox x:Name="UsernameList"
                                     ItemsSource="{Binding LoginUsernames}"
                                     Background="Transparent" BorderThickness="0"
                                     Focusable="False"
                                     SelectionChanged="UsernameList_SelectionChanged"
                                     MouseMove="UsernameList_MouseMove"
                                     PreviewMouseDown="UsernameList_PreviewMouseDown"
                                     MaxHeight="220">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Focusable" Value="False"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="bg" Background="Transparent"
                                                            Padding="14,9">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bg" Property="Background"
                                                                    Value="{StaticResource AccentBluePaleBrush}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="bg" Property="Background"
                                                                    Value="#BFDBFE"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets"
                                                       FontSize="12" VerticalAlignment="Center"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Margin="0,0,10,0"/>
                                            <TextBlock Text="{Binding}" FontSize="13"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Popup>
                </Grid>

                <!-- ID/비밀번호 저장 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <CheckBox Content="아이디 저장"
                              IsChecked="{Binding SaveUsername}"
                              FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                              Margin="0,0,20,0"/>
                    <CheckBox Content="비밀번호 저장"
                              IsChecked="{Binding SavePassword}"
                              FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>

                <!-- 오류 메시지 -->
                <TextBlock Text="{Binding LoginError}"
                           FontSize="12" Foreground="{StaticResource StatusDangerBrush}"
                           Margin="0,0,0,16" TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding LoginError}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- 로그인 버튼 -->
                <Button Command="{Binding LoginCommand}"
                        Padding="0,14" Margin="0,8,0,0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="{StaticResource AccentBlueBrush}"
                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <!-- 로딩 중 -->
                                    <TextBlock Text="로그인 중..." FontSize="15" FontWeight="SemiBold"
                                               Foreground="White" HorizontalAlignment="Center"
                                               Visibility="{Binding IsLoginBusy, Converter={StaticResource BoolToVis}}"/>
                                    <!-- 기본 -->
                                    <TextBlock Text="로그인" FontSize="15" FontWeight="SemiBold"
                                               Foreground="White" HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLoginBusy}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#155FAD"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="bg" Property="Background" Value="{StaticResource TextDisabledBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <TextBlock Text="© 2026 ㈜오토시스. All rights reserved."
                           FontSize="11" Foreground="{StaticResource TextDisabledBrush}"
                           HorizontalAlignment="Center" Margin="0,32,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
