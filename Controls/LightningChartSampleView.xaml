<UserControl x:Class="CMS5000.Controls.LightningChartSampleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Grid Background="#0A0A16">
        <!-- 차트 배경 그리드 라인 -->
        <Canvas x:Name="ChartCanvas" ClipToBounds="True"/>

        <!-- 축 레이블 -->
        <TextBlock x:Name="XAxisLabel" Text="Frequency (Hz)"
                   Foreground="#44AAAACC" FontSize="11"
                   HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,6"/>
        <TextBlock x:Name="YAxisLabel" Text="Amplitude"
                   Foreground="#44AAAACC" FontSize="11"
                   HorizontalAlignment="Left" VerticalAlignment="Center" Margin="4,0,0,0">
            <TextBlock.LayoutTransform>
                <RotateTransform Angle="-90"/>
            </TextBlock.LayoutTransform>
        </TextBlock>

        <!-- 차트 제목 -->
        <TextBlock x:Name="ChartTitle"
                   Foreground="#AACCDDFF" FontSize="13" FontWeight="SemiBold"
                   HorizontalAlignment="Left" VerticalAlignment="Top" Margin="16,10,0,0"/>
    </Grid>
</UserControl>
