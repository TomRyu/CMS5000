                                            <Border Margin="0,0,0,-8" Background="{StaticResource AccentBlueBrush}" Height="2" VerticalAlignment="Bottom"><Border.Style><Style TargetType="Border"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding IsCtTab1}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></Border.Style></Border>
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding CtSwitchTab2Command}" BorderThickness="0" Background="Transparent" Cursor="Hand" Padding="12,8">
