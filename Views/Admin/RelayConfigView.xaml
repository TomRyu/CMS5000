<Window x:Class="CMS5000.Views.Admin.RelayConfigView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctl="clr-namespace:CMS5000.Controls"
        Title="{Binding DialogTitle}"
        Width="820" Height="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F0F3">
    <Window.Resources>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Combo" TargetType="ComboBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="BorderBrush" Value="#B8C0CC"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Grp" TargetType="GroupBox">
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#B8C0CC"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Padding" Value="22,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="#FFFFFF" CornerRadius="4" BorderBrush="#9AA7BD" BorderThickness="1" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="#EAF1FB"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══ 상단 정보 ══ -->
        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#D5DAE2" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/><RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="76"/><ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="64"/><ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="86"/><ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="STATION ID" Style="{StaticResource Lbl}"/>
                <ctl:NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding StationId, Mode=OneWay}" IsEnabled="False"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="RACK ID" Style="{StaticResource Lbl}"/>
                <ctl:NumericUpDown Grid.Row="0" Grid.Column="3" Value="{Binding RackId, Mode=OneWay}" IsEnabled="False"/>
                <TextBlock Grid.Row="0" Grid.Column="4" Text="MODULE ID" Style="{StaticResource Lbl}"/>
                <ctl:NumericUpDown Grid.Row="0" Grid.Column="5" Value="{Binding ModuleId, Mode=OneWay}" IsEnabled="False"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Name" Style="{StaticResource Lbl}"/>
                <TextBox  Grid.Row="2" Grid.Column="1" Height="24" VerticalContentAlignment="Center"
                          TextAlignment="Center" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Row="2" Grid.Column="2" Text="Activity" Style="{StaticResource Lbl}"/>
                <ComboBox Grid.Row="2" Grid.Column="3" Style="{StaticResource Combo}" SelectedIndex="{Binding Activity}">
                    <ComboBoxItem Content="Inactivity"/>
                    <ComboBoxItem Content="Activity"/>
                </ComboBox>
                <TextBlock Grid.Row="2" Grid.Column="4" Text="Channel Type" Style="{StaticResource Lbl}"/>
                <TextBox  Grid.Row="2" Grid.Column="5" Height="24" VerticalContentAlignment="Center" IsReadOnly="True"
                          TextAlignment="Center" Text="{Binding ChannelTypeText, Mode=OneWay}" Background="#F3F4F6"/>
                <TextBlock Grid.Row="2" Grid.Column="6" Text="ID :" Style="{StaticResource Lbl}" HorizontalAlignment="Right" Margin="0,0,46,0"/>
                <ctl:NumericUpDown Grid.Row="2" Grid.Column="6" Width="44" HorizontalAlignment="Right"
                                   Value="{Binding ChannelId, Mode=OneWay}" IsEnabled="False"/>
            </Grid>
        </Border>

        <!-- ══ Mode / And-Voting ══ -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <GroupBox Grid.Column="0" Header="Mode" Style="{StaticResource Grp}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <RadioButton Content="Non Latching" GroupName="Mode" Margin="0,0,40,0" VerticalAlignment="Center"
                                 IsChecked="{Binding ModeNonLatch}"/>
                    <RadioButton Content="Latching" GroupName="Mode" VerticalAlignment="Center"
                                 IsChecked="{Binding ModeLatch}"/>
                </StackPanel>
            </GroupBox>
            <GroupBox Grid.Column="2" Header="And-Voting" Style="{StaticResource Grp}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <RadioButton Content="Normal" GroupName="AndVoting" Margin="0,0,40,0" VerticalAlignment="Center"
                                 IsChecked="{Binding AvNormal}"/>
                    <RadioButton Content="True" GroupName="AndVoting" VerticalAlignment="Center"
                                 IsChecked="{Binding AvTrue}"/>
                </StackPanel>
            </GroupBox>
        </Grid>

        <!-- ══ RELAY LOGIC ══ -->
        <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#D5DAE2" BorderThickness="1" CornerRadius="4" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#EEF2F8" BorderBrush="#C7CED9" BorderThickness="1" Margin="0,0,0,6">
                    <TextBlock Text="RELAY LOGIC" FontWeight="SemiBold" FontSize="13" Foreground="#334155"
                               HorizontalAlignment="Center" Padding="0,6"/>
                </Border>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="230"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Adding.... -->
                    <GroupBox Grid.Column="0" Header="Adding...." Style="{StaticResource Grp}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/><RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/><RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/><RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/><RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/><RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="86"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Sequence" Style="{StaticResource Lbl}" HorizontalAlignment="Left"/>
                            <ctl:NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding Seq, Mode=OneWay}" IsEnabled="False"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Module ID" Style="{StaticResource Lbl}" HorizontalAlignment="Left"/>
                            <ComboBox Grid.Row="2" Grid.Column="1" Style="{StaticResource Combo}"
                                      ItemsSource="{Binding LogicModules}" SelectedItem="{Binding AddModuleId}"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Channel ID" Style="{StaticResource Lbl}" HorizontalAlignment="Left"/>
                            <ComboBox Grid.Row="4" Grid.Column="1" Style="{StaticResource Combo}"
                                      ItemsSource="{Binding LogicChannels}" SelectedItem="{Binding AddChannelId}"/>
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Alert / Danger" Style="{StaticResource Lbl}" HorizontalAlignment="Left"/>
                            <ComboBox Grid.Row="6" Grid.Column="1" Style="{StaticResource Combo}"
                                      ItemsSource="{Binding AlertItems}" SelectedItem="{Binding AddAlert}"/>
                            <TextBlock Grid.Row="8" Grid.Column="0" Text="And/Or/End" Style="{StaticResource Lbl}" HorizontalAlignment="Left"/>
                            <ComboBox Grid.Row="8" Grid.Column="1" Style="{StaticResource Combo}"
                                      ItemsSource="{Binding AoeItems}" SelectedItem="{Binding AddAoe}"/>
                            <Button Grid.Row="10" Grid.ColumnSpan="2" Command="{Binding AddLogicCommand}"
                                    Style="{StaticResource Btn}" Margin="0,8,0,0">
                                <TextBlock Text="Add" FontSize="12" FontWeight="SemiBold" Foreground="#1565C0"/>
                            </Button>
                        </Grid>
                    </GroupBox>

                    <!-- Logic Grid -->
                    <DataGrid Grid.Column="2" AutoGenerateColumns="False" IsReadOnly="True"
                              HeadersVisibility="Column" GridLinesVisibility="All"
                              Background="#FFFFFF" RowBackground="#FFFFFF" AlternatingRowBackground="#F7F9FC"
                              CanUserAddRows="False" CanUserResizeRows="False"
                              ItemsSource="{Binding Logic}" SelectedItem="{Binding SelectedLogic}">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Remove" Command="{Binding RemoveLogicCommand}"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="SEQ"         Binding="{Binding Sequence}"    Width="60"/>
                            <DataGridTextColumn Header="ModuleID"    Binding="{Binding ModuleId}"    Width="80"/>
                            <DataGridTextColumn Header="ChannelID"   Binding="{Binding ChannelId}"   Width="80"/>
                            <DataGridTextColumn Header="Alert/Danger" Binding="{Binding AlertDanger}" Width="100"/>
                            <DataGridTextColumn Header="And/Or/End"  Binding="{Binding AndOrEnd}"    Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Grid>
        </Border>

        <!-- ══ 버튼 ══ -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Command="{Binding OkCommand}" Style="{StaticResource Btn}" Margin="0,0,12,0" MinWidth="115">
                <TextBlock Text="OK" FontSize="12" FontWeight="SemiBold" Foreground="#1565C0"/>
            </Button>
            <Button Command="{Binding CancelCommand}" Style="{StaticResource Btn}" MinWidth="115">
                <TextBlock Text="CANCEL" FontSize="12" FontWeight="SemiBold" Foreground="#C0392B"/>
            </Button>
        </StackPanel>
    </Grid>
</Window>
