<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <!-- Velopack: WPF 자동생성 Main 대신 Program.cs의 Main 사용 -->
    <StartupObject>CMS5000.Program</StartupObject>
    <ApplicationIcon>CMS5000.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Velopack" Version="0.*"/>
    <PackageReference Include="supabase-csharp" Version="0.*"/>
    <PackageReference Include="BCrypt.Net-Next" Version="4.*"/>
    <PackageReference Include="System.Security.Cryptography.ProtectedData" Version="9.*"/>
  </ItemGroup>

  <ItemGroup>
    <Resource Include="CMS5000.ico"/>
    <Resource Include="Images\autosyslogo.png"/>
    <Content Include="appsettings.json">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

</Project>
