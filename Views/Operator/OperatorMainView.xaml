<UserControl x:Class="CMS5000.Views.Operator.OperatorMainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource ContentBgBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- KPI 카드 -->
            <RowDefinition Height="*"/>      <!-- 설비 상태 -->
            <RowDefinition Height="230"/>    <!-- 알람 리스트 -->
        </Grid.RowDefinitions>

        <!-- ===== KPI 요약 카드 영역 ===== -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBgBrush}"
                BorderBrush="{StaticResource HeaderBorderBrush}" BorderThickness="0,0,0,1"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 전체 -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,10,0"
                        Cursor="Hand">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding ClearFilterCommand}"/>
                    </Border.InputBindings>
                    <StackPanel>
                        <TextBlock Text="전체 설비" Style="{StaticResource SectionTitleStyle}"/>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                            <TextBlock Text="{Binding TotalCount}" FontSize="38" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" LineHeight="42"/>
                            <TextBlock Text=" 대" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 정상 -->
                <Border Grid.Column="1" Margin="5,0" Cursor="Hand" CornerRadius="6"
                        BorderThickness="2">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource StatusGoodBrush}"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FilterIsNormal}" Value="True">
                                    <Setter Property="BorderBrush" Value="White"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsFiltered}" Value="True">
                                    <Setter Property="Opacity" Value="0.6"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding FilterIsNormal}" Value="True">
                                    <Setter Property="Opacity" Value="1"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Border.Effect>
                        <DropShadowEffect Color="#20000000" BlurRadius="6" ShadowDepth="1"/>
                    </Border.Effect>
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding ShowFilterCommand}"
                                      CommandParameter="Normal"/>
                    </Border.InputBindings>
                    <Grid Margin="14,12">
                        <StackPanel>
                            <TextBlock Text="정상" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="{Binding NormalCount}" FontSize="38" FontWeight="Bold"
                                           Foreground="White" LineHeight="42"/>
                                <TextBlock Text=" 대" FontSize="14" Foreground="#CCffffff"
                                           VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                            </StackPanel>
                        </StackPanel>
                        <!-- 선택 표시 -->
                        <TextBlock Text="▼" FontSize="10" Foreground="White" Opacity="0.8"
                                   HorizontalAlignment="Right" VerticalAlignment="Bottom">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FilterIsNormal}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- 경고 -->
                <Border Grid.Column="2" Margin="5,0" Cursor="Hand" CornerRadius="6"
                        BorderThickness="2">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource StatusWarningBrush}"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FilterIsWarning}" Value="True">
                                    <Setter Property="BorderBrush" Value="White"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsFiltered}" Value="True">
                                    <Setter Property="Opacity" Value="0.6"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding FilterIsWarning}" Value="True">
                                    <Setter Property="Opacity" Value="1"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Border.Effect>
                        <DropShadowEffect Color="#20000000" BlurRadius="6" ShadowDepth="1"/>
                    </Border.Effect>
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding ShowFilterCommand}"
                                      CommandParameter="Warning"/>
                    </Border.InputBindings>
                    <Grid Margin="14,12">
                        <StackPanel>
                            <TextBlock Text="경고" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="{Binding WarningCount}" FontSize="38" FontWeight="Bold"
                                           Foreground="White" LineHeight="42"/>
                                <TextBlock Text=" 대" FontSize="14" Foreground="#CCffffff"
                                           VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Text="▼" FontSize="10" Foreground="White" Opacity="0.8"
                                   HorizontalAlignment="Right" VerticalAlignment="Bottom">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FilterIsWarning}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- 위험 -->
                <Border Grid.Column="3" Margin="10,0,0,0" Cursor="Hand" CornerRadius="6"
                        BorderThickness="2">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource StatusDangerBrush}"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FilterIsDanger}" Value="True">
                                    <Setter Property="BorderBrush" Value="White"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsFiltered}" Value="True">
                                    <Setter Property="Opacity" Value="0.6"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding FilterIsDanger}" Value="True">
                                    <Setter Property="Opacity" Value="1"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Border.Effect>
                        <DropShadowEffect Color="#20000000" BlurRadius="6" ShadowDepth="1"/>
                    </Border.Effect>
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding ShowFilterCommand}"
                                      CommandParameter="Danger"/>
                    </Border.InputBindings>
                    <Grid Margin="14,12">
                        <StackPanel>
                            <TextBlock Text="위험" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="{Binding DangerCount}" FontSize="38" FontWeight="Bold"
                                           Foreground="White" LineHeight="42"/>
                                <TextBlock Text=" 대" FontSize="14" Foreground="#CCffffff"
                                           VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Text="▼" FontSize="10" Foreground="White" Opacity="0.8"
                                   HorizontalAlignment="Right" VerticalAlignment="Bottom">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FilterIsDanger}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ===== 설비 상태 카드 그리드 ===== -->
        <Grid Grid.Row="1" Margin="20,16,20,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 섹션 헤더 (필터 상태 표시) -->
            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 전체 보기 시 -->
                <TextBlock Grid.Column="0" FontSize="15" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="설비 상태 현황"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFiltered}" Value="True">
                                    <Setter Property="Text" Value="{Binding FilterLabel}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- 필터 카운트 배지 -->
                <Border Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Center"
                        Margin="130,0,0,0" CornerRadius="10" Padding="8,2">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Setter Property="Background" Value="{StaticResource AccentBluePaleBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFiltered}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding FilterIsWarning}" Value="True">
                                    <Setter Property="Background" Value="#FFF5E0"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding FilterIsDanger}" Value="True">
                                    <Setter Property="Background" Value="#FFE8E8"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock FontSize="11" FontWeight="SemiBold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource AccentBlueBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FilterIsWarning}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource StatusWarningBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding FilterIsDanger}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource StatusDangerBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        <Run Text="{Binding FilteredEquipments.Count, Mode=OneWay}"/>
                        <Run Text="대"/>
                    </TextBlock>
                </Border>

                <!-- 전체 보기 버튼 (필터 활성 시) -->
                <Button Grid.Column="1" Content="✕ 전체 보기"
                        Command="{Binding ClearFilterCommand}"
                        Padding="10,4" FontSize="11">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource FlatButtonStyle}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFiltered}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding FilteredEquipments}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="190" Height="120" Margin="0,0,10,10"
                                    Style="{StaticResource CardStyle}" Cursor="Hand">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                                        <Ellipse Width="10" Height="10" Margin="0,0,7,0" VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="{StaticResource StatusGoodBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Warning">
                                                            <Setter Property="Fill" Value="{StaticResource StatusWarningBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Danger">
                                                            <Setter Property="Fill" Value="{StaticResource StatusDangerBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Offline">
                                                            <Setter Property="Fill" Value="{StaticResource StatusOfflineBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                    </StackPanel>

                                    <TextBlock Grid.Row="1" Text="{Binding Location}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="11" Margin="0,5,0,0"/>

                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,6,0,0">
                                        <TextBlock Text="{Binding CurrentValue, StringFormat=F1}"
                                                   FontSize="22" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentBlueBrush}"/>
                                        <TextBlock Text="{Binding Unit}" FontSize="10"
                                                   VerticalAlignment="Bottom"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="4,0,0,2"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- ===== 실시간 알람 ===== -->
        <Border Grid.Row="2" Background="{StaticResource HeaderBgBrush}"
                BorderBrush="{StaticResource HeaderBorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="16,8"
                        BorderBrush="{StaticResource HeaderBorderBrush}" BorderThickness="0,0,0,1"
                        Background="{StaticResource TreePanelBgBrush}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="실시간 알람" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <Border Style="{StaticResource BadgeDangerStyle}" Margin="8,0,0,0">
                            <TextBlock Text="{Binding ActiveAlarms.Count}" FontSize="11"
                                       Foreground="White" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                </Border>

                <DataGrid Grid.Row="1" ItemsSource="{Binding ActiveAlarms}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                          BorderThickness="0" CanUserResizeColumns="True">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="수준" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10" Padding="7,2" HorizontalAlignment="Left" Margin="4,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource StatusGoodBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                        <Setter Property="Background" Value="{StaticResource StatusWarningBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Level}" Value="Danger">
                                                        <Setter Property="Background" Value="{StaticResource StatusDangerBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Level}" Value="Critical">
                                                        <Setter Property="Background" Value="{StaticResource StatusDangerBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Level}" FontSize="10"
                                                   Foreground="White" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="설비명"    Binding="{Binding EquipmentName}" Width="130"/>
                        <DataGridTextColumn Header="채널"      Binding="{Binding Channel}"       Width="70"/>
                        <DataGridTextColumn Header="메시지"    Binding="{Binding Message}"       Width="*"/>
                        <DataGridTextColumn Header="발생 시각" Binding="{Binding OccurredAt, StringFormat='yyyy-MM-dd HH:mm:ss'}" Width="165"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
