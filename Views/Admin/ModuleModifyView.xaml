<Window x:Class="CMS5000.Views.Admin.ModuleModifyView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:CMS5000.Converters"
        xmlns:ctl="clr-namespace:CMS5000.Controls"
        Title="{Binding DialogTitle}"
        Width="600" Height="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F0F3">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Input" TargetType="TextBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="BorderBrush" Value="#B8C0CC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Combo" TargetType="ComboBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="BorderBrush" Value="#B8C0CC"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Grp" TargetType="GroupBox">
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#B8C0CC"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Padding" Value="20,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="#FFFFFF" CornerRadius="4" BorderBrush="#9AA7BD" BorderThickness="1" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#EAF1FB"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bg" Property="Background" Value="#ECECEC"/>
                                <Setter TargetName="bg" Property="BorderBrush" Value="#D0D0D0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 헤더 -->
            <RowDefinition Height="*"/>     <!-- 채널 -->
            <RowDefinition Height="Auto"/>  <!-- 버튼 -->
        </Grid.RowDefinitions>

        <!-- ══ 모듈 헤더 ══════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#F7F8FA" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="3" Padding="12,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Row0 : STATION / RACK / ID -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="STATION ID" Style="{StaticResource Lbl}" Margin="0,0,8,0"/>
                <ctl:NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding StationId, Mode=OneWay}" IsEnabled="False"/>
                <TextBlock Grid.Row="0" Grid.Column="3" Text="RACK ID" Style="{StaticResource Lbl}" Margin="0,0,8,0"/>
                <ctl:NumericUpDown Grid.Row="0" Grid.Column="4" Value="{Binding RackId, Mode=OneWay}" IsEnabled="False" HorizontalAlignment="Left" Width="110"/>

                <!-- Row2 : ID / NAME -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="ID" Style="{StaticResource Lbl}" Margin="0,0,8,0"/>
                <ctl:NumericUpDown Grid.Row="2" Grid.Column="1" Value="{Binding ModuleId, Mode=OneWay}" IsEnabled="False"/>
                <TextBlock Grid.Row="2" Grid.Column="3" Text="NAME" Style="{StaticResource Lbl}" Margin="0,0,8,0"/>
                <TextBox Grid.Row="2" Grid.Column="4" Text="{Binding ModuleName, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource Input}"/>

                <!-- Row4 : TYPE / Activity / Config date -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="TYPE" Style="{StaticResource Lbl}" Margin="0,0,8,0"/>
                <ComboBox Grid.Row="4" Grid.Column="1" ItemsSource="{Binding ModuleTypes}"
                          SelectedItem="{Binding SelectedModuleType}" DisplayMemberPath="NicName"
                          Style="{StaticResource Combo}"/>
                <CheckBox Grid.Row="4" Grid.Column="3" IsChecked="{Binding IsActive}" Content="Activity"
                          Foreground="#1F2937" FontSize="12" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <TextBlock Grid.Row="4" Grid.Column="4" Style="{StaticResource Lbl}" Foreground="#777777"
                           Text="{Binding ConfigDate, StringFormat='Config : {0}'}"/>
            </Grid>
        </Border>

        <!-- ══ 채널 4개 ══════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,12,0,12">
            <ItemsControl ItemsSource="{Binding Channels}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <GroupBox Header="{Binding SlotLabel}" Style="{StaticResource Grp}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Activity -->
                                <CheckBox Grid.Column="0" IsChecked="{Binding IsActive}" Content="Activity"
                                          Foreground="#1F2937" FontSize="12" VerticalAlignment="Center" Margin="0,0,16,0"/>

                                <!-- Reference 그룹 (ShowReference & Activity) -->
                                <Border Grid.Column="1" BorderBrush="#C8CDD6" BorderThickness="1" CornerRadius="3"
                                        Padding="8,5" Margin="0,0,12,0"
                                        IsEnabled="{Binding IsActive}"
                                        Visibility="{Binding ShowReference, Converter={StaticResource BoolToVis}}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Reference" Style="{StaticResource Lbl}" Margin="0,0,10,0"/>
                                        <RadioButton Content="ON" IsChecked="{Binding RefOn}" Foreground="#1F2937"
                                                     FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <RadioButton Content="OFF" IsChecked="{Binding RefOff}" Foreground="#1F2937"
                                                     FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <ComboBox Width="170" Style="{StaticResource Combo}"
                                                  ItemsSource="{Binding DataContext.RefChannelOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  SelectedItem="{Binding SelectedRefChannel}"
                                                  DisplayMemberPath="DisplayName"
                                                  IsEnabled="{Binding RefOn}"/>
                                    </StackPanel>
                                </Border>

                                <!-- Config 버튼 -->
                                <Button Grid.Column="2" Content="Config" Style="{StaticResource Btn}"
                                        IsEnabled="{Binding IsActive}"
                                        Click="ConfigChannel_Click"/>
                            </Grid>
                        </GroupBox>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ══ 버튼 ══════════════════════════════════════════ -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Command="{Binding ModifyCommand}" Style="{StaticResource Btn}" Margin="0,0,10,0">
                <TextBlock Text="MODIFY" FontSize="12" FontWeight="SemiBold" Foreground="#1565C0"/>
            </Button>
            <Button Command="{Binding CancelCommand}" Style="{StaticResource Btn}">
                <TextBlock Text="CANCEL" FontSize="12" FontWeight="SemiBold" Foreground="#C0392B"/>
            </Button>
        </StackPanel>
    </Grid>
</Window>
