<Window x:Class="CMS5000.Views.Admin.RackCopyView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctl="clr-namespace:CMS5000.Controls"
        Title="{Binding DialogTitle}"
        Width="440" Height="490"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F0F3">
    <Window.Resources>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Combo" TargetType="ComboBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="BorderBrush" Value="#B8C0CC"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Grp" TargetType="GroupBox">
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#B8C0CC"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Padding" Value="22,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="#FFFFFF" CornerRadius="4" BorderBrush="#9AA7BD" BorderThickness="1" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="#EAF1FB"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══ Original Source ══ -->
        <GroupBox Grid.Row="0" Header="Original Source" Style="{StaticResource Grp}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/><RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/><RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/><RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="StationID" Style="{StaticResource Lbl}"/>
                <ctl:NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding SrcStationId, Mode=OneWay}" IsEnabled="False"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="RackID" Style="{StaticResource Lbl}"/>
                <ctl:NumericUpDown Grid.Row="2" Grid.Column="1" Value="{Binding SrcRackId, Mode=OneWay}" IsEnabled="False"/>
                <TextBlock Grid.Row="4" Grid.Column="0" Text="ModuleID" Style="{StaticResource Lbl}"/>
                <ctl:NumericUpDown Grid.Row="4" Grid.Column="1" IsEnabled="False"/>
                <TextBlock Grid.Row="6" Grid.Column="0" Text="ChannelID" Style="{StaticResource Lbl}"/>
                <ctl:NumericUpDown Grid.Row="6" Grid.Column="1" IsEnabled="False"/>
            </Grid>
        </GroupBox>

        <!-- ══ Destination Source ══ -->
        <GroupBox Grid.Row="1" Header="Destination Source" Style="{StaticResource Grp}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/><RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/><RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/><RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="StationID" Style="{StaticResource Lbl}"/>
                <ComboBox Grid.Row="0" Grid.Column="1" Style="{StaticResource Combo}"
                          ItemsSource="{Binding Stations}" SelectedItem="{Binding DestStation}"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="RackID" Style="{StaticResource Lbl}"/>
                <ComboBox Grid.Row="2" Grid.Column="1" Style="{StaticResource Combo}" IsEditable="True"
                          ItemsSource="{Binding DestRacks}" Text="{Binding DestRackText, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Row="4" Grid.Column="0" Text="ModuleID" Style="{StaticResource Lbl}"/>
                <ComboBox Grid.Row="4" Grid.Column="1" Style="{StaticResource Combo}" IsEnabled="False"/>
                <TextBlock Grid.Row="6" Grid.Column="0" Text="ChannelID" Style="{StaticResource Lbl}"/>
                <ComboBox Grid.Row="6" Grid.Column="1" Style="{StaticResource Combo}" IsEnabled="False"/>
            </Grid>
        </GroupBox>

        <!-- ══ 버튼 ══ -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Command="{Binding CopyCommand}" Style="{StaticResource Btn}" Margin="0,0,10,0">
                <TextBlock Text="Copy" FontSize="12" FontWeight="SemiBold" Foreground="#1565C0"/>
            </Button>
            <Button Command="{Binding CancelCommand}" Style="{StaticResource Btn}">
                <TextBlock Text="Cancel" FontSize="12" FontWeight="SemiBold" Foreground="#C0392B"/>
            </Button>
        </StackPanel>
    </Grid>
</Window>
