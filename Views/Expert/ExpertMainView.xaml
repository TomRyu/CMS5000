<UserControl x:Class="CMS5000.Views.Expert.ExpertMainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource ContentBgBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>    <!-- 중앙: 멀티 플롯 -->
            <ColumnDefinition Width="230"/>  <!-- 우측: 도구 패널 -->
        </Grid.ColumnDefinitions>

        <!-- ===== 중앙: 플롯 + 비교 영역 ===== -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>    <!-- 플롯 탭 -->
                <RowDefinition Height="200"/>  <!-- 비교 영역 -->
            </Grid.RowDefinitions>

            <!-- 플롯 탭 카드 -->
            <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="16,16,8,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 탭 헤더 -->
                    <Border Grid.Row="0" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,0,1"
                            Background="{StaticResource TreePanelBgBrush}" Margin="-16,-16,-16,12"
                            CornerRadius="6,6,0,0">
                        <DockPanel>
                            <ItemsControl ItemsSource="{Binding OpenPlots}" DockPanel.Dock="Left">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource CardBorderBrush}"
                                                BorderThickness="0,0,1,0" Padding="12,8" Cursor="Hand">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Title}" FontSize="12"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <Button Content="×" Width="16" Height="16"
                                                        FontSize="10" Margin="6,0,0,0"
                                                        Style="{StaticResource FlatButtonStyle}"
                                                        Padding="0" BorderThickness="0"
                                                        Command="{Binding DataContext.CloseTabCommand,
                                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Content="+ Plot 추가" Style="{StaticResource AccentButtonStyle}"
                                    DockPanel.Dock="Right" Padding="10,6" FontSize="11"
                                    Margin="4,4" Command="{Binding AddPlotCommand}"/>
                        </DockPanel>
                    </Border>

                    <!-- 플롯 본문 -->
                    <Border Grid.Row="1" Background="{StaticResource ContentBgBrush}"
                            BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="4">
                        <Grid>
                            <TextBlock Foreground="{StaticResource TextDisabledBrush}" FontSize="13"
                                       HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Run Text="[ "/>
                                <Run Text="{Binding ActiveTab.PlotType}"/>
                                <Run Text=" Plot 영역 — 차트 라이브러리 연동 예정 ]"/>
                            </TextBlock>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- 하단: 비교 카드 -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="16,0,8,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="비교 분석 / 진단 메모"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{StaticResource ContentBgBrush}"
                                BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                                CornerRadius="3" Margin="0,0,6,0">
                            <TextBlock Text="[ 비교 Plot 영역 ]"
                                       Foreground="{StaticResource TextDisabledBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                        </Border>
                        <TextBox Grid.Column="1" AcceptsReturn="True" TextWrapping="Wrap"
                                 Background="{StaticResource ContentBgBrush}"
                                 Text="진단 메모 / 분석 결론을 입력하세요..."
                                 Foreground="{StaticResource TextSecondaryBrush}"
                                 BorderBrush="{StaticResource CardBorderBrush}" Margin="6,0,0,0"
                                 Padding="8"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- ===== 우측: 도구 패널 ===== -->
        <Border Grid.Column="1" Background="{StaticResource TreePanelBgBrush}"
                BorderBrush="{StaticResource TreePanelBorderBrush}" BorderThickness="1,0,0,0">
            <DockPanel>
                <Border DockPanel.Dock="Top" Background="{StaticResource TreePanelHeaderBrush}"
                        BorderBrush="{StaticResource TreePanelBorderBrush}" BorderThickness="0,0,0,1"
                        Padding="14,10">
                    <TextBlock Text="분석 도구" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14,12">
                        <TextBlock Text="설비 선택" Style="{StaticResource SectionTitleStyle}"/>
                        <ComboBox ItemsSource="{Binding EquipmentList}" SelectedItem="{Binding SelectedEquipment}" Margin="0,0,0,10"/>

                        <TextBlock Text="Plot 유형" Style="{StaticResource SectionTitleStyle}"/>
                        <ComboBox ItemsSource="{Binding PlotTypeList}" SelectedItem="{Binding SelectedPlotType}" Margin="0,0,0,10"/>

                        <Button Content="Plot 추가" Style="{StaticResource AccentButtonStyle}"
                                Command="{Binding AddPlotCommand}" Height="32" Margin="0,0,0,16"/>

                        <Separator/>

                        <TextBlock Text="조작 도구" Style="{StaticResource SectionTitleStyle}" Margin="0,12,0,8"/>
                        <UniformGrid Columns="2" Margin="0,0,0,6">
                            <Button Content="Zoom In"  Style="{StaticResource FlatButtonStyle}" Margin="0,0,3,3" Padding="6,5" FontSize="11"/>
                            <Button Content="Zoom Out" Style="{StaticResource FlatButtonStyle}" Margin="3,0,0,3" Padding="6,5" FontSize="11"/>
                            <Button Content="Marker"   Style="{StaticResource FlatButtonStyle}" Margin="0,0,3,3" Padding="6,5" FontSize="11"/>
                            <Button Content="Cursor"   Style="{StaticResource FlatButtonStyle}" Margin="3,0,0,3" Padding="6,5" FontSize="11"/>
                        </UniformGrid>
                        <Button Content="구간 선택" Style="{StaticResource FlatButtonStyle}" Height="30" Margin="0,0,0,4" FontSize="11"/>
                        <Button Content="초기화"   Style="{StaticResource FlatButtonStyle}" Height="30" Margin="0,0,0,12" FontSize="11"/>

                        <Separator/>

                        <TextBlock Text="축 설정" Style="{StaticResource SectionTitleStyle}" Margin="0,12,0,8"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="X Min" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="0" Height="26"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="X Max" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="1000" Height="26"/>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Y Max" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="Auto" Height="26"/>
                        </Grid>
                        <Button Content="축 적용" Style="{StaticResource FlatButtonStyle}" Height="30" FontSize="11"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
