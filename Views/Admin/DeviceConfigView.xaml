                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="CT &amp; Plot" FontSize="11" FontWeight="SemiBold"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/><Style.Triggers><DataTrigger Binding="{Binding IsCtTab3}" Value="True"><Setter Property="Foreground" Value="{StaticResource AccentBlueBrush}"/></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock>
                                            <Border Margin="0,0,0,-8" Background="{StaticResource AccentBlueBrush}" Height="2" VerticalAlignment="Bottom"><Border.Style><Style TargetType="Border"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding IsCtTab3}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></Border.Style></Border>
