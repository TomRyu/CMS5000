<UserControl x:Class="CMS5000.Views.Maintenance.MaintenanceMainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource ContentBgBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>  <!-- 좌측: 필터 패널 -->
            <ColumnDefinition Width="*"/>    <!-- 중앙+하단: 분석 영역 -->
        </Grid.ColumnDefinitions>

        <!-- ===== 좌측: 필터 패널 ===== -->
        <Border Grid.Column="0" Background="{StaticResource TreePanelBgBrush}"
                BorderBrush="{StaticResource TreePanelBorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- 필터 헤더 -->
                <Border DockPanel.Dock="Top" Background="{StaticResource TreePanelHeaderBrush}"
                        BorderBrush="{StaticResource TreePanelBorderBrush}" BorderThickness="0,0,0,1"
                        Padding="14,10">
                    <TextBlock Text="분석 조건" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                </Border>
                <!-- 필터 바디 -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14,12">

                        <TextBlock Text="설비" Style="{StaticResource SectionTitleStyle}"/>
                        <ComboBox ItemsSource="{Binding EquipmentList}"
                                  SelectedItem="{Binding SelectedEquipment}" Margin="0,0,0,12"/>

                        <TextBlock Text="채널" Style="{StaticResource SectionTitleStyle}"/>
                        <ComboBox ItemsSource="{Binding ChannelList}"
                                  SelectedItem="{Binding SelectedChannel}" Margin="0,0,0,12"/>

                        <TextBlock Text="조회 기간" Style="{StaticResource SectionTitleStyle}"/>
                        <DatePicker SelectedDate="{Binding StartDate}" Margin="0,0,0,6"/>
                        <DatePicker SelectedDate="{Binding EndDate}"   Margin="0,0,0,12"/>

                        <TextBlock Text="이벤트 유형" Style="{StaticResource SectionTitleStyle}"/>
                        <ComboBox ItemsSource="{Binding EventTypeList}"
                                  SelectedItem="{Binding SelectedEventType}" Margin="0,0,0,16"/>

                        <Button Content="조 회" Style="{StaticResource AccentButtonStyle}"
                                Command="{Binding SearchCommand}" Height="36"/>

                        <Separator Margin="0,14"/>

                        <TextBlock Text="빠른 기간" Style="{StaticResource SectionTitleStyle}"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="1일"  Style="{StaticResource FlatButtonStyle}" Padding="10,5" FontSize="11" Margin="0,0,4,0"/>
                            <Button Content="7일"  Style="{StaticResource FlatButtonStyle}" Padding="10,5" FontSize="11" Margin="0,0,4,0"/>
                            <Button Content="30일" Style="{StaticResource FlatButtonStyle}" Padding="10,5" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ===== 중앙+하단 영역 ===== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>    <!-- Trend Plot -->
                <RowDefinition Height="230"/>  <!-- 이력 테이블 -->
            </Grid.RowDefinitions>

            <!-- Trend Plot 카드 -->
            <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="16,16,16,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 플롯 헤더 -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Long Trend" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text=" — " Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding SelectedEquipment}"
                                       Foreground="{StaticResource AccentBlueBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text=" / " Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding SelectedChannel}"
                                       Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Zoom In"  Style="{StaticResource FlatButtonStyle}" Padding="9,4" FontSize="11" Margin="0,0,5,0"/>
                            <Button Content="Zoom Out" Style="{StaticResource FlatButtonStyle}" Padding="9,4" FontSize="11" Margin="0,0,5,0"/>
                            <Button Content="기준선"   Style="{StaticResource FlatButtonStyle}" Padding="9,4" FontSize="11"/>
                        </StackPanel>
                    </Grid>

                    <!-- 플롯 플레이스홀더 -->
                    <Border Grid.Row="1" Background="{StaticResource ContentBgBrush}"
                            BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="4">
                        <Grid>
                            <TextBlock Text="[ Trend Plot 영역 — 차트 라이브러리 연동 예정 ]"
                                       Foreground="{StaticResource TextDisabledBrush}"
                                       FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- 이력 테이블 카드 -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="16,0,16,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="정비 이력 / 이벤트 로그"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding HistoryRecords}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              BorderThickness="1" BorderBrush="{StaticResource CardBorderBrush}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="발생 시각" Binding="{Binding OccurredAt, StringFormat='MM-dd HH:mm'}" Width="110"/>
                            <DataGridTextColumn Header="설비명"   Binding="{Binding EquipmentName}" Width="110"/>
                            <DataGridTextColumn Header="이벤트"   Binding="{Binding EventType}"     Width="100"/>
                            <DataGridTextColumn Header="내용"     Binding="{Binding Description}"   Width="*"/>
                            <DataGridTextColumn Header="조치"     Binding="{Binding Action}"        Width="90"/>
                            <DataGridTextColumn Header="담당자"   Binding="{Binding HandledBy}"     Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
