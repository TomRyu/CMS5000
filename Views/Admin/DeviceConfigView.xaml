                                                    <TextBox Text="{Binding EditCtDesc, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Padding="7,5" FontSize="12" Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"/>
