<UserControl x:Class="CMS5000.Views.Admin.DeviceConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:m="clr-namespace:CMS5000.Models"
             xmlns:av="clr-namespace:CMS5000.Views.Admin"
             xmlns:vm="clr-namespace:CMS5000.ViewModels.Admin"
             Background="{StaticResource ContentBgBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Row 0: 메뉴 바 -->
            <RowDefinition Height="Auto"/>  <!-- Row 1: 헤더 / 스테이션 선택 -->
            <RowDefinition Height="*"/>     <!-- Row 2: 메인 콘텐츠 (좌: 트리 / 우: 상세) -->
            <RowDefinition Height="Auto"/>  <!-- Row 3: 상태 메시지 -->
        </Grid.RowDefinitions>

        <!-- ══ Row 0: 메뉴 바 ════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{StaticResource TreePanelHeaderBrush}"
                BorderBrush="{StaticResource HeaderBorderBrush}" BorderThickness="0,0,0,1" Height="36">
            <Menu Background="Transparent" VerticalAlignment="Center" FontSize="13">
                <Menu.Resources>
                    <!-- 서브메뉴 팝업 배경 -->
                    <Style x:Key="DarkSubMenuItem" TargetType="MenuItem">
                        <Setter Property="Foreground" Value="#1E293B"/>
                        <Setter Property="FontSize" Value="12"/>
                    </Style>
                </Menu.Resources>

                <!-- System 메뉴 -->
                <MenuItem Padding="12,6" Background="Transparent">
                    <MenuItem.Header>
                        <TextBlock Text="System" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                    </MenuItem.Header>
                    <MenuItem.Style>
                        <Style TargetType="MenuItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource AccentBluePaleBrush}"/>
                                </Trigger>
                                <Trigger Property="IsSubmenuOpen" Value="True">
                                    <Setter Property="Background" Value="{StaticResource AccentBluePaleBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </MenuItem.Style>
                    <MenuItem Header="새로 고침" Command="{Binding RefreshCommand}" Style="{StaticResource DarkSubMenuItem}">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Check Data" Command="{Binding CheckDataCommand}" Style="{StaticResource DarkSubMenuItem}">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="설정 저장 (XLSX)" Command="{Binding SaveSettingsXlsxCommand}" Style="{StaticResource DarkSubMenuItem}">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="설정 로딩 및 수정" Command="{Binding LoadSettingsCommand}" Style="{StaticResource DarkSubMenuItem}">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="설정 DB 백업 (XLSX)" Command="{Binding BackupDbXlsxCommand}" Style="{StaticResource DarkSubMenuItem}">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#E53E3E"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="전체 DB 백업복원" Command="{Binding BackupRestoreAllDbCommand}" Style="{StaticResource DarkSubMenuItem}">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#E53E3E"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>

                <!-- Connection 메뉴 (원본 Database Connect/Disconnect — 실제 동작) -->
                <MenuItem Padding="12,6" Background="Transparent">
                    <MenuItem.Header>
                        <TextBlock Text="Connection" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                    </MenuItem.Header>
                    <MenuItem.Style>
                        <Style TargetType="MenuItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource AccentBluePaleBrush}"/>
                                </Trigger>
                                <Trigger Property="IsSubmenuOpen" Value="True">
                                    <Setter Property="Background" Value="{StaticResource AccentBluePaleBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </MenuItem.Style>
                    <MenuItem Header="Database Connect"
                              Command="{Binding DataContext.DbConnectCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                              Style="{StaticResource DarkSubMenuItem}">
                        <MenuItem.Icon><TextBlock Text="&#xE703;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#16A34A"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Database Disconnect"
                              Command="{Binding DataContext.DbDisconnectCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                              Style="{StaticResource DarkSubMenuItem}">
                        <MenuItem.Icon><TextBlock Text="&#xE703;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#9CA3AF"/></MenuItem.Icon>
                    </MenuItem>
                </MenuItem>

                <!-- Insert 메뉴 -->
                <MenuItem Padding="12,6" Background="Transparent">
                    <MenuItem.Header>
                        <TextBlock Text="Insert" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                    </MenuItem.Header>
                    <MenuItem.Style>
                        <Style TargetType="MenuItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource AccentBluePaleBrush}"/>
                                </Trigger>
                                <Trigger Property="IsSubmenuOpen" Value="True">
                                    <Setter Property="Background" Value="{StaticResource AccentBluePaleBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </MenuItem.Style>
                    <MenuItem Header="모듈 타입 (Module Type)" Command="{Binding OpenModuleTypeCommand}" Style="{StaticResource DarkSubMenuItem}">
                        <MenuItem.Icon><TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="12"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="채널 타입 (Channel Type)" Command="{Binding OpenChannelTypeCommand}" Style="{StaticResource DarkSubMenuItem}">
                        <MenuItem.Icon><TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="12"/></MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="센서 (Sensor)"              Command="{Binding OpenSensorCommand}"       Style="{StaticResource DarkSubMenuItem}"/>
                    <MenuItem Header="센서 단위 (Sensor Unit)"    Command="{Binding OpenSensorUnitCommand}"   Style="{StaticResource DarkSubMenuItem}"/>
                    <MenuItem Header="Display Plot"                Command="{Binding OpenDisplayPlotCommand}"  Style="{StaticResource DarkSubMenuItem}"/>
                    <MenuItem Header="비례값 (Proportional)"      Command="{Binding OpenProportionalCommand}" Style="{StaticResource DarkSubMenuItem}"/>
                    <MenuItem Header="스케일 범위 (Scale Range)"  Command="{Binding OpenScaleRangeCommand}"  Style="{StaticResource DarkSubMenuItem}"/>
                    <MenuItem Header="이벤트/상태 (Event/Status)" Command="{Binding OpenEventStatusCommand}"  Style="{StaticResource DarkSubMenuItem}"/>
                </MenuItem>
            </Menu>
        </Border>

        <!-- ══ Row 1: 헤더 ════════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="20,12,20,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="장비 구성" FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Text="설비 RACK 구조 및 TRAIN 계층을 조회하고 관리합니다."
                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- 새로 고침 -->
            <Button Grid.Column="1" Command="{Binding RefreshCommand}"
                    Style="{StaticResource FlatButtonStyle}"
                    Padding="10,6" VerticalAlignment="Center"
                    Background="{StaticResource CardBgBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text=" 새로 고침" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- ══ Row 2: 메인 콘텐츠 ════════════════════════════════════ -->
        <Grid Grid.Row="2" Margin="20,12,20,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>   <!-- 좌: 트리 패널 -->
                <ColumnDefinition Width="8"/>     <!-- 간격 -->
                <ColumnDefinition Width="*"/>     <!-- 우: 상세 패널 -->
            </Grid.ColumnDefinitions>

            <!-- ─── 좌측 패널: STATION 리스트 + RACK 트리(2*) + TRAIN 트리(1*) ──────── -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="110"/>  <!-- STATION 리스트 -->
                    <RowDefinition Height="8"/>    <!-- 간격 -->
                    <RowDefinition Height="2*"/>   <!-- RACK 트리 -->
                    <RowDefinition Height="8"/>    <!-- 간격 -->
                    <RowDefinition Height="1*"/>   <!-- TRAIN 트리 -->
                </Grid.RowDefinitions>

                <!-- STATION 리스트 -->
                <Border Grid.Row="0"
                        Background="{StaticResource CardBgBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                        CornerRadius="8" ClipToBounds="True">
                    <DockPanel>
                        <Border DockPanel.Dock="Top"
                                Background="{StaticResource TreePanelHeaderBrush}"
                                BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,0,1"
                                Padding="12,6">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#xE731;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="STATION" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <!-- 컬럼 헤더 -->
                        <Grid DockPanel.Dock="Top" Background="#A0A0A0" Height="22">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ID"      FontSize="11" FontWeight="Bold" Foreground="#000000" Padding="6,0" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="NAME"    FontSize="11" FontWeight="Bold" Foreground="#000000" Padding="6,0" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="COMPANY" FontSize="11" FontWeight="Bold" Foreground="#000000" Padding="6,0" VerticalAlignment="Center"/>
                        </Grid>
                        <!-- 스테이션 ListBox -->
                        <ListBox x:Name="StationListBox"
                                 ItemsSource="{Binding Stations}"
                                 SelectedItem="{Binding SelectedStation}"
                                 Background="{StaticResource CardBgBrush}"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 Tag="{Binding}">
                            <ListBox.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="STATION" FontWeight="SemiBold">
                                        <MenuItem.Icon>
                                            <TextBlock Text="&#xE731;" FontFamily="Segoe MDL2 Assets" FontSize="11"/>
                                        </MenuItem.Icon>
                                        <MenuItem Header="Insert" Command="{Binding AddStationCommand}">
                                            <MenuItem.Icon><TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="11"/></MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Modify" Command="{Binding EditStationCommand}">
                                            <MenuItem.Icon><TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="11"/></MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Delete" Command="{Binding DeleteStationCommand}">
                                            <MenuItem.Icon><TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="#E53E3E"/></MenuItem.Icon>
                                        </MenuItem>
                                    </MenuItem>
                                    <MenuItem Header="RACK" FontWeight="SemiBold">
                                        <MenuItem.Icon><TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="11"/></MenuItem.Icon>
                                        <MenuItem Header="Insert" Command="{Binding CtxRackInsertCommand}">
                                            <MenuItem.Icon><TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="11"/></MenuItem.Icon>
                                        </MenuItem>
                                    </MenuItem>
                                    <MenuItem Header="TRAIN" FontWeight="SemiBold">
                                        <MenuItem.Icon><TextBlock Text="&#xECAA;" FontFamily="Segoe MDL2 Assets" FontSize="11"/></MenuItem.Icon>
                                        <MenuItem Header="Insert" Command="{Binding CtxTrainInsertCommand}">
                                            <MenuItem.Icon><TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="11"/></MenuItem.Icon>
                                        </MenuItem>
                                    </MenuItem>
                                    <Separator/>
                                    <MenuItem Header="Assign Insert" Command="{Binding AssignInsertCommand}">
                                        <MenuItem.Icon><TextBlock Text="&#xE8FA;" FontFamily="Segoe MDL2 Assets" FontSize="11"/></MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </ListBox.ContextMenu>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="bg" Background="Transparent" Height="22">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="bg" Property="Background" Value="#2E7FD4"/>
                                                    </Trigger>
                                                    <MultiTrigger>
                                                        <MultiTrigger.Conditions>
                                                            <Condition Property="IsMouseOver" Value="True"/>
                                                            <Condition Property="IsSelected" Value="False"/>
                                                        </MultiTrigger.Conditions>
                                                        <Setter TargetName="bg" Property="Background" Value="#D0E8F8"/>
                                                    </MultiTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding StationId}" FontSize="11"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Margin="6,0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="11"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Margin="6,0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Company}" FontSize="11"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Margin="6,0" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>

                <!-- RACK 트리 -->
                <Border Grid.Row="2"
                        Background="{StaticResource CardBgBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                        CornerRadius="8" ClipToBounds="True">
                    <DockPanel>
                        <Border DockPanel.Dock="Top"
                                Background="{StaticResource TreePanelHeaderBrush}"
                                BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,0,1"
                                Padding="12,8">
                            <Grid>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE8F9;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="RACK" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border DockPanel.Dock="Top" Padding="12,8"
                                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="로드 중..." HorizontalAlignment="Center"
                                       FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Border>
                        <TreeView x:Name="RackTreeView"
                                  ItemsSource="{Binding RackNodes}"
                                  SelectedItemChanged="RackTree_SelectedItemChanged"
                                  Background="Transparent" BorderThickness="0"
                                  VirtualizingStackPanel.IsVirtualizing="True">
                            <TreeView.Resources>
                                <HierarchicalDataTemplate DataType="{x:Type m:DeviceTreeNode}"
                                                          ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal" Margin="2,2"
                                                Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=TreeView}}"
                                                MouseRightButtonDown="RackNode_RightClick">
                                        <StackPanel.ContextMenu>
                                            <ContextMenu>
                                                <!-- ── RACK 전용 ──────────────────────── -->
                                                <MenuItem Header="Open"
                                                          Command="{Binding PlacementTarget.Tag.RackOpenCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                    <MenuItem.Icon>
                                                        <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                                    </MenuItem.Icon>
                                                    <MenuItem.Style>
                                                        <Style TargetType="MenuItem">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding PlacementTarget.DataContext.Kind, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="{x:Static m:NodeKind.Rack}">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </MenuItem.Style>
                                                </MenuItem>
                                                <MenuItem Header="Hw Config"
                                                          Command="{Binding PlacementTarget.Tag.RackHwConfigCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                    <MenuItem.Icon>
                                                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                                    </MenuItem.Icon>
                                                    <MenuItem.Style>
                                                        <Style TargetType="MenuItem">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding PlacementTarget.DataContext.Kind, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="{x:Static m:NodeKind.Rack}">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </MenuItem.Style>
                                                </MenuItem>
                                                <Separator>
                                                    <Separator.Style>
                                                        <Style TargetType="Separator">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding PlacementTarget.DataContext.Kind, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="{x:Static m:NodeKind.Rack}">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Separator.Style>
                                                </Separator>

                                                <!-- ── 공통 (Rack / Module / Channel) ── -->
                                                <MenuItem Header="Modify"
                                                          Command="{Binding PlacementTarget.Tag.RackModifyCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                    <MenuItem.Icon>
                                                        <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="Delete"
                                                          Command="{Binding PlacementTarget.Tag.CtxRackDeleteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                    <MenuItem.Icon>
                                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>

                                                <!-- ── RACK 전용: Rack Copy ───────────── -->
                                                <MenuItem Header="Rack Copy"
                                                          Command="{Binding PlacementTarget.Tag.RackCopyCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                    <MenuItem.Icon>
                                                        <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                                    </MenuItem.Icon>
                                                    <MenuItem.Style>
                                                        <Style TargetType="MenuItem">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding PlacementTarget.DataContext.Kind, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="{x:Static m:NodeKind.Rack}">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </MenuItem.Style>
                                                </MenuItem>

                                                <!-- ── MODULE 전용: Module Copy ───────── -->
                                                <MenuItem Header="Module Copy"
                                                          Command="{Binding PlacementTarget.Tag.CtxModuleCopyCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                    <MenuItem.Icon><TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="12"/></MenuItem.Icon>
                                                    <MenuItem.Style>
                                                        <Style TargetType="MenuItem">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding PlacementTarget.DataContext.Kind, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="{x:Static m:NodeKind.Module}">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </MenuItem.Style>
                                                </MenuItem>

                                                <!-- ── CHANNEL 전용: Channel Copy ─────── -->
                                                <MenuItem Header="Channel Copy"
                                                          Command="{Binding PlacementTarget.Tag.CtxChannelCopyCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                    <MenuItem.Icon><TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="12"/></MenuItem.Icon>
                                                    <MenuItem.Style>
                                                        <Style TargetType="MenuItem">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding PlacementTarget.DataContext.Kind, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="{x:Static m:NodeKind.Channel}">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </MenuItem.Style>
                                                </MenuItem>

                                                <!-- ── RACK 전용: Module 서브메뉴 ─────── -->
                                                <Separator>
                                                    <Separator.Style>
                                                        <Style TargetType="Separator">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding PlacementTarget.DataContext.Kind, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="{x:Static m:NodeKind.Rack}">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Separator.Style>
                                                </Separator>
                                                <MenuItem Header="Module">
                                                    <MenuItem.Icon>
                                                        <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                                    </MenuItem.Icon>
                                                    <MenuItem.Style>
                                                        <Style TargetType="MenuItem">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding PlacementTarget.DataContext.Kind, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="{x:Static m:NodeKind.Rack}">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </MenuItem.Style>
                                                    <MenuItem Header="REFERENCE/IO Insert"
                                                              Command="{Binding PlacementTarget.Tag.CtxModuleInsertCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                    <MenuItem Header="RELAY Insert"
                                                              Command="{Binding PlacementTarget.Tag.CtxRelayInsertCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                </MenuItem>

                                                <!-- ── MODULE 전용: Channel 서브메뉴 ──── -->
                                                <Separator>
                                                    <Separator.Style>
                                                        <Style TargetType="Separator">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding PlacementTarget.DataContext.Kind, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="{x:Static m:NodeKind.Module}">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Separator.Style>
                                                </Separator>
                                                <MenuItem Header="Channel">
                                                    <MenuItem.Icon>
                                                        <TextBlock Text="&#xE81E;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                                    </MenuItem.Icon>
                                                    <MenuItem.Style>
                                                        <Style TargetType="MenuItem">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding PlacementTarget.DataContext.Kind, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="{x:Static m:NodeKind.Module}">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </MenuItem.Style>
                                                    <MenuItem Header="추가"
                                                              Command="{Binding PlacementTarget.Tag.CtxAddChannelCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                </MenuItem>

                                                <!-- ── 공통: 확장 / 축소 ─────────────── -->
                                                <Separator/>
                                                <MenuItem Header="확장" Click="RackExpand_Click">
                                                    <MenuItem.Icon>
                                                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#1565C0"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="축소" Click="RackCollapse_Click">
                                                    <MenuItem.Icon>
                                                        <TextBlock Text="&#xE738;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#1565C0"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                            </ContextMenu>
                                        </StackPanel.ContextMenu>
                                        <Ellipse Width="7" Height="7" Margin="0,0,5,0" VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="{StaticResource StatusGoodBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                            <Setter Property="Fill" Value="{StaticResource TextDisabledBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <Border CornerRadius="3" Padding="3,1" Margin="0,0,5,0" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#1D4ED8"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Kind}" Value="{x:Static m:NodeKind.Module}">
                                                            <Setter Property="Background" Value="#6D28D9"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Kind}" Value="{x:Static m:NodeKind.Channel}">
                                                            <Setter Property="Background" Value="#065F46"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding KindLabel}" FontSize="8" FontWeight="Bold" Foreground="White"/>
                                        </Border>
                                        <TextBlock Text="{Binding DisplayText}" FontSize="11"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.Resources>
                        </TreeView>
                    </DockPanel>
                </Border>

                <!-- TRAIN 트리 -->
                <Border Grid.Row="4"
                        Background="{StaticResource CardBgBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                        CornerRadius="8" ClipToBounds="True">
                    <DockPanel>
                        <Border DockPanel.Dock="Top"
                                Background="{StaticResource TreePanelHeaderBrush}"
                                BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,0,1"
                                Padding="12,6">
                            <Grid>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE8EC;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="TRAIN" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <TreeView x:Name="TrainTreeView"
                                  ItemsSource="{Binding TrainNodes}"
                                  SelectedItemChanged="TrainTree_SelectedItemChanged"
                                  Background="Transparent" BorderThickness="0"
                                  VirtualizingStackPanel.IsVirtualizing="True">
                            <TreeView.Resources>
                                <HierarchicalDataTemplate DataType="{x:Type m:DeviceTreeNode}"
                                                          ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal" Margin="2,2"
                                                Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=TreeView}}"
                                                MouseRightButtonDown="TrainNode_RightClick">
                                        <StackPanel.ContextMenu>
                                            <ContextMenu>
                                                <!-- 공통: Modify / Delete -->
                                                <MenuItem Header="Modify"
                                                          Command="{Binding PlacementTarget.Tag.EditTrainNodeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                    <MenuItem.Icon><TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="11"/></MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="Delete"
                                                          Command="{Binding PlacementTarget.Tag.DeleteTrainNodeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                    <MenuItem.Icon><TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="#E53E3E"/></MenuItem.Icon>
                                                </MenuItem>

                                                <!-- TRAIN 전용: Component ▸ Insert -->
                                                <Separator>
                                                    <Separator.Style>
                                                        <Style TargetType="Separator">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding PlacementTarget.DataContext.Kind, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="{x:Static m:NodeKind.Train}">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding PlacementTarget.DataContext.Kind, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="{x:Static m:NodeKind.Component}">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Separator.Style>
                                                </Separator>
                                                <MenuItem Header="Component">
                                                    <MenuItem.Style>
                                                        <Style TargetType="MenuItem">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding PlacementTarget.DataContext.Kind, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="{x:Static m:NodeKind.Train}">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </MenuItem.Style>
                                                    <MenuItem.Icon><TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="11"/></MenuItem.Icon>
                                                    <MenuItem Header="Insert"
                                                              Command="{Binding PlacementTarget.Tag.AddChildTrainCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                </MenuItem>

                                                <!-- COMPONENT 전용: POINT ▸ Insert -->
                                                <MenuItem Header="POINT">
                                                    <MenuItem.Style>
                                                        <Style TargetType="MenuItem">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding PlacementTarget.DataContext.Kind, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="{x:Static m:NodeKind.Component}">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </MenuItem.Style>
                                                    <MenuItem.Icon><TextBlock Text="&#xE707;" FontFamily="Segoe MDL2 Assets" FontSize="11"/></MenuItem.Icon>
                                                    <MenuItem Header="Insert"
                                                              Command="{Binding PlacementTarget.Tag.AddChildTrainCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                </MenuItem>

                                                <Separator/>
                                                <MenuItem Header="확장" Click="TrainExpand_Click">
                                                    <MenuItem.Icon><TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="#1565C0"/></MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="축소" Click="TrainCollapse_Click">
                                                    <MenuItem.Icon><TextBlock Text="&#xE738;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="#1565C0"/></MenuItem.Icon>
                                                </MenuItem>
                                            </ContextMenu>
                                        </StackPanel.ContextMenu>
                                        <Ellipse Width="7" Height="7" Margin="0,0,5,0" VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="{StaticResource StatusGoodBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                            <Setter Property="Fill" Value="{StaticResource TextDisabledBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <Border CornerRadius="3" Padding="3,1" Margin="0,0,5,0" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#0369A1"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Kind}" Value="{x:Static m:NodeKind.Component}">
                                                            <Setter Property="Background" Value="#B45309"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Kind}" Value="{x:Static m:NodeKind.Point}">
                                                            <Setter Property="Background" Value="#065F46"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding KindLabel}" FontSize="8" FontWeight="Bold" Foreground="White"/>
                                        </Border>
                                        <TextBlock Text="{Binding DisplayText}" FontSize="11"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.Resources>
                        </TreeView>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- ─── 우측 패널: 상세 정보 / 타입 관리 ────────────────── -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- 탭 스트립 -->
                    <RowDefinition Height="*"/>     <!-- 콘텐츠 -->
                </Grid.RowDefinitions>

                <!-- ── 탭 스트립 ──────────────────────────────────────── -->
                <Border Grid.Row="0"
                        Background="{StaticResource CardBgBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1,1,1,0"
                        CornerRadius="8,8,0,0"
                        Visibility="{Binding HasTypeTabs, Converter={StaticResource BoolToVis}}">
                    <ItemsControl ItemsSource="{Binding TypeTabs}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,1,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource AccentBluePaleBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <!-- 탭 제목 버튼 -->
                                        <Button Command="{Binding DataContext.SelectTabCommand,
                                                         RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource FlatButtonStyle}"
                                                Background="Transparent"
                                                Padding="14,8,8,8" BorderThickness="0" Cursor="Hand">
                                            <TextBlock FontSize="12" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text"       Value="{Binding Title}"/>
                                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource AccentBlueBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Button>
                                        <!-- 탭 닫기 버튼 -->
                                        <Button Command="{Binding DataContext.CloseTabCommand,
                                                         RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource FlatButtonStyle}"
                                                Background="Transparent"
                                                Padding="2,8,10,8" BorderThickness="0" Cursor="Hand"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource AccentBlueBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- ── 콘텐츠 패널들 ──────────────────────────────────── -->
                <Grid Grid.Row="1">

                <!-- RACK 편집 패널 (제거됨) -->
                <Border Background="{StaticResource CardBgBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                        CornerRadius="8"
                        Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="20">
                            <TextBlock Text="{Binding RackPanelTitle}"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                            <!-- 읽기 모드 -->
                            <StackPanel Visibility="{Binding IsRackNameReadOnly, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="이름" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding RackEditName}" FontSize="13"
                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,10"/>

                                <TextBlock Text="상세" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding RackEditInfo}" FontSize="12" TextWrapping="Wrap"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,14"/>

                                <Button Command="{Binding EditRackNameCommand}"
                                        Visibility="{Binding ShowEditNameButton, Converter={StaticResource BoolToVis}}"
                                        Padding="0,7" Margin="0,0,0,8">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource FlatButtonStyle}">
                                            <Setter Property="BorderBrush"    Value="{StaticResource CardBorderBrush}"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding EditNameButtonLabel, StringFormat=' {0}'}" FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <!-- 편집 모드 -->
                            <StackPanel Visibility="{Binding IsRackNameEditing, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="이름" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1"
                                        CornerRadius="6" Background="{StaticResource InputBgBrush}" Margin="0,0,0,10">
                                    <TextBox Text="{Binding EditRackName, UpdateSourceTrigger=PropertyChanged}"
                                             BorderThickness="0" Padding="10,7" FontSize="13"
                                             Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </Border>

                                <StackPanel Visibility="{Binding ShowRackLocation, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="위치" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                    <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1"
                                            CornerRadius="6" Background="{StaticResource InputBgBrush}" Margin="0,0,0,14">
                                        <TextBox Text="{Binding EditRackLocation, UpdateSourceTrigger=PropertyChanged}"
                                                 BorderThickness="0" Padding="10,7" FontSize="13"
                                                 Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    </Border>
                                </StackPanel>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Command="{Binding CancelRackNameCommand}"
                                            Style="{StaticResource FlatButtonStyle}" Padding="0,8"
                                            BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1">
                                        <TextBlock Text="취소" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </Button>
                                    <Button Grid.Column="2" Command="{Binding SaveRackNameCommand}"
                                            Padding="0,8" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bg" Background="{StaticResource AccentBlueBrush}"
                                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bg" Property="Background" Value="#155FAD"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <TextBlock Text="저장" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                    </Button>
                                </Grid>
                            </StackPanel>

                            <Separator Margin="0,4,0,14" Background="{StaticResource CardBorderBrush}"/>

                            <!-- 활성 상태 표시 -->
                            <TextBlock Text="활성화 상태" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,6,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{StaticResource StatusGoodBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RackEditIsActive}" Value="False">
                                                    <Setter Property="Fill" Value="{StaticResource TextDisabledBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock FontSize="13" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text"       Value="활성"/>
                                            <Setter Property="Foreground" Value="{StaticResource StatusGoodBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RackEditIsActive}" Value="False">
                                                    <Setter Property="Text"       Value="비활성"/>
                                                    <Setter Property="Foreground" Value="{StaticResource TextDisabledBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <!-- RACK 토글 -->
                            <Button Command="{Binding ToggleRackActivityCommand}" Padding="0,9" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedRackNode.Kind}" Value="{x:Static m:NodeKind.Rack}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bg" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource StatusGoodBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RackEditIsActive}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource TextDisabledBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="White">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="RACK 활성화"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RackEditIsActive}" Value="True">
                                                    <Setter Property="Text" Value="RACK 비활성화"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button>

                            <!-- MODULE 토글 -->
                            <Button Command="{Binding ToggleModuleActivityCommand}" Padding="0,9" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedRackNode.Kind}" Value="{x:Static m:NodeKind.Module}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bg" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource StatusGoodBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RackEditIsActive}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource TextDisabledBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="White">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="MODULE 활성화"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RackEditIsActive}" Value="True">
                                                    <Setter Property="Text" Value="MODULE 비활성화"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button>

                            <!-- CHANNEL 토글 -->
                            <Button Command="{Binding ToggleChannelActivityCommand}" Padding="0,9" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedRackNode.Kind}" Value="{x:Static m:NodeKind.Channel}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bg" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource StatusGoodBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RackEditIsActive}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource TextDisabledBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="White">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="CHANNEL 활성화"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RackEditIsActive}" Value="True">
                                                    <Setter Property="Text" Value="CHANNEL 비활성화"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- RACK Modify 패널 (탭) -->
                <Border Background="{StaticResource CardBgBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                        CornerRadius="0,0,8,8"
                        Visibility="{Binding IsRackModifyVisible, Converter={StaticResource BoolToVis}}">
                    <av:RackModifyControl DataContext="{Binding RackModifyVM}"/>
                </Border>

                <!-- H/W Config 패널 (탭) -->
                <Border Background="{StaticResource CardBgBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                        CornerRadius="0,0,8,8"
                        Visibility="{Binding IsHwConfigVisible, Converter={StaticResource BoolToVis}}">
                    <av:HwConfigControl DataContext="{Binding HwConfigVM}"/>
                </Border>

                <!-- REFERENCE/IO Insert 패널 (탭) -->
                <Border Background="{StaticResource CardBgBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                        CornerRadius="0,0,8,8"
                        Visibility="{Binding IsModuleInsertVisible, Converter={StaticResource BoolToVis}}">
                    <av:ModuleInsertControl DataContext="{Binding ModuleInsertVM}"/>
                </Border>

                <!-- RELAY Insert 패널 (탭) -->
                <Border Background="{StaticResource CardBgBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                        CornerRadius="0,0,8,8"
                        Visibility="{Binding IsRelayInsertVisible, Converter={StaticResource BoolToVis}}">
                    <av:RelayModuleControl DataContext="{Binding RelayInsertVM}"/>
                </Border>

                <!-- ASSIGN(매칭) 패널 (탭) -->
                <Border Background="{StaticResource CardBgBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                        CornerRadius="0,0,8,8"
                        Visibility="{Binding IsAssignVisible, Converter={StaticResource BoolToVis}}">
                    <av:AssignControl DataContext="{Binding AssignTab}"/>
                </Border>

                <!-- RACK 뷰 패널 (탭) -->
                <Border Background="{StaticResource CardBgBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                        CornerRadius="0,0,8,8"
                        VerticalAlignment="Top"
                        Visibility="{Binding IsRackViewVisible, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 헤더 -->
                        <Border Grid.Row="0" Background="#1A2235" Padding="16,10">
                            <TextBlock Text="{Binding RackViewTitle}"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Border>

                        <!-- Modify 툴바 -->
                        <Border Grid.Row="1" Background="#232B3E"
                                BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,0,1"
                                Padding="8,5">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="RackModifyBtn" Click="RackModify_Click"
                                        Cursor="Hand" Padding="10,5"
                                        ToolTip="RACK 정보 수정">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg" CornerRadius="4"
                                                    Background="Transparent" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="#2D3A54"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="13" Foreground="#93C5FD"
                                                   VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBlock Text="Modify" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="#93C5FD" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- 슬롯 — 실제 제품 랙 형태 (번호 밴드 + 키 큰 본체 + 하단 레일) -->
                        <ScrollViewer Grid.Row="2"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled"
                                      Padding="12,12,12,8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>   <!-- 번호 밴드 -->
                                    <RowDefinition Height="Auto"/>   <!-- 랙 본체 -->
                                    <RowDefinition Height="Auto"/>   <!-- 하단 레일 -->
                                </Grid.RowDefinitions>

                                <!-- 번호 밴드 : Module NO. + 1~14 -->
                                <StackPanel Grid.Row="0" Orientation="Horizontal">
                                    <Border Width="78" Height="40"
                                            Background="#232B3E" BorderBrush="#3A4A6A" BorderThickness="1"
                                            CornerRadius="3">
                                        <TextBlock Text="Module NO. &gt;&gt;"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   TextAlignment="Center" TextWrapping="Wrap"
                                                   FontSize="10" Foreground="#94A3B8"/>
                                    </Border>
                                    <ItemsControl ItemsSource="{Binding RackViewSlots}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="52" Height="40" Margin="3,0"
                                                        Background="#232B3E" BorderBrush="#3A4A6A" BorderThickness="1"
                                                        CornerRadius="3">
                                                    <TextBlock Text="{Binding SlotNumber}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               FontSize="12" FontWeight="SemiBold" Foreground="#CBD5E1"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <!-- 랙 본체 : 좌측 공백 + 키 큰 슬롯 -->
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5,0,0">
                                    <Border Width="78" Background="Transparent"/>
                                    <ListBox x:Name="RackSlotList"
                                             ItemsSource="{Binding RackViewSlots}"
                                             SelectedItem="{Binding SelectedRackViewSlot}"
                                             Background="Transparent" BorderThickness="0" Padding="0"
                                             VirtualizingPanel.IsVirtualizing="False"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="Margin" Value="3,0"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                                                <EventSetter Event="MouseDoubleClick" Handler="RackSlot_DoubleClick"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border x:Name="card"
                                                                    Width="52" Height="380" CornerRadius="4" BorderThickness="1"
                                                                    Background="#161D2E" BorderBrush="#2D3A54"
                                                                    ToolTip="{Binding TooltipText}" Cursor="Hand">
                                                                <ContentPresenter/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter TargetName="card" Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
                                                                    <Setter TargetName="card" Property="BorderThickness" Value="2"/>
                                                                </Trigger>
                                                                <MultiTrigger>
                                                                    <MultiTrigger.Conditions>
                                                                        <Condition Property="IsMouseOver" Value="True"/>
                                                                        <Condition Property="IsSelected"  Value="False"/>
                                                                    </MultiTrigger.Conditions>
                                                                    <Setter TargetName="card" Property="BorderBrush" Value="#4A6A9A"/>
                                                                </MultiTrigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <!-- 모듈 장착 여부 : 슬롯 전체를 색상으로 채움 (텍스트 없음) -->
                                                <Grid Width="50">
                                                    <Border VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                                                            Margin="5" CornerRadius="3"
                                                            Background="{Binding ActiveColor}"
                                                            Visibility="{Binding IsOccupied, Converter={StaticResource BoolToVis}}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>

                                <!-- 하단 레일 -->
                                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,5,0,0">
                                    <Border Width="78" Background="Transparent"/>
                                    <ItemsControl ItemsSource="{Binding RackViewSlots}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="52" Height="44" Margin="3,0"
                                                        Background="#1C2336" BorderBrush="#2D3A54" BorderThickness="1"
                                                        CornerRadius="3"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>

                        <!-- 상태 바 -->
                        <Border Grid.Row="3" Padding="16,8"
                                BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,1,0,0">
                            <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="슬롯을 더블클릭하면 모듈 수정 창이 열립니다"/>
                        </Border>
                    </Grid>
                </Border>


                <!-- ─── 모듈 타입 관리 패널 ─────────────────────────── -->
                <Border Background="{StaticResource CardBgBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                        CornerRadius="8"
                        Visibility="{Binding IsModuleTypeVisible, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 헤더 -->
                        <Border Grid.Row="0" Background="{StaticResource TreePanelHeaderBrush}"
                                BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,0,1"
                                Padding="16,10" CornerRadius="8,8,0,0">
                            <Grid>
                                <TextBlock Text="모듈 타입 (Module Type)" FontSize="14" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                <Button Command="{Binding CloseTypePanelCommand}" HorizontalAlignment="Right"
                                        Style="{StaticResource FlatButtonStyle}" Padding="8,4"
                                        BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" ToolTip="닫기">
                                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- 내부 탭 스트립 -->
                        <Border Grid.Row="1" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,0,1"
                                Background="{StaticResource ContentBgBrush}">
                            <StackPanel Orientation="Horizontal" Margin="8,0">
                                <!-- ModuleType 탭 -->
                                <Button Command="{Binding SwitchToMtTabCommand}" BorderThickness="0" Background="Transparent"
                                        Cursor="Hand" Padding="16,8">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="bg" Background="Transparent" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="bg" Property="Background" Value="{StaticResource AccentBluePaleBrush}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="ModuleType" FontSize="12" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMtTabMt}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource AccentBlueBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Border Margin="0,0,0,-8" Background="{StaticResource AccentBlueBrush}" Height="2" VerticalAlignment="Bottom">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMtTabMt}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                    </StackPanel>
                                </Button>
                                <!-- Module & Channel Type 탭 -->
                                <Button Command="{Binding SwitchToMctTabCommand}" BorderThickness="0" Background="Transparent"
                                        Cursor="Hand" Padding="16,8">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="bg" Background="Transparent" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="bg" Property="Background" Value="{StaticResource AccentBluePaleBrush}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Module &amp; Channel Type" FontSize="12" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMtTabMct}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource AccentBlueBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Border Margin="0,0,0,-8" Background="{StaticResource AccentBlueBrush}" Height="2" VerticalAlignment="Bottom">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMtTabMct}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- 콘텐츠 영역 (두 내부 탭이 같은 셀에서 Visibility로 전환) -->
                        <Grid Grid.Row="2">

                            <!-- ① ModuleType 탭 내용 -->
                            <Grid Visibility="{Binding IsMtTabMt, Converter={StaticResource BoolToVis}}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <DataGrid Grid.Row="0" ItemsSource="{Binding ModuleTypeRows}" SelectedItem="{Binding SelectedModuleTypeRow}"
                                          AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                          CanUserAddRows="False" CanUserDeleteRows="False"
                                          Background="Transparent" BorderThickness="0" RowBackground="Transparent"
                                          AlternatingRowBackground="#08FFFFFF" HorizontalGridLinesBrush="{StaticResource CardBorderBrush}"
                                          Foreground="{StaticResource TextPrimaryBrush}" FontSize="12">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="TYPE ID"     Width="80"  Binding="{Binding TypeId}"/>
                                        <DataGridTextColumn Header="NicName"     Width="110" Binding="{Binding NicName}"/>
                                        <DataGridTextColumn Header="Name"        Width="180" Binding="{Binding Name}"/>
                                        <DataGridTextColumn Header="Description" Width="*"   Binding="{Binding Description}"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <Border Grid.Row="1" BorderBrush="{StaticResource AccentBlueBrush}" BorderThickness="0,1,0,0"
                                        Background="{StaticResource ContentBgBrush}"
                                        Visibility="{Binding IsMtEditing, Converter={StaticResource BoolToVis}}">
                                    <StackPanel Margin="16,12">
                                        <TextBlock Text="{Binding MtEditTitle}" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentBlueBrush}" Margin="0,0,0,10"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="180"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Type ID" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                                                <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{StaticResource InputBgBrush}">
                                                    <TextBox Text="{Binding EditMtTypeId, UpdateSourceTrigger=PropertyChanged}"
                                                             IsReadOnly="{Binding IsMtAddingNew, Converter={StaticResource InverseBoolConverter}}"
                                                             BorderThickness="0" Padding="7,5" FontSize="12" Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                </Border>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="NicName" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                                                <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{StaticResource InputBgBrush}">
                                                    <TextBox Text="{Binding EditMtNicName, UpdateSourceTrigger=PropertyChanged}"
                                                             BorderThickness="0" Padding="7,5" FontSize="12" Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                </Border>
                                            </StackPanel>
                                            <StackPanel Grid.Column="4">
                                                <TextBlock Text="Name" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                                                <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{StaticResource InputBgBrush}">
                                                    <TextBox Text="{Binding EditMtName, UpdateSourceTrigger=PropertyChanged}"
                                                             BorderThickness="0" Padding="7,5" FontSize="12" Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                </Border>
                                            </StackPanel>
                                            <StackPanel Grid.Column="6">
                                                <TextBlock Text="Description" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                                                <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{StaticResource InputBgBrush}">
                                                    <TextBox Text="{Binding EditMtDesc, UpdateSourceTrigger=PropertyChanged}"
                                                             BorderThickness="0" Padding="7,5" FontSize="12" Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                                            <Button Command="{Binding MtCancelCommand}" Style="{StaticResource FlatButtonStyle}" Padding="14,6" Margin="0,0,6,0" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1">
                                                <TextBlock Text="취소" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                            </Button>
                                            <Button Command="{Binding MtSaveCommand}" Padding="16,6" Cursor="Hand">
                                                <Button.Template><ControlTemplate TargetType="Button"><Border x:Name="bg" Background="{StaticResource AccentBlueBrush}" CornerRadius="5" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="#155FAD"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                                                <TextBlock Text="저장" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="2" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,1,0,0" Padding="16,10">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Command="{Binding MtInsertCommand}" Padding="16,7" Margin="0,0,6,0" Cursor="Hand">
                                                <Button.Template><ControlTemplate TargetType="Button"><Border x:Name="bg" Background="{StaticResource AccentBlueBrush}" CornerRadius="5" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="#155FAD"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                                                <TextBlock Text="INSERT" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                            </Button>
                                            <Button Command="{Binding MtModifyCommand}" Style="{StaticResource FlatButtonStyle}" Padding="16,7" Margin="0,0,6,0" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1">
                                                <TextBlock Text="MODIFY" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>
                                            </Button>
                                            <Button Command="{Binding MtDeleteCommand}" Style="{StaticResource FlatButtonStyle}" Padding="16,7" BorderBrush="{StaticResource StatusDangerBrush}" BorderThickness="1">
                                                <TextBlock Text="DELETE" FontSize="12" Foreground="{StaticResource StatusDangerBrush}"/>
                                            </Button>
                                        </StackPanel>
                                        <Button Command="{Binding CloseTypePanelCommand}" HorizontalAlignment="Right" Style="{StaticResource FlatButtonStyle}" Padding="16,7" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1">
                                            <TextBlock Text="CLOSE" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- ② Module &amp; Channel Type 탭 내용 -->
                            <Grid Visibility="{Binding IsMtTabMct, Converter={StaticResource BoolToVis}}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Module Type 선택 콤보박스 -->
                                <Border Grid.Row="0" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,0,1"
                                        Background="{StaticResource ContentBgBrush}" Padding="16,10">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Module Type" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="4"
                                                Background="{StaticResource InputBgBrush}" Width="260" Padding="4,0">
                                            <ComboBox ItemsSource="{Binding McModuleTypes}"
                                                      SelectedItem="{Binding SelectedMcModule}"
                                                      DisplayMemberPath="Name"
                                                      BorderThickness="0" Padding="6,5" FontSize="12" Background="Transparent"/>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- Channel Type 목록 -->
                                <DataGrid Grid.Row="1" ItemsSource="{Binding McChannelRows}" SelectedItem="{Binding McSelectedChannelRow}"
                                          AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                          CanUserAddRows="False" CanUserDeleteRows="False"
                                          Background="Transparent" BorderThickness="0" RowBackground="Transparent"
                                          AlternatingRowBackground="#08FFFFFF" HorizontalGridLinesBrush="{StaticResource CardBorderBrush}"
                                          Foreground="{StaticResource TextPrimaryBrush}" FontSize="12">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Channel Type" Width="*" Binding="{Binding Name}"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- 채널 타입 추가 폼 -->
                                <Border Grid.Row="2" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,1,0,0"
                                        Background="{StaticResource ContentBgBrush}" Padding="16,10">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="추가할 Channel Type" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="4"
                                                Background="{StaticResource InputBgBrush}" Width="260" Padding="4,0" Margin="0,0,10,0">
                                            <ComboBox ItemsSource="{Binding AllChannelTypesForMc}"
                                                      SelectedItem="{Binding McSelectedCtForAdd}"
                                                      DisplayMemberPath="Name"
                                                      BorderThickness="0" Padding="6,5" FontSize="12" Background="Transparent"/>
                                        </Border>
                                        <Button Command="{Binding McAddCommand}" Padding="14,6" Cursor="Hand">
