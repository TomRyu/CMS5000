<Window x:Class="CMS5000.Views.Admin.RackOpenView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:m="clr-namespace:CMS5000.Models"
        Title="{Binding RackTitle}"
        Width="1010" Height="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="26"/>
        </Grid.RowDefinitions>

        <!-- ── Toolbar ───────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#F4F4F4" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0">
                <Button Command="{Binding ModifyCommand}" Padding="8,3" Margin="2,0"
                        Background="White" BorderBrush="#C0C0C0" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="Modify" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- ── Rack visualization (실제 제품 랙 형태) ──────────── -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled" Padding="10,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- 슬롯 번호 헤더 밴드 -->
                    <RowDefinition Height="*"/>      <!-- 랙 본체 (키 큰 슬롯) -->
                    <RowDefinition Height="Auto"/>   <!-- 하단 레일 -->
                </Grid.RowDefinitions>

                <!-- 헤더 밴드 : Module NO. 라벨 + 1~14 번호 -->
                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <Border Width="84" Height="46"
                            Background="#E8EAED" BorderBrush="#BDBDBD" BorderThickness="1">
                        <TextBlock Text="Module NO. &gt;&gt;"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   TextWrapping="Wrap" TextAlignment="Center"
                                   FontSize="11" Foreground="#333333"/>
                    </Border>
                    <ItemsControl ItemsSource="{Binding Slots}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type m:RackSlotItem}">
                                <Border Width="58" Height="46" Margin="2,0"
                                        Background="#E8EAED" BorderBrush="#BDBDBD" BorderThickness="1">
                                    <TextBlock Text="{Binding SlotNumber}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontSize="12" FontWeight="SemiBold" Foreground="#555555"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- 랙 본체 : 좌측 공백 + 키 큰 슬롯들 -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,0">
                    <Border Width="84" Background="Transparent"/>
                    <ListBox ItemsSource="{Binding Slots}"
                             SelectedItem="{Binding SelectedSlot, Mode=TwoWay}"
                             Background="Transparent" BorderThickness="0" Padding="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="2,0"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" Width="58" Height="430"
                                                    BorderThickness="1" BorderBrush="#C8C8C8"
                                                    Background="#FAFAFA" CornerRadius="2">
                                                <ContentPresenter HorizontalAlignment="Stretch"
                                                                  VerticalAlignment="Stretch"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#2563EB"/>
                                                    <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                                                </Trigger>
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsMouseOver" Value="True"/>
                                                        <Condition Property="IsSelected"  Value="False"/>
                                                    </MultiTrigger.Conditions>
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#93C5FD"/>
                                                </MultiTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type m:RackSlotItem}">
                                <!-- 모듈 충전 표시 : 중앙 색상 블록만 (텍스트 없음) -->
                                <Grid ToolTip="{Binding ModuleName}">
                                    <Border VerticalAlignment="Center" HorizontalAlignment="Stretch"
                                            Height="150" Margin="6,0" CornerRadius="2">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsOccupied}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Setter Property="Background" Value="#16A34A"/>
                                                    </DataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsOccupied}" Value="True"/>
                                                            <Condition Binding="{Binding IsActive}"   Value="False"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Background" Value="#9CA3AF"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>

                <!-- 하단 레일 -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,4,0,0">
                    <Border Width="84" Background="Transparent"/>
                    <ItemsControl ItemsSource="{Binding Slots}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type m:RackSlotItem}">
                                <Border Width="58" Height="50" Margin="2,0"
                                        Background="#EFEFEF" BorderBrush="#D0D0D0" BorderThickness="1"
                                        CornerRadius="2"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- ── Status bar ────────────────────────────────────── -->
        <Border Grid.Row="2" Background="#F4F4F4" BorderBrush="#DDDDDD" BorderThickness="0,1,0,0">
            <TextBlock Text="Database State.." FontSize="11" Foreground="#555555"
                       VerticalAlignment="Center" Margin="8,0"/>
        </Border>
    </Grid>
</Window>
