<Window x:Class="CMS5000.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CMS5000.ViewModels"
        xmlns:opView="clr-namespace:CMS5000.Views.Operator"
        xmlns:mtView="clr-namespace:CMS5000.Views.Maintenance"
        xmlns:exView="clr-namespace:CMS5000.Views.Expert"
        xmlns:shellView="clr-namespace:CMS5000.Views.Shell"
        xmlns:opVm="clr-namespace:CMS5000.ViewModels.Operator"
        xmlns:mtVm="clr-namespace:CMS5000.ViewModels.Maintenance"
        xmlns:exVm="clr-namespace:CMS5000.ViewModels.Expert"
        xmlns:adVm="clr-namespace:CMS5000.ViewModels"
        xmlns:adView="clr-namespace:CMS5000.Views.Admin"
        xmlns:dcVm="clr-namespace:CMS5000.ViewModels.Admin"
        xmlns:stVm="clr-namespace:CMS5000.ViewModels.Settings"
        xmlns:stView="clr-namespace:CMS5000.Views.Settings"
        xmlns:logView="clr-namespace:CMS5000.Views.Log"
        xmlns:monVm="clr-namespace:CMS5000.ViewModels.Monitoring"
        xmlns:monView="clr-namespace:CMS5000.Views.Monitoring"
        xmlns:models="clr-namespace:CMS5000.Models"
        Title="{Binding WindowTitle}"
        Icon="pack://application:,,,/CMS5000.ico"
        Height="900" Width="1440"
        MinHeight="700" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource ContentBgBrush}"
        WindowStyle="SingleBorderWindow">

    <Window.Resources>
        <DataTemplate DataType="{x:Type opVm:OperatorViewModel}">
            <opView:OperatorMainView DataContext="{Binding}"/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type mtVm:MaintenanceViewModel}">
            <mtView:MaintenanceMainView DataContext="{Binding}"/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type exVm:ExpertViewModel}">
            <exView:ExpertMainView DataContext="{Binding}"/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type adVm:AdminViewModel}">
            <adView:AdminView DataContext="{Binding}"/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type dcVm:DeviceConfigViewModel}">
            <adView:DeviceConfigView DataContext="{Binding}"/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type stVm:SettingsViewModel}">
            <stView:SettingsView DataContext="{Binding}"/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type adVm:LogViewModel}">
            <logView:LogView DataContext="{Binding}"/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type monVm:MonitoringViewModel}">
            <monView:MonitoringView DataContext="{Binding}"/>
        </DataTemplate>

        <!-- NavNode status dot converter (inline style trigger) -->
        <Style x:Key="StatusDotStyle" TargetType="Ellipse">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="Fill" Value="{StaticResource StatusGoodBrush}"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <!-- Root: Login 화면 or Main Shell -->
    <Grid>
        <!-- ===== LOGIN VIEW ===== -->
        <shellView:LoginView DataContext="{Binding}">
            <shellView:LoginView.Style>
                <Style TargetType="shellView:LoginView">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoginVisible}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </shellView:LoginView.Style>
        </shellView:LoginView>

        <!-- ===== MAIN SHELL ===== -->
        <Grid>
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoginVisible}" Value="False">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>      <!-- Row 0: 콘텐츠 (아이콘/트리/메인) -->
                <RowDefinition Height="Auto"/>   <!-- Row 1: DB 연결 상태바 -->
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72"/>   <!-- Col 0: Icon strip -->
                <ColumnDefinition Width="0"/>    <!-- Col 1: (구) Database Name 트리 패널 제거됨 -->
                <ColumnDefinition Width="*"/>    <!-- Col 2: Main content -->
            </Grid.ColumnDefinitions>

            <!-- COL 0 : ICON STRIP -->
            <Border Grid.Column="0" Background="{StaticResource NavIconBgBrush}"
                    Panel.ZIndex="10" Width="72">
                <Border.Resources>
                    <!-- 공통 네비 버튼 템플릿 매크로 (각 버튼에서 인라인 사용) -->
                    <Style x:Key="NavBtnBase" TargetType="Button">
                        <Setter Property="Width" Value="72"/>
                        <Setter Property="Height" Value="72"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Foreground" Value="#99FFFFFF"/>
                    </Style>
                </Border.Resources>

                <DockPanel LastChildFill="False">

                    <!-- 로고 -->
                    <Border DockPanel.Dock="Top" Height="52"
                            Background="{StaticResource NavIconActiveBrush}"
                            BorderBrush="#22FFFFFF" BorderThickness="0,0,0,1">
                        <TextBlock Text="CMS-5000" FontSize="11" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- 상단: 관리자/장비구성 (Admin 로그인 시 상단 배치) -->
                    <StackPanel DockPanel.Dock="Top" Margin="0,4,0,0">

                        <!-- 관리자 (Admin 역할일 때만 표시) -->
                        <Button Width="72" Height="66" Cursor="Hand"
                                Command="{Binding SwitchNavCommand}" CommandParameter="Admin"
                                ToolTip="사용자 관리">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAdminRole}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="Transparent">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock x:Name="ico" Text="&#xE7EF;"
                                                       FontFamily="Segoe MDL2 Assets" FontSize="22"
                                                       Foreground="#88FFFFFF" HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="lbl" Text="사용자" FontSize="10"
                                                       Foreground="#66FFFFFF" HorizontalAlignment="Center"
                                                       Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding ActiveNavIcon}" Value="Admin">
                                            <Setter TargetName="bg" Property="Background" Value="{StaticResource AccentBlueBrush}"/>
                                            <Setter TargetName="ico" Property="Foreground" Value="White"/>
                                            <Setter TargetName="lbl" Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="{StaticResource NavIconHoverBrush}"/>
                                            <Setter TargetName="ico" Property="Foreground" Value="#DDFFFFFF"/>
                                            <Setter TargetName="lbl" Property="Foreground" Value="#BBFFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- 장비구성 (Admin 역할일 때만 표시) -->
                        <Button Width="72" Height="66" Cursor="Hand"
                                Command="{Binding SwitchNavCommand}" CommandParameter="DeviceConfig"
                                ToolTip="장비 구성">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAdminRole}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="Transparent">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock x:Name="ico" Text="&#xE950;"
                                                       FontFamily="Segoe MDL2 Assets" FontSize="22"
                                                       Foreground="#88FFFFFF" HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="lbl" Text="장비구성" FontSize="10"
                                                       Foreground="#66FFFFFF" HorizontalAlignment="Center"
                                                       Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding ActiveNavIcon}" Value="DeviceConfig">
                                            <Setter TargetName="bg" Property="Background" Value="{StaticResource AccentBlueBrush}"/>
                                            <Setter TargetName="ico" Property="Foreground" Value="White"/>
                                            <Setter TargetName="lbl" Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="{StaticResource NavIconHoverBrush}"/>
                                            <Setter TargetName="ico" Property="Foreground" Value="#DDFFFFFF"/>
                                            <Setter TargetName="lbl" Property="Foreground" Value="#BBFFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                    </StackPanel>

                    <!-- 하단 고정 영역 -->
                    <StackPanel DockPanel.Dock="Bottom">
                        <Rectangle Height="1" Fill="#22FFFFFF" Margin="10,6"/>

                        <!-- 설정 -->
                        <Button Width="72" Height="66" Cursor="Hand"
                                Command="{Binding SwitchNavCommand}" CommandParameter="Settings"
                                ToolTip="설정">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="Transparent">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock x:Name="ico" Text="&#xE713;"
                                                       FontFamily="Segoe MDL2 Assets" FontSize="22"
                                                       Foreground="#88FFFFFF" HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="lbl" Text="설정" FontSize="10"
                                                       Foreground="#66FFFFFF" HorizontalAlignment="Center"
                                                       Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding ActiveNavIcon}" Value="Settings">
                                            <Setter TargetName="bg" Property="Background" Value="{StaticResource AccentBlueBrush}"/>
                                            <Setter TargetName="ico" Property="Foreground" Value="White"/>
                                            <Setter TargetName="lbl" Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="{StaticResource NavIconHoverBrush}"/>
                                            <Setter TargetName="ico" Property="Foreground" Value="#DDFFFFFF"/>
                                            <Setter TargetName="lbl" Property="Foreground" Value="#BBFFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                    </StackPanel>

                    <!-- 메인 메뉴 (Admin일 때 숨김) -->
                    <StackPanel DockPanel.Dock="Top" Margin="0,4,0,0">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAdminRole}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <!-- 대시보드 -->
                        <Button Width="72" Height="72" Cursor="Hand"
                                Command="{Binding SwitchNavCommand}" CommandParameter="Dashboard"
                                ToolTip="대시보드">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="Transparent">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock x:Name="ico" Text="&#xE80F;"
                                                       FontFamily="Segoe MDL2 Assets" FontSize="22"
                                                       Foreground="#88FFFFFF" HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="lbl" Text="대시보드" FontSize="10"
                                                       Foreground="#66FFFFFF" HorizontalAlignment="Center"
                                                       Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding ActiveNavIcon}" Value="Dashboard">
                                            <Setter TargetName="bg" Property="Background" Value="{StaticResource AccentBlueBrush}"/>
                                            <Setter TargetName="ico" Property="Foreground" Value="White"/>
                                            <Setter TargetName="lbl" Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="{StaticResource NavIconHoverBrush}"/>
                                            <Setter TargetName="ico" Property="Foreground" Value="#DDFFFFFF"/>
                                            <Setter TargetName="lbl" Property="Foreground" Value="#BBFFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- 설비 -->
                        <Button Width="72" Height="72" Cursor="Hand"
                                Command="{Binding SwitchNavCommand}" CommandParameter="Equipment"
                                ToolTip="설비">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="Transparent">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock x:Name="ico" Text="&#xE950;"
                                                       FontFamily="Segoe MDL2 Assets" FontSize="22"
                                                       Foreground="#88FFFFFF" HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="lbl" Text="설비" FontSize="10"
                                                       Foreground="#66FFFFFF" HorizontalAlignment="Center"
                                                       Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding ActiveNavIcon}" Value="Equipment">
                                            <Setter TargetName="bg" Property="Background" Value="{StaticResource AccentBlueBrush}"/>
                                            <Setter TargetName="ico" Property="Foreground" Value="White"/>
                                            <Setter TargetName="lbl" Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="{StaticResource NavIconHoverBrush}"/>
                                            <Setter TargetName="ico" Property="Foreground" Value="#DDFFFFFF"/>
                                            <Setter TargetName="lbl" Property="Foreground" Value="#BBFFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- 알람 -->
                        <Button Width="72" Height="72" Cursor="Hand"
                                Command="{Binding SwitchNavCommand}" CommandParameter="Alarm"
                                ToolTip="알람">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="Transparent">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock x:Name="ico" Text="&#xEA8F;"
                                                       FontFamily="Segoe MDL2 Assets" FontSize="22"
                                                       Foreground="#88FFFFFF" HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="lbl" Text="알람" FontSize="10"
                                                       Foreground="#66FFFFFF" HorizontalAlignment="Center"
                                                       Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding ActiveNavIcon}" Value="Alarm">
                                            <Setter TargetName="bg" Property="Background" Value="{StaticResource AccentBlueBrush}"/>
                                            <Setter TargetName="ico" Property="Foreground" Value="White"/>
                                            <Setter TargetName="lbl" Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="{StaticResource NavIconHoverBrush}"/>
                                            <Setter TargetName="ico" Property="Foreground" Value="#DDFFFFFF"/>
                                            <Setter TargetName="lbl" Property="Foreground" Value="#BBFFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- 분석 (Expert만) -->
                        <Button Width="72" Height="72" Cursor="Hand"
                                Command="{Binding SwitchNavCommand}" CommandParameter="Analysis"
                                ToolTip="분석">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsExpertRole}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="Transparent">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock x:Name="ico" Text="&#xE9D2;"
                                                       FontFamily="Segoe MDL2 Assets" FontSize="22"
                                                       Foreground="#88FFFFFF" HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="lbl" Text="분석" FontSize="10"
                                                       Foreground="#66FFFFFF" HorizontalAlignment="Center"
                                                       Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding ActiveNavIcon}" Value="Analysis">
                                            <Setter TargetName="bg" Property="Background" Value="{StaticResource AccentBlueBrush}"/>
                                            <Setter TargetName="ico" Property="Foreground" Value="White"/>
                                            <Setter TargetName="lbl" Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="{StaticResource NavIconHoverBrush}"/>
                                            <Setter TargetName="ico" Property="Foreground" Value="#DDFFFFFF"/>
                                            <Setter TargetName="lbl" Property="Foreground" Value="#BBFFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- 진단 (Maintenance + Expert) -->
                        <Button Width="72" Height="72" Cursor="Hand"
                                Command="{Binding SwitchNavCommand}" CommandParameter="Diagnosis"
                                ToolTip="진단">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMaintenanceOrExpert}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="Transparent">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock x:Name="ico" Text="&#xECAD;"
                                                       FontFamily="Segoe MDL2 Assets" FontSize="22"
                                                       Foreground="#88FFFFFF" HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="lbl" Text="진단" FontSize="10"
                                                       Foreground="#66FFFFFF" HorizontalAlignment="Center"
                                                       Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding ActiveNavIcon}" Value="Diagnosis">
                                            <Setter TargetName="bg" Property="Background" Value="{StaticResource AccentBlueBrush}"/>
                                            <Setter TargetName="ico" Property="Foreground" Value="White"/>
                                            <Setter TargetName="lbl" Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="{StaticResource NavIconHoverBrush}"/>
                                            <Setter TargetName="ico" Property="Foreground" Value="#DDFFFFFF"/>
                                            <Setter TargetName="lbl" Property="Foreground" Value="#BBFFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- 점검/이력 (Maintenance + Expert) -->
                        <Button Width="72" Height="72" Cursor="Hand"
                                Command="{Binding SwitchNavCommand}" CommandParameter="Inspection"
                                ToolTip="점검/이력">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMaintenanceOrExpert}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="Transparent">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock x:Name="ico" Text="&#xE9D5;"
                                                       FontFamily="Segoe MDL2 Assets" FontSize="22"
                                                       Foreground="#88FFFFFF" HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="lbl" Text="점검/이력" FontSize="10"
                                                       Foreground="#66FFFFFF" HorizontalAlignment="Center"
                                                       Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding ActiveNavIcon}" Value="Inspection">
                                            <Setter TargetName="bg" Property="Background" Value="{StaticResource AccentBlueBrush}"/>
                                            <Setter TargetName="ico" Property="Foreground" Value="White"/>
                                            <Setter TargetName="lbl" Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="{StaticResource NavIconHoverBrush}"/>
                                            <Setter TargetName="ico" Property="Foreground" Value="#DDFFFFFF"/>
                                            <Setter TargetName="lbl" Property="Foreground" Value="#BBFFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- 보고서 -->
                        <Button Width="72" Height="72" Cursor="Hand"
                                Command="{Binding SwitchNavCommand}" CommandParameter="Report"
                                ToolTip="보고서">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="Transparent">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock x:Name="ico" Text="&#xE7C3;"
                                                       FontFamily="Segoe MDL2 Assets" FontSize="22"
                                                       Foreground="#88FFFFFF" HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="lbl" Text="보고서" FontSize="10"
                                                       Foreground="#66FFFFFF" HorizontalAlignment="Center"
                                                       Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding ActiveNavIcon}" Value="Report">
                                            <Setter TargetName="bg" Property="Background" Value="{StaticResource AccentBlueBrush}"/>
                                            <Setter TargetName="ico" Property="Foreground" Value="White"/>
                                            <Setter TargetName="lbl" Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="{StaticResource NavIconHoverBrush}"/>
                                            <Setter TargetName="ico" Property="Foreground" Value="#DDFFFFFF"/>
                                            <Setter TargetName="lbl" Property="Foreground" Value="#BBFFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- 로그 -->
                        <Button Width="72" Height="72" Cursor="Hand"
                                Command="{Binding SwitchNavCommand}" CommandParameter="Log"
                                ToolTip="로그">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="Transparent">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock x:Name="ico" Text="&#xE81C;"
                                                       FontFamily="Segoe MDL2 Assets" FontSize="22"
                                                       Foreground="#88FFFFFF" HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="lbl" Text="로그" FontSize="10"
                                                       Foreground="#66FFFFFF" HorizontalAlignment="Center"
                                                       Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding ActiveNavIcon}" Value="Log">
                                            <Setter TargetName="bg" Property="Background" Value="{StaticResource AccentBlueBrush}"/>
                                            <Setter TargetName="ico" Property="Foreground" Value="White"/>
                                            <Setter TargetName="lbl" Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="{StaticResource NavIconHoverBrush}"/>
                                            <Setter TargetName="ico" Property="Foreground" Value="#DDFFFFFF"/>
                                            <Setter TargetName="lbl" Property="Foreground" Value="#BBFFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ====================================================
                 COL 1 : TREE NAV PANEL (light)
                 ==================================================== -->
            <!-- (구) COL 1 Database Name 트리 패널 — 제거됨 (비-admin은 MonitoringView 자체 트리 사용) -->

            <!-- ====================================================
                 COL 2 : MAIN CONTENT
                 ==================================================== -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="52"/>  <!-- Header bar -->
                    <RowDefinition Height="*"/>   <!-- Content -->
                </Grid.RowDefinitions>

                <!-- HEADER BAR -->
                <Border Grid.Row="0" Background="{StaticResource HeaderBgBrush}"
                        BorderBrush="{StaticResource HeaderBorderBrush}" BorderThickness="0,0,0,1">
                    <Grid Margin="16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- (구) Tree 토글 ☰ — 제거됨. CMS5000 로고 -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="2,0,0,0">
                            <TextBlock Text="⬡" FontSize="18" Foreground="{StaticResource AccentBlueBrush}"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="CMS-" FontSize="17" FontWeight="Bold"
                                       Foreground="{StaticResource AccentBlueBrush}"/>
                            <TextBlock Text="5000" FontSize="17" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>

                        <!-- 역할 태그 -->
                        <Border Grid.Column="2" HorizontalAlignment="Left" VerticalAlignment="Center"
                                Background="{StaticResource AccentBluePaleBrush}"
                                BorderBrush="{StaticResource AccentBlueLightBrush}"
                                BorderThickness="1" CornerRadius="12" Padding="10,3" Margin="16,0,0,0">
                            <TextBlock Text="{Binding SelectedRoleName}" FontSize="11"
                                       Foreground="{StaticResource AccentBlueBrush}" FontWeight="SemiBold"/>
                        </Border>

                        <!-- 우측: 알림 + 검색 + 로그아웃 -->
                        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- 경고 알림 (Warning) -->
                            <Grid Margin="0,0,8,0">
                                <Button Style="{StaticResource FlatButtonStyle}"
                                        BorderThickness="0" Background="Transparent" Padding="6,4"
                                        Command="{Binding ShowAlarmDetailCommand}"
                                        CommandParameter="Warning"
                                        ToolTip="경고 설비 보기">
                                    <TextBlock Text="🔔" FontSize="16"/>
                                </Button>
                                <Border Background="{StaticResource StatusWarningBrush}"
                                        CornerRadius="8" Width="16" Height="16"
                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Margin="0,-2,-2,0" IsHitTestVisible="False">
                                    <TextBlock Text="{Binding NotificationCount}" FontSize="9"
                                               Foreground="White" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <!-- 위험 알림 (Danger) -->
                            <Grid Margin="0,0,8,0">
                                <Button Style="{StaticResource FlatButtonStyle}"
                                        BorderThickness="0" Background="Transparent" Padding="6,4"
                                        Command="{Binding ShowAlarmDetailCommand}"
                                        CommandParameter="Danger"
                                        ToolTip="위험 설비 보기">
                                    <TextBlock Text="🚨" FontSize="16"/>
                                </Button>
                                <Border Background="{StaticResource StatusDangerBrush}"
                                        CornerRadius="8" Width="16" Height="16"
                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Margin="0,-2,-2,0" IsHitTestVisible="False">
                                    <TextBlock Text="{Binding AlertCount}" FontSize="9"
                                               Foreground="White" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <!-- 업데이트 상태 -->
                            <TextBlock Text="{Binding UpdateStatus}" FontSize="11"
                                       Foreground="{StaticResource AccentBlueLightBrush}"
                                       VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding UpdateStatus}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <!-- 시간 -->
                            <TextBlock Text="{Binding CurrentTime}" FontSize="11" FontFamily="Consolas"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <!-- 사용자 아바타 + 이름 + 로그아웃 -->
                            <Border CornerRadius="6" Padding="8,4" Cursor="Hand"
                                    ToolTip="클릭하여 로그아웃">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource AccentBluePaleBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick" Command="{Binding LogoutCommand}"/>
                                </Border.InputBindings>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="30" Height="30" CornerRadius="15"
                                            Background="{StaticResource AccentBlueBrush}"
                                            BorderBrush="{StaticResource AccentBlueLightBrush}"
                                            BorderThickness="1.5">
                                        <TextBlock Text="{Binding SelectedRoleName[0], FallbackValue='U'}"
                                                   FontSize="13" FontWeight="Bold" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Margin="8,0,6,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding SelectedRoleName}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="로그아웃" FontSize="10"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                    <TextBlock Text="&#xE8FB;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="12" Foreground="{StaticResource TextDisabledBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- CONTENT AREA -->
                <Grid Grid.Row="1" Background="{StaticResource ContentBgBrush}">
                    <!-- Role View -->
                    <ContentPresenter Content="{Binding CurrentView}"/>
                </Grid>
            </Grid>

            <!-- ====================================================
                 ROW 1 : DB 연결 상태바 (CMS-3000 호환 LED + 텍스트)
                 ==================================================== -->
            <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                    Background="{StaticResource HeaderBgBrush}"
                    BorderBrush="{StaticResource HeaderBorderBrush}" BorderThickness="0,1,0,0"
                    Height="24" Panel.ZIndex="20">
                <DockPanel VerticalAlignment="Center" Margin="12,0">
                    <!-- 좌측 끝: 연결 토글 버튼 (모든 역할 접근) — 연결됨이면 '연결 해제', 끊김이면 '재연결'(다이얼로그) -->
                    <Button DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,10,0"
                            ToolTip="DB 연결 해제 / 재연결">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                <Setter Property="FontSize" Value="10"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Content" Value="재연결"/>
                                <Setter Property="Command" Value="{Binding DbConnectCommand}"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="Transparent"
                                                    BorderBrush="{StaticResource HeaderBorderBrush}" BorderThickness="1"
                                                    CornerRadius="3" Padding="8,1">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentBluePaleBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDbConnected}" Value="True">
                                        <Setter Property="Content" Value="연결 해제"/>
                                        <Setter Property="Command" Value="{Binding DbDisconnectCommand}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- 좌측: 연결 LED + 텍스트 -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- 연결 LED : 연결 시 녹색 깜빡임, 끊기면 회색 고정 -->
                    <Ellipse Width="9" Height="9" VerticalAlignment="Center"
                             ToolTip="{Binding ConnectionStatusText}">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource StatusOfflineBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDbConnected}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource StatusGoodBrush}"/>
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="LedBlink">
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="1" To="0.2" Duration="0:0:0.6"
                                                                     AutoReverse="True"
                                                                     RepeatBehavior="Forever"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="LedBlink"/>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding ConnectionStatusText}" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="7,0,0,0"/>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
