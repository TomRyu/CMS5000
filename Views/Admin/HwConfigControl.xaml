<UserControl x:Class="CMS5000.Views.Admin.HwConfigControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F0F3">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="B2V"/>
        <Style x:Key="Tool" TargetType="Button">
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="#FFFFFF" CornerRadius="4" BorderBrush="#9AA7BD" BorderThickness="1" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="#EAF1FB"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bg" Property="Background" Value="#ECECEC"/>
                                <Setter TargetName="bg" Property="BorderBrush" Value="#D0D0D0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/><Setter Property="Foreground" Value="#333333"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Input" TargetType="TextBox">
            <Setter Property="Background" Value="#FFFFFF"/><Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="BorderBrush" Value="#B8C0CC"/><Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5,4"/><Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══ 툴바 ══ -->
        <Border Grid.Row="0" Background="#F4F5F7" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="3" Padding="10,8" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="IP" Style="{StaticResource Lbl}" Margin="0,0,6,0"/>
                <TextBox Style="{StaticResource Input}" Width="120" Text="{Binding Ip, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding Disconnected}"/>
                <TextBlock Text="Port" Style="{StaticResource Lbl}" Margin="10,0,6,0"/>
                <TextBox Style="{StaticResource Input}" Width="70" Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding Disconnected}"/>
                <Rectangle Width="1" Fill="#D0D0D0" Margin="12,2"/>
                <Button Style="{StaticResource Tool}" Command="{Binding ConnectCommand}"><TextBlock Text="Connection" FontSize="12"/></Button>
                <Button Style="{StaticResource Tool}" Command="{Binding DisconnectCommand}"><TextBlock Text="DisConnection" FontSize="12"/></Button>
                <Button Style="{StaticResource Tool}" Command="{Binding DownloadCommand}"><TextBlock Text="DownLoad" FontSize="12"/></Button>
                <Button Style="{StaticResource Tool}" Command="{Binding UploadCommand}"><TextBlock Text="UpLoad" FontSize="12"/></Button>
                <Button Style="{StaticResource Tool}" Command="{Binding ClearCommand}"><TextBlock Text="Clear" FontSize="12"/></Button>
                <Button Style="{StaticResource Tool}" Command="{Binding SaveLogCommand}"><TextBlock Text="Save Log" FontSize="12"/></Button>
                <Button Style="{StaticResource Tool}" Command="{Binding SaveToDbCommand}"><TextBlock Text="DB 저장" FontSize="12"/></Button>
                <CheckBox Content="raw hex" IsChecked="{Binding LogRawHex}" VerticalAlignment="Center" Margin="6,0,0,0" FontSize="12" Foreground="#333333"/>
            </StackPanel>
        </Border>

        <!-- ══ 본문: RACK LIST + 통신상태 ══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="3">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#E8EAED" Padding="10,6" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1">
                        <TextBlock Text="RACK LIST" FontSize="12" FontWeight="SemiBold" Foreground="#333333"/>
                    </Border>
                    <TreeView ItemsSource="{Binding Nodes}" BorderThickness="0" Background="Transparent" Margin="4">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem"><Setter Property="IsExpanded" Value="True"/></Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox IsChecked="{Binding IsChecked}" VerticalAlignment="Center" Margin="0,0,6,0"
                                              Visibility="{Binding DataContext.ShowCheckBoxes, RelativeSource={RelativeSource AncestorType=TreeView}, Converter={StaticResource B2V}}"/>
                                    <TextBlock Text="{Binding Name}" FontSize="12" Foreground="#1F2937" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding FromDevice}" Value="True">
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Setter Property="Foreground" Value="#1D4ED8"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding DeviceInfo}" FontSize="11" Foreground="#6B7280" VerticalAlignment="Center"
                                               Margin="8,0,0,0" Visibility="{Binding HasDeviceInfo, Converter={StaticResource B2V}}"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Background="White" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="3">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#E8EAED" Padding="10,6" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1">
                        <TextBlock Text="COMMUNICATION STATE" FontSize="12" FontWeight="SemiBold" Foreground="#333333"/>
                    </Border>
                    <TextBox Text="{Binding LogText, Mode=OneWay}" IsReadOnly="True" BorderThickness="0"
                             FontFamily="Consolas" FontSize="12" Background="White" Foreground="#1F2937"
                             TextWrapping="NoWrap" IsReadOnlyCaretVisible="True"
                             VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Auto"
                             TextChanged="Log_TextChanged"/>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ══ 상태바 ══ -->
        <Border Grid.Row="2" Background="#F4F5F7" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="3" Padding="10,6" Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="9" Height="9" VerticalAlignment="Center" Margin="0,0,8,0">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="#9CA3AF"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Connected}" Value="True"><Setter Property="Fill" Value="#16A34A"/></DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="{Binding State}" FontSize="11" Foreground="#555555" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
