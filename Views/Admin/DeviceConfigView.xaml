                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,0,1" Background="{StaticResource ContentBgBrush}" Padding="16,10">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="채널 타입" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{StaticResource InputBgBrush}" Width="260" Padding="4,0">
                                            <ComboBox ItemsSource="{Binding AllCtForJunction}" SelectedItem="{Binding CtJunction_SelectedCt}" DisplayMemberPath="Name" BorderThickness="0" Padding="6,5" FontSize="12" Background="Transparent"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                                <DataGrid Grid.Row="1" ItemsSource="{Binding CtPl_Rows}" SelectedItem="{Binding CtPl_SelectedRow}"
                                          AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                          CanUserAddRows="False" CanUserDeleteRows="False"
                                          Background="Transparent" BorderThickness="0" RowBackground="Transparent"
                                          AlternatingRowBackground="#08FFFFFF" HorizontalGridLinesBrush="{StaticResource CardBorderBrush}"
                                          Foreground="{StaticResource TextPrimaryBrush}" FontSize="12">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Display Plot" Width="*" Binding="{Binding Name}"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <Border Grid.Row="2" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,1,0,0" Background="{StaticResource ContentBgBrush}" Padding="16,10">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="추가할 Plot" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{StaticResource InputBgBrush}" Width="260" Padding="4,0" Margin="0,0,10,0">
                                            <ComboBox ItemsSource="{Binding AllPlotsForCt}" SelectedItem="{Binding CtPl_SelectedAdd}" DisplayMemberPath="Name" BorderThickness="0" Padding="6,5" FontSize="12" Background="Transparent"/>
                                        </Border>
                                        <Button Command="{Binding CtPl_AddCommand}" Padding="14,6" Cursor="Hand"><Button.Template><ControlTemplate TargetType="Button"><Border x:Name="bg" Background="{StaticResource AccentBlueBrush}" CornerRadius="5" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="#155FAD"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                                            <TextBlock Text="ADD" FontSize="12" FontWeight="SemiBold" Foreground="White"/></Button>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="3" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,1,0,0" Padding="16,10">
                                    <Grid>
                                        <Button Command="{Binding CtPl_DeleteCommand}" HorizontalAlignment="Left" Style="{StaticResource FlatButtonStyle}" Padding="16,7" BorderBrush="{StaticResource StatusDangerBrush}" BorderThickness="1"><TextBlock Text="DELETE" FontSize="12" Foreground="{StaticResource StatusDangerBrush}"/></Button>
                                        <Button Command="{Binding CloseTypePanelCommand}" HorizontalAlignment="Right" Style="{StaticResource FlatButtonStyle}" Padding="16,7" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"><TextBlock Text="CLOSE" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/></Button>
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- ⑤ CT & Proportional 탭 -->
                            <Grid Visibility="{Binding IsCtTab4, Converter={StaticResource BoolToVis}}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,0,1" Background="{StaticResource ContentBgBrush}" Padding="16,10">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="채널 타입" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{StaticResource InputBgBrush}" Width="260" Padding="4,0">
                                            <ComboBox ItemsSource="{Binding AllCtForJunction}" SelectedItem="{Binding CtJunction_SelectedCt}" DisplayMemberPath="Name" BorderThickness="0" Padding="6,5" FontSize="12" Background="Transparent"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                                <DataGrid Grid.Row="1" ItemsSource="{Binding CtPr_Rows}" SelectedItem="{Binding CtPr_SelectedRow}"
                                          AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                          CanUserAddRows="False" CanUserDeleteRows="False"
                                          Background="Transparent" BorderThickness="0" RowBackground="Transparent"
                                          AlternatingRowBackground="#08FFFFFF" HorizontalGridLinesBrush="{StaticResource CardBorderBrush}"
                                          Foreground="{StaticResource TextPrimaryBrush}" FontSize="12">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Proportional" Width="*" Binding="{Binding Name}"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <Border Grid.Row="2" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,1,0,0" Background="{StaticResource ContentBgBrush}" Padding="16,10">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="추가할 Proportional" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{StaticResource InputBgBrush}" Width="260" Padding="4,0" Margin="0,0,10,0">
                                            <ComboBox ItemsSource="{Binding AllPropsForCt}" SelectedItem="{Binding CtPr_SelectedAdd}" DisplayMemberPath="Name" BorderThickness="0" Padding="6,5" FontSize="12" Background="Transparent"/>
                                        </Border>
                                        <Button Command="{Binding CtPr_AddCommand}" Padding="14,6" Cursor="Hand"><Button.Template><ControlTemplate TargetType="Button"><Border x:Name="bg" Background="{StaticResource AccentBlueBrush}" CornerRadius="5" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="#155FAD"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                                            <TextBlock Text="ADD" FontSize="12" FontWeight="SemiBold" Foreground="White"/></Button>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="3" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,1,0,0" Padding="16,10">
                                    <Grid>
                                        <Button Command="{Binding CtPr_DeleteCommand}" HorizontalAlignment="Left" Style="{StaticResource FlatButtonStyle}" Padding="16,7" BorderBrush="{StaticResource StatusDangerBrush}" BorderThickness="1"><TextBlock Text="DELETE" FontSize="12" Foreground="{StaticResource StatusDangerBrush}"/></Button>
                                        <Button Command="{Binding CloseTypePanelCommand}" HorizontalAlignment="Right" Style="{StaticResource FlatButtonStyle}" Padding="16,7" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"><TextBlock Text="CLOSE" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/></Button>
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- ⑥ CT & Scale Range 탭 -->
                            <Grid Visibility="{Binding IsCtTab5, Converter={StaticResource BoolToVis}}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,0,1" Background="{StaticResource ContentBgBrush}" Padding="16,10">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="채널 타입" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{StaticResource InputBgBrush}" Width="260" Padding="4,0">
                                            <ComboBox ItemsSource="{Binding AllCtForJunction}" SelectedItem="{Binding CtJunction_SelectedCt}" DisplayMemberPath="Name" BorderThickness="0" Padding="6,5" FontSize="12" Background="Transparent"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                                <DataGrid Grid.Row="1" ItemsSource="{Binding CtSc_Rows}" SelectedItem="{Binding CtSc_SelectedRow}"
                                          AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                          CanUserAddRows="False" CanUserDeleteRows="False"
                                          Background="Transparent" BorderThickness="0" RowBackground="Transparent"
                                          AlternatingRowBackground="#08FFFFFF" HorizontalGridLinesBrush="{StaticResource CardBorderBrush}"
                                          Foreground="{StaticResource TextPrimaryBrush}" FontSize="12">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Scale Range" Width="*" Binding="{Binding Name}"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <Border Grid.Row="2" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,1,0,0" Background="{StaticResource ContentBgBrush}" Padding="16,10">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="추가할 Scale Range" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{StaticResource InputBgBrush}" Width="260" Padding="4,0" Margin="0,0,10,0">
                                            <ComboBox ItemsSource="{Binding AllScalesForCt}" SelectedItem="{Binding CtSc_SelectedAdd}" DisplayMemberPath="Name" BorderThickness="0" Padding="6,5" FontSize="12" Background="Transparent"/>
                                        </Border>
                                        <Button Command="{Binding CtSc_AddCommand}" Padding="14,6" Cursor="Hand"><Button.Template><ControlTemplate TargetType="Button"><Border x:Name="bg" Background="{StaticResource AccentBlueBrush}" CornerRadius="5" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="#155FAD"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                                            <TextBlock Text="ADD" FontSize="12" FontWeight="SemiBold" Foreground="White"/></Button>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="3" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,1,0,0" Padding="16,10">
                                    <Grid>
                                        <Button Command="{Binding CtSc_DeleteCommand}" HorizontalAlignment="Left" Style="{StaticResource FlatButtonStyle}" Padding="16,7" BorderBrush="{StaticResource StatusDangerBrush}" BorderThickness="1"><TextBlock Text="DELETE" FontSize="12" Foreground="{StaticResource StatusDangerBrush}"/></Button>
                                        <Button Command="{Binding CloseTypePanelCommand}" HorizontalAlignment="Right" Style="{StaticResource FlatButtonStyle}" Padding="16,7" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"><TextBlock Text="CLOSE" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/></Button>
                                    </Grid>
                                </Border>
                            </Grid>

                        </Grid>
                    </Grid>
                </Border>

                <!-- ─── 센서 관리 패널 ───────────────────────────── -->
                <Border Background="{StaticResource CardBgBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                        CornerRadius="8"
                        Visibility="{Binding IsSensorVisible, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{StaticResource TreePanelHeaderBrush}"
                                BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,0,1"
                                Padding="16,10" CornerRadius="8,8,0,0">
                            <Grid>
                                <TextBlock Text="센서 (Sensor)" FontSize="14" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                <Button Command="{Binding CloseTypePanelCommand}" HorizontalAlignment="Right"
                                        Style="{StaticResource FlatButtonStyle}" Padding="8,4"
                                        BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" ToolTip="닫기">
                                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </Button>
                            </Grid>
                        </Border>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding SensorRows}" SelectedItem="{Binding SelectedSensorRow}"
                                  AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  Background="Transparent" BorderThickness="0" RowBackground="Transparent"
                                  AlternatingRowBackground="#08FFFFFF" HorizontalGridLinesBrush="{StaticResource CardBorderBrush}"
                                  Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"
                                  HorizontalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID"           Width="60"  Binding="{Binding SensorId}"/>
                                <DataGridTextColumn Header="NAME"         Width="200" Binding="{Binding Name}"/>
                                <DataGridTextColumn Header="SensorType"   Width="80"  Binding="{Binding TypeLabel}"/>
                                <DataGridTextColumn Header="Sensitivity"  Width="90"  Binding="{Binding Sensitivity, StringFormat={}{0:F3}}"/>
                                <DataGridTextColumn Header="SensorUnit"   Width="80"  Binding="{Binding UnitName}"/>
                                <DataGridTextColumn Header="ICP"          Width="50"  Binding="{Binding Icp}"/>
                                <DataGridTextColumn Header="POWER"        Width="60"  Binding="{Binding Power}"/>
                                <DataGridTextColumn Header="POWER LOWER"  Width="90"  Binding="{Binding PowerCheckLow}"/>
                                <DataGridTextColumn Header="POWER UPPER"  Width="90"  Binding="{Binding PowerCheckHigh}"/>
                                <DataGridTextColumn Header="Company"      Width="160" Binding="{Binding BrandName}"/>
                                <DataGridTextColumn Header="Spec."        Width="*"   Binding="{Binding Spec}"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- 편집 폼 -->
                        <Border Grid.Row="2" BorderBrush="{StaticResource AccentBlueBrush}" BorderThickness="0,1,0,0"
                                Background="{StaticResource ContentBgBrush}"
                                Visibility="{Binding IsSensorEditing, Converter={StaticResource BoolToVis}}">
                            <StackPanel Margin="16,12">
                                <TextBlock Text="{Binding SensorEditTitle}" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBlueBrush}" Margin="0,0,0,10"/>
                                <!-- 1행: ID / Name / Type / Sensitivity / Unit -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Sensor ID" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                                        <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{StaticResource InputBgBrush}">
                                            <TextBox Text="{Binding EditSensorId, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True"
                                                     BorderThickness="0" Padding="7,5" FontSize="12" Background="Transparent" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Name" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                                        <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{StaticResource InputBgBrush}">
                                            <TextBox Text="{Binding EditSensorName, UpdateSourceTrigger=PropertyChanged}"
                                                     BorderThickness="0" Padding="7,5" FontSize="12" Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="Type" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                                        <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{StaticResource InputBgBrush}" Padding="4,0">
                                            <ComboBox SelectedIndex="{Binding EditSensorType}" BorderThickness="0" Padding="4,5" FontSize="12" Background="Transparent">
                                                <ComboBoxItem Content="Proximitor"/>
                                                <ComboBoxItem Content="Magnetic"/>
                                            </ComboBox>
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Grid.Column="6">
                                        <TextBlock Text="Sensitivity" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                                        <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{StaticResource InputBgBrush}">
                                            <TextBox Text="{Binding EditSensorSensitivity, UpdateSourceTrigger=PropertyChanged}"
                                                     BorderThickness="0" Padding="7,5" FontSize="12" Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Grid.Column="8">
                                        <TextBlock Text="Unit" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                                        <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{StaticResource InputBgBrush}" Padding="4,0">
                                            <ComboBox ItemsSource="{Binding SensorUnitOptions}"
                                                      DisplayMemberPath="Name"
                                                      SelectedValue="{Binding EditSensorUnitId}"
                                                      SelectedValuePath="UnitId"
                                                      BorderThickness="0" Padding="4,5" FontSize="12" Background="Transparent"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                                <!-- 2행: ICP / Power / PowerLow / PowerHigh / Brand / Spec -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="ICP" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                                        <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{StaticResource InputBgBrush}" Padding="4,0">
                                            <ComboBox SelectedIndex="{Binding EditSensorIcp}" BorderThickness="0" Padding="4,5" FontSize="12" Background="Transparent">
                                                <ComboBoxItem Content="OFF"/>
                                                <ComboBoxItem Content="ON"/>
                                            </ComboBox>
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Power" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                                        <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{StaticResource InputBgBrush}" Padding="4,0">
                                            <ComboBox SelectedIndex="{Binding EditSensorPower}" BorderThickness="0" Padding="4,5" FontSize="12" Background="Transparent">
                                                <ComboBoxItem Content="24V"/>
                                                <ComboBoxItem Content="18V"/>
                                            </ComboBox>
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="Power Low" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                                        <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{StaticResource InputBgBrush}">
                                            <TextBox Text="{Binding EditSensorPowerLow, UpdateSourceTrigger=PropertyChanged}"
                                                     BorderThickness="0" Padding="7,5" FontSize="12" Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Grid.Column="6">
                                        <TextBlock Text="Power High" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                                        <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{StaticResource InputBgBrush}">
                                            <TextBox Text="{Binding EditSensorPowerHigh, UpdateSourceTrigger=PropertyChanged}"
                                                     BorderThickness="0" Padding="7,5" FontSize="12" Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Grid.Column="8">
                                        <TextBlock Text="Company" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                                        <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{StaticResource InputBgBrush}">
                                            <TextBox Text="{Binding EditSensorBrandName, UpdateSourceTrigger=PropertyChanged}"
                                                     BorderThickness="0" Padding="7,5" FontSize="12" Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Grid.Column="10">
                                        <TextBlock Text="Spec." FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                                        <Border BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{StaticResource InputBgBrush}">
                                            <TextBox Text="{Binding EditSensorSpec, UpdateSourceTrigger=PropertyChanged}"
                                                     BorderThickness="0" Padding="7,5" FontSize="12" Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                                    <Button Command="{Binding SensorCancelCommand}" Style="{StaticResource FlatButtonStyle}" Padding="14,6" Margin="0,0,6,0" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1">
                                        <TextBlock Text="취소" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </Button>
                                    <Button Command="{Binding SensorSaveCommand}" Padding="16,6" Cursor="Hand">
                                        <Button.Template><ControlTemplate TargetType="Button"><Border x:Name="bg" Background="{StaticResource AccentBlueBrush}" CornerRadius="5" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="#155FAD"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                                        <TextBlock Text="저장" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- 버튼 바 -->
                        <Border Grid.Row="3" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,1,0,0" Padding="16,10">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <Button Command="{Binding SensorInsertCommand}" Padding="16,7" Margin="0,0,6,0" Cursor="Hand">
                                        <Button.Template><ControlTemplate TargetType="Button"><Border x:Name="bg" Background="{StaticResource AccentBlueBrush}" CornerRadius="5" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="#155FAD"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                                        <TextBlock Text="INSERT" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                    </Button>
                                    <Button Command="{Binding SensorModifyCommand}" Style="{StaticResource FlatButtonStyle}" Padding="16,7" Margin="0,0,6,0" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1">
                                        <TextBlock Text="MODIFY" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    </Button>
                                    <Button Command="{Binding SensorDeleteCommand}" Style="{StaticResource FlatButtonStyle}" Padding="16,7" BorderBrush="{StaticResource StatusDangerBrush}" BorderThickness="1">
                                        <TextBlock Text="DELETE" FontSize="12" Foreground="{StaticResource StatusDangerBrush}"/>
                                    </Button>
                                </StackPanel>
                                <Button Command="{Binding CloseTypePanelCommand}" HorizontalAlignment="Right" Style="{StaticResource FlatButtonStyle}" Padding="16,7" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1">
                                    <TextBlock Text="CLOSE" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- ─── 센서 단위 관리 패널 (2-tab) ─────────────────── -->
                <Border Background="{StaticResource CardBgBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                        CornerRadius="8"
                        Visibility="{Binding IsSensorUnitVisible, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{StaticResource TreePanelHeaderBrush}"
                                BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,0,1"
                                Padding="16,10" CornerRadius="8,8,0,0">
                            <Grid>
                                <TextBlock Text="센서 단위 (Sensor Unit)" FontSize="14" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                <Button Command="{Binding CloseTypePanelCommand}" HorizontalAlignment="Right"
                                        Style="{StaticResource FlatButtonStyle}" Padding="8,4"
                                        BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" ToolTip="닫기">
                                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </Button>
                            </Grid>
                        </Border>
                        <!-- 내부 탭 스트립 -->
