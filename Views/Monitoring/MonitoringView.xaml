<UserControl x:Class="CMS5000.Views.Monitoring.MonitoringView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:CMS5000.Controls"
             xmlns:conv="clr-namespace:CMS5000.Converters"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             Background="#ECEEF1">
    <UserControl.Resources>
        <conv:MonStatusToBrushConverter x:Key="StatusBrush"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- 상단 메인 탭 버튼 (Status/Events/Plots/Case History) — 라이트 테마 -->
        <Style x:Key="MainTabBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="22,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" BorderBrush="Transparent"
                                BorderThickness="0,0,0,3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#EAF1FB"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#2563EB"/>
                                <Setter Property="Foreground" Value="#2563EB"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 하위 탭 버튼 (List/Bar Graph/Overview …) — 라이트 테마 -->
        <Style x:Key="SubTabBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#E6EBF2"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2563EB"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 좌측 사이드 탭(Machines/Devices) — 라이트 테마 -->
        <Style x:Key="SideTabBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="#E9EDF3" BorderBrush="#E2E8F0"
                                BorderThickness="0,0,0,2" Padding="0,10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FFFFFF"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#2563EB"/>
                                <Setter Property="Foreground" Value="#2563EB"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 표 공통 -->
        <Style x:Key="MonGrid" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowHeight" Value="46"/>
            <Setter Property="ColumnHeaderHeight" Value="46"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="RowBackground" Value="#FFFFFF"/>
        </Style>
        <Style x:Key="MonHdr" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F3F5F8"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 헤더 -->
            <RowDefinition Height="*"/>      <!-- 본문 -->
        </Grid.RowDefinitions>

        <!-- ===== 상단 헤더 (라이트) ===== -->
        <Border Grid.Row="0" Background="#FFFFFF" Height="68"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="False" Margin="18,0">
                <Button DockPanel.Dock="Left" Command="{Binding ToggleSidebarCommand}" Cursor="Hand"
                        Background="Transparent" BorderThickness="0" Margin="0,0,14,0"
                        ToolTip="사이드바 접기/펼치기" VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="b" Background="#F1F5F9" CornerRadius="5" Padding="10,7">
                                <TextBlock Text="☰" FontSize="16" Foreground="#475569"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="b" Property="Background" Value="#E2E8F0"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <TextBlock DockPanel.Dock="Left" Text="{Binding MachineTitle}"
                           Foreground="#1F2937" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#2563EB" CornerRadius="5" Padding="16,8" Margin="0,0,10,0">
                        <TextBlock Text="🔍  Display" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                    </Border>
                    <Border Background="#F1F5F9" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="5" Padding="16,8" Margin="0,0,16,0">
                        <TextBlock Text="⚙  Configure" Foreground="#334155" FontSize="13" FontWeight="SemiBold"/>
                    </Border>
                    <TextBlock Text="Full Mode" Foreground="#94A3B8" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ===== 본문: 좌 사이드바 | 스플리터 | 메인 ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding SidebarWidth, Mode=TwoWay}" MinWidth="0" MaxWidth="560"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── 좌측 사이드바 (라이트) ── -->
            <Grid Grid.Column="0" Background="#FFFFFF" ClipToBounds="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Machines/Devices -->
                    <RowDefinition Height="*"/>     <!-- 트리 -->
                    <RowDefinition Height="Auto"/>  <!-- Spectrum -->
                    <RowDefinition Height="Auto"/>  <!-- Trended -->
                </Grid.RowDefinitions>

                <!-- Machines / Devices 탭 -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Machines" Style="{StaticResource SideTabBtn}"
                            Tag="{Binding IsMachinesSide}" Command="{Binding SelectSideTabCommand}" CommandParameter="Machines"/>
                    <Button Grid.Column="1" Content="Devices" Style="{StaticResource SideTabBtn}"
                            Tag="{Binding IsDevicesSide}" Command="{Binding SelectSideTabCommand}" CommandParameter="Devices"/>
                </Grid>

                <!-- 트리 -->
                <TreeView Grid.Row="1" ItemsSource="{Binding CurrentTree}" Background="Transparent"
                          BorderThickness="0" Foreground="#334155"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <TreeView.Resources>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="True"/>
                            <Setter Property="Foreground" Value="#334155"/>
                        </Style>
                    </TreeView.Resources>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,8,0"
                                         Fill="{Binding StatusColor}"/>
                                <TextBlock Text="{Binding DisplayText}" Foreground="#334155" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>

                <!-- Spectrum & Phy Waveforms -->
                <StackPanel Grid.Row="2">
                    <Border Background="#EEF1F5" BorderBrush="#E2E8F0" BorderThickness="0,1" Padding="14,8">
                        <TextBlock Text="Spectrum &amp; Phy Waveforms" Foreground="#334155" FontWeight="Bold" FontSize="13"/>
                    </Border>
                    <ItemsControl ItemsSource="{Binding SpectrumWaveforms}" Margin="14,8,8,12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Text}" Foreground="#5B9BD5" FontSize="13" Margin="0,4"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Trended Variables -->
                <StackPanel Grid.Row="3">
                    <Border Background="#EEF1F5" BorderBrush="#E2E8F0" BorderThickness="0,1" Padding="14,8">
                        <TextBlock Text="Trended Variables" Foreground="#334155" FontWeight="Bold" FontSize="13"/>
                    </Border>
                    <ItemsControl ItemsSource="{Binding TrendedVariables}" Margin="6,8,8,14">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="3" Padding="8,4" Margin="0,2">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Highlighted}" Value="True">
                                                    <Setter Property="Background" Value="#DCEAFB"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Text}" Foreground="#5B9BD5" FontSize="13"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>

            <!-- 폭 조절 스플리터 -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          Background="#E2E8F0" ResizeBehavior="PreviousAndNext" Cursor="SizeWE"/>

            <!-- ── 메인 영역 ── -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- 메인 탭 -->
                    <RowDefinition Height="Auto"/>  <!-- 하위 탭 -->
                    <RowDefinition Height="*"/>     <!-- 콘텐츠 -->
                </Grid.RowDefinitions>

                <!-- 메인 탭 (라이트) -->
                <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Status"       Style="{StaticResource MainTabBtn}" Tag="{Binding IsStatusTab}"      Command="{Binding SelectMainTabCommand}" CommandParameter="Status"/>
                        <Button Content="Events"       Style="{StaticResource MainTabBtn}" Tag="{Binding IsEventsTab}"      Command="{Binding SelectMainTabCommand}" CommandParameter="Events"/>
                        <Button Content="Plots"        Style="{StaticResource MainTabBtn}" Tag="{Binding IsPlotsTab}"       Command="{Binding SelectMainTabCommand}" CommandParameter="Plots"/>
                        <Button Content="Case History" Style="{StaticResource MainTabBtn}" Tag="{Binding IsCaseHistoryTab}" Command="{Binding SelectMainTabCommand}" CommandParameter="CaseHistory"/>
                    </StackPanel>
                </Border>

                <!-- 하위 탭 (라이트) -->
                <Border Grid.Row="1" Background="#EEF1F5" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Height="42">
                    <Grid Margin="8,0">
                        <!-- Status 하위탭 -->
                        <StackPanel Orientation="Horizontal" Visibility="{Binding IsStatusTab, Converter={StaticResource BoolToVis}}">
                            <Button Content="List"      Style="{StaticResource SubTabBtn}" Tag="{Binding IsStatusList}"     Command="{Binding SelectStatusSubCommand}" CommandParameter="List"/>
                            <Button Content="Bar Graph" Style="{StaticResource SubTabBtn}" Tag="{Binding IsStatusBar}"      Command="{Binding SelectStatusSubCommand}" CommandParameter="BarGraph"/>
                            <Button Content="Overview"  Style="{StaticResource SubTabBtn}" Tag="{Binding IsStatusOverview}" Command="{Binding SelectStatusSubCommand}" CommandParameter="Overview"/>
                        </StackPanel>
                        <!-- Events 하위탭 -->
                        <StackPanel Orientation="Horizontal" Visibility="{Binding IsEventsTab, Converter={StaticResource BoolToVis}}">
                            <Button Content="Alarms"        Style="{StaticResource SubTabBtn}" Tag="{Binding IsEvAlarms}"  Command="{Binding SelectEventSubCommand}" CommandParameter="Alarms"/>
                            <Button Content="Bearing Health" Style="{StaticResource SubTabBtn}" Tag="{Binding IsEvBearing}" Command="{Binding SelectEventSubCommand}" CommandParameter="Bearing"/>
                            <Button Content="Rotor Health"  Style="{StaticResource SubTabBtn}" Tag="{Binding IsEvRotor}"   Command="{Binding SelectEventSubCommand}" CommandParameter="Rotor"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 콘텐츠 -->
                <Grid Grid.Row="2" Margin="18">

                    <!-- ===== STATUS > LIST ===== -->
                    <Border Background="#FFFFFF" CornerRadius="6" BorderBrush="#E2E8F0" BorderThickness="1"
                            Visibility="{Binding IsStatusList, Converter={StaticResource BoolToVis}}">
                        <DataGrid Style="{StaticResource MonGrid}" ColumnHeaderStyle="{StaticResource MonHdr}"
                                  ItemsSource="{Binding StatusList}">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Point" Width="2*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="14,0">
                                                <Ellipse Width="13" Height="13" VerticalAlignment="Center" Margin="0,0,10,0"
                                                         Fill="{Binding Status, Converter={StaticResource StatusBrush}}"/>
                                                <TextBlock Text="{Binding Point}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Machine"          Binding="{Binding Machine}"       Width="*"/>
                                <DataGridTextColumn Header="Tag Name"         Binding="{Binding TagName}"       Width="*"/>
                                <DataGridTextColumn Header="Display"          Binding="{Binding Display}"       Width="*"/>
                                <DataGridTextColumn Header="Peak Amplitude"   Binding="{Binding PeakAmplitude}" Width="*"/>
                                <DataGridTextColumn Header="Last Recorded Date" Binding="{Binding LastRecorded}" Width="1.4*"/>
                                <DataGridTemplateColumn Header="Status" Width="Auto">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Ellipse Width="13" Height="13" Margin="20,0" VerticalAlignment="Center"
                                                     Fill="{Binding Status, Converter={StaticResource StatusBrush}}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- ===== STATUS > BAR GRAPH ===== -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding IsStatusBar, Converter={StaticResource BoolToVis}}">
                        <ItemsControl ItemsSource="{Binding BarGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,18">
                                        <TextBlock Text="{Binding MachineTitle}" FontSize="20" FontWeight="Bold"
                                                   Foreground="#1F2937" Margin="6,4,0,12"/>
                                        <ItemsControl ItemsSource="{Binding Cards}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><UniformGrid Rows="1"/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#FFFFFF" CornerRadius="6" BorderBrush="#E2E8F0"
                                                            BorderThickness="1" Margin="6" Padding="14">
                                                        <StackPanel>
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                                <Ellipse Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,8,0"
                                                                         Fill="{Binding Status, Converter={StaticResource StatusBrush}}"/>
                                                                <TextBlock Text="{Binding Axis}" FontWeight="Bold" FontSize="15" Foreground="#1F2937"/>
                                                            </StackPanel>
                                                            <ctrl:MiniBarPlot Height="170"
                                                                              Value="{Binding Value}" AxisMax="{Binding AxisMax}" Status="{Binding Status}"/>
                                                            <TextBlock Text="{Binding ValueText}" HorizontalAlignment="Center"
                                                                       FontSize="20" FontWeight="Bold" Foreground="#1F2937" Margin="0,8,0,2"/>
                                                            <TextBlock Text="{Binding Timestamp}" HorizontalAlignment="Center"
                                                                       FontSize="12" Foreground="#94A3B8"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- ===== STATUS > OVERVIEW ===== -->
                    <Border Background="#FFFFFF" CornerRadius="6" BorderBrush="#E2E8F0" BorderThickness="1" Padding="20"
                            Visibility="{Binding IsStatusOverview, Converter={StaticResource BoolToVis}}">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding Overview}" VerticalAlignment="Center">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <!-- 측정값 -->
                                            <StackPanel VerticalAlignment="Center" Margin="14,0">
                                                <StackPanel Orientation="Horizontal" Margin="0,1">
                                                    <Ellipse Width="9" Height="9" VerticalAlignment="Center" Margin="0,0,6,0"
                                                             Fill="{Binding Status, Converter={StaticResource StatusBrush}}"/>
                                                    <TextBlock Text="Overall " Foreground="#64748B" FontSize="13"/>
                                                    <TextBlock Text="{Binding Overall}" FontWeight="Bold" Foreground="#1F2937" FontSize="13"/>
                                                    <TextBlock Text=" mm/s" Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,1">
                                                    <TextBlock Text="Horizontal " Foreground="#64748B" FontSize="13" Margin="15,0,0,0"/>
                                                    <TextBlock Text="{Binding Horizontal}" FontWeight="Bold" Foreground="#1F2937" FontSize="13"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,1">
                                                    <TextBlock Text="Axial " Foreground="#64748B" FontSize="13" Margin="15,0,0,0"/>
                                                    <TextBlock Text="{Binding Axial}" FontWeight="Bold" Foreground="#1F2937" FontSize="13"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <!-- 블록 -->
                                            <Border Width="150" Height="130" CornerRadius="8" BorderThickness="2" Margin="6,0,30,0"
                                                    Background="#E5E9F0" BorderBrush="#9AA7BD">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Good">
                                                                <Setter Property="Background" Value="#9BE7B4"/>
                                                                <Setter Property="BorderBrush" Value="#22C55E"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Name}" FontSize="20" FontWeight="Bold"
                                                           Foreground="#334155" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <!-- ===== EVENTS (Alarms/Bearing/Rotor) ===== -->
                    <Border Background="#FFFFFF" CornerRadius="6" BorderBrush="#E2E8F0" BorderThickness="1"
                            Visibility="{Binding IsEventsTab, Converter={StaticResource BoolToVis}}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="{Binding EventsTitle}" FontSize="16" FontWeight="Bold"
                                       Foreground="#334155" Margin="16,14,0,8"/>
                            <DataGrid Style="{StaticResource MonGrid}" ColumnHeaderStyle="{StaticResource MonHdr}"
                                      ItemsSource="{Binding CurrentEvents}">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Level" Width="Auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="4" Padding="8,3" Margin="14,0" VerticalAlignment="Center"
                                                        Background="{Binding Status, Converter={StaticResource StatusBrush}}">
                                                    <TextBlock Text="{Binding Level}" Foreground="White" FontWeight="SemiBold" FontSize="12"/>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Audit Path"   Binding="{Binding AuditPath}"   Width="1.6*"/>
                                    <DataGridTextColumn Header="Device Point" Binding="{Binding DevicePoint}" Width="1.4*"/>
                                    <DataGridTextColumn Header="Machine"      Binding="{Binding Machine}"     Width="*"/>
                                    <DataGridTextColumn Header="Description"  Binding="{Binding Description}"  Width="1.8*"/>
                                    <DataGridTextColumn Header="Type"         Binding="{Binding Type}"        Width="*"/>
                                    <DataGridTextColumn Header="Value"        Binding="{Binding Value}"       Width="1.2*"/>
                                    <DataGridTextColumn Header="Time"         Binding="{Binding Time}"        Width="1.4*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <!-- ===== PLOTS (ScottPlot 12종) ===== -->
                    <Grid Visibility="{Binding IsPlotsTab, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="250"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 좌: Plot Type 목록 -->
                        <Border Grid.Column="0" Background="#FFFFFF" CornerRadius="6" BorderBrush="#E2E8F0"
                                BorderThickness="1" Margin="0,0,12,0">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="Plot Type" FontSize="15" FontWeight="Bold"
                                           Foreground="#334155" Margin="14,14,0,8"/>
                                <ListBox ItemsSource="{Binding PlotTypeNames}"
                                         SelectedItem="{Binding SelectedPlotType, Mode=TwoWay}"
                                         BorderThickness="0" Background="Transparent"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="14,9"/>
                                            <Setter Property="Margin" Value="6,1"/>
                                            <Setter Property="Foreground" Value="#334155"/>
                                            <Setter Property="FontSize" Value="13"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="bd" Background="Transparent" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter TextElement.Foreground="{TemplateBinding Foreground}"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="bd" Property="Background" Value="#EEF2F8"/>
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="bd" Property="Background" Value="#2563EB"/>
                                                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>
                            </DockPanel>
                        </Border>

                        <!-- 우: 차트 영역 -->
                        <Border Grid.Column="1" Background="#FFFFFF" CornerRadius="6" BorderBrush="#E2E8F0" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <DockPanel Grid.Row="0" Margin="16,12,16,6" LastChildFill="False">
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                        <Border Background="#F3F5F8" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="5" Padding="12,6" Margin="0,0,8,0">
                                            <TextBlock Text="Set Time Range" Foreground="#334155" FontSize="12"/>
                                        </Border>
                                        <Border Background="#F3F5F8" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="5" Padding="12,6">
                                            <TextBlock Text="Export" Foreground="#334155" FontSize="12"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock DockPanel.Dock="Left" Text="{Binding PlotHeader}" FontSize="16" FontWeight="Bold"
                                               Foreground="#334155" VerticalAlignment="Center"/>
                                </DockPanel>

                                <ctrl:MonitoringPlotView Grid.Row="1" Margin="10,0,10,4"
                                                         PlotType="{Binding SelectedPlotType}"/>

                                <Border Grid.Row="2" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="18,10">
                                    <TextBlock Text="샘플/합성 데이터 — 실 DB 연동 예정" FontSize="12" Foreground="#94A3B8"/>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- ===== CASE HISTORY ===== -->
                    <Border Visibility="{Binding IsCaseHistoryTab, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Case History view" FontSize="20" Foreground="#94A3B8"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
