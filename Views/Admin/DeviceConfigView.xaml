                                </StackPanel>
                                <Button Command="{Binding CloseTypePanelCommand}" HorizontalAlignment="Right" Style="{StaticResource FlatButtonStyle}" Padding="16,7" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1">
                                    <TextBlock Text="CLOSE" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- ─── RACK Insert 탭 패널 ─────────────────────────── -->
                <Border Background="{StaticResource CardBgBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                        CornerRadius="8"
                        Visibility="{Binding IsRackInsertVisible, Converter={StaticResource BoolToVis}}">
                    <Grid DataContext="{Binding RackInsertTab}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 헤더 -->
                        <Border Grid.Row="0" Background="{StaticResource TreePanelHeaderBrush}"
                                BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,0,1"
                                Padding="16,10" CornerRadius="8,8,0,0">
                            <TextBlock Text="RACK INSERT" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Border>

                        <!-- 상단: Station ID / Rack ID / Activity -->
                        <Border Grid.Row="1" Background="{StaticResource TreePanelHeaderBrush}" Padding="16,10"
                                BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="STATION ID :" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
