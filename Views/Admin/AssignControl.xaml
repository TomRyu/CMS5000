<UserControl x:Class="CMS5000.Views.Admin.AssignControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="Hdr" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="Margin"     Value="2,0,0,4"/>
        </Style>

        <Style x:Key="DG" TargetType="DataGrid">
            <Setter Property="Background"               Value="#FFFFFF"/>
            <Setter Property="Foreground"               Value="#1F2937"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="BorderBrush"              Value="#C7CED9"/>
            <Setter Property="GridLinesVisibility"      Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E5E9F0"/>
            <Setter Property="VerticalGridLinesBrush"   Value="#E5E9F0"/>
            <Setter Property="RowBackground"            Value="#FFFFFF"/>
            <Setter Property="AlternatingRowBackground" Value="#F7F9FC"/>
            <Setter Property="SelectionMode"            Value="Single"/>
            <Setter Property="FontSize"                 Value="11"/>
            <Setter Property="ColumnHeaderHeight"       Value="24"/>
            <Setter Property="RowHeight"                Value="20"/>
            <Setter Property="AutoGenerateColumns"      Value="False"/>
            <Setter Property="CanUserAddRows"           Value="False"/>
            <Setter Property="CanUserResizeRows"        Value="False"/>
            <Setter Property="IsReadOnly"               Value="True"/>
            <Setter Property="HeadersVisibility"        Value="Column"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="#EEF2F8"/>
            <Setter Property="Foreground"      Value="#475569"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Padding"         Value="6,2"/>
            <Setter Property="BorderBrush"     Value="#C7CED9"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Padding" Value="20,7"/>
            <Setter Property="Cursor"  Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="#FFFFFF" CornerRadius="4" BorderBrush="#9AA7BD" BorderThickness="1" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="#EAF1FB"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bg" Property="Background"  Value="#F1F2F4"/>
                                <Setter TargetName="bg" Property="BorderBrush" Value="#D5D8DE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="150"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="Bold" Foreground="#1F2937" VerticalAlignment="Center"/>
            <TextBlock Text="  ..." FontSize="11" Foreground="#2563EB" VerticalAlignment="Center"
                       Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 좌측 -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/><RowDefinition Height="8"/>
                    <RowDefinition Height="*"/><RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0">
                    <TextBlock DockPanel.Dock="Top" Text="RACK" Style="{StaticResource Hdr}"/>
                    <DataGrid Style="{StaticResource DG}" ItemsSource="{Binding Racks}"
                              SelectedItem="{Binding SelectedRack, Mode=TwoWay}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="RackID"   Binding="{Binding RackId}"   Width="70"/>
                            <DataGridTextColumn Header="Name"     Binding="{Binding Name}"     Width="*"/>
                            <DataGridTextColumn Header="Activity" Binding="{Binding Activity}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>

                <DockPanel Grid.Row="2">
                    <TextBlock DockPanel.Dock="Top" Text="MODULE" Style="{StaticResource Hdr}"/>
                    <DataGrid Style="{StaticResource DG}" ItemsSource="{Binding Modules}"
                              SelectedItem="{Binding SelectedModule, Mode=TwoWay}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ModuleID"   Binding="{Binding ModuleId}"   Width="70"/>
                            <DataGridTextColumn Header="Name"       Binding="{Binding Name}"       Width="*"/>
                            <DataGridTextColumn Header="Activity"   Binding="{Binding Activity}"   Width="60"/>
                            <DataGridTextColumn Header="ModuleType" Binding="{Binding ModuleType}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>

                <DockPanel Grid.Row="4">
                    <TextBlock DockPanel.Dock="Top" Text="CHANNEL" Style="{StaticResource Hdr}"/>
                    <DataGrid Style="{StaticResource DG}" ItemsSource="{Binding Channels}"
                              SelectedItem="{Binding SelectedChannel, Mode=TwoWay}">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAssigned}" Value="True">
                                        <Setter Property="Foreground" Value="#2563EB"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ChannelID"   Binding="{Binding ChannelId}"   Width="70"/>
                            <DataGridTextColumn Header="Name"        Binding="{Binding Name}"        Width="*"/>
                            <DataGridTextColumn Header="Activity"    Binding="{Binding Activity}"    Width="60"/>
                            <DataGridTextColumn Header="ChannelType" Binding="{Binding ChannelType}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Grid>

            <!-- 우측 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/><RowDefinition Height="8"/>
                    <RowDefinition Height="*"/><RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0">
                    <TextBlock DockPanel.Dock="Top" Text="TRAIN" Style="{StaticResource Hdr}"/>
                    <DataGrid Style="{StaticResource DG}" ItemsSource="{Binding Trains}"
                              SelectedItem="{Binding SelectedTrain, Mode=TwoWay}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="TrainID"  Binding="{Binding TrainId}"  Width="70"/>
                            <DataGridTextColumn Header="Name"     Binding="{Binding Name}"     Width="*"/>
                            <DataGridTextColumn Header="Activity" Binding="{Binding Activity}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>

                <DockPanel Grid.Row="2">
                    <TextBlock DockPanel.Dock="Top" Text="COMPONENT" Style="{StaticResource Hdr}"/>
                    <DataGrid Style="{StaticResource DG}" ItemsSource="{Binding Components}"
                              SelectedItem="{Binding SelectedComponent, Mode=TwoWay}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ComponentID" Binding="{Binding ComponentId}" Width="90"/>
                            <DataGridTextColumn Header="Name"        Binding="{Binding Name}"        Width="*"/>
                            <DataGridTextColumn Header="Activity"    Binding="{Binding Activity}"    Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>

                <DockPanel Grid.Row="4">
                    <TextBlock DockPanel.Dock="Top" Text="POINT" Style="{StaticResource Hdr}"/>
                    <DataGrid Style="{StaticResource DG}" ItemsSource="{Binding Points}"
                              SelectedItem="{Binding SelectedPoint, Mode=TwoWay}">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAssigned}" Value="True">
                                        <Setter Property="Foreground" Value="#2563EB"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="PointID"  Binding="{Binding PointId}"  Width="70"/>
                            <DataGridTextColumn Header="Name"     Binding="{Binding Name}"     Width="*"/>
                            <DataGridTextColumn Header="Activity" Binding="{Binding Activity}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Grid>
        </Grid>

        <!-- ASSIGN 목록 -->
        <DockPanel Grid.Row="2" Margin="0,10,0,0">
            <TextBlock DockPanel.Dock="Top" Text="ASSIGN" Style="{StaticResource Hdr}"/>
            <DataGrid Style="{StaticResource DG}" ItemsSource="{Binding AssignList}"
                      SelectedItem="{Binding SelectedAssign, Mode=TwoWay}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="StationID"   Binding="{Binding StationId}"   Width="70"/>
                    <DataGridTextColumn Header="RackID"      Binding="{Binding RackId}"      Width="60"/>
                    <DataGridTextColumn Header="ModuleID"    Binding="{Binding ModuleId}"    Width="70"/>
                    <DataGridTextColumn Header="ChannelID"   Binding="{Binding ChannelId}"   Width="70"/>
                    <DataGridTextColumn Header="ChannelName" Binding="{Binding ChannelName}" Width="*"/>
                    <DataGridTextColumn Header="TrainID"     Binding="{Binding TrainId}"     Width="60"/>
                    <DataGridTextColumn Header="ComponentID" Binding="{Binding ComponentId}" Width="90"/>
                    <DataGridTextColumn Header="PointID"     Binding="{Binding PointId}"     Width="60"/>
                    <DataGridTextColumn Header="PointName"   Binding="{Binding PointName}"   Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <!-- 선택 + 버튼 -->
        <Border Grid.Row="3" Background="#FFFFFF" BorderBrush="#D5DAE2" BorderThickness="1"
                CornerRadius="4" Padding="14,8" Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="34"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="선택 채널 : " FontSize="11" Foreground="#64748B"/>
                    <TextBlock Text="{Binding SelectedChannelText}" FontSize="11" FontWeight="SemiBold" Foreground="#1F2937"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="&#x2194;" FontSize="15" Foreground="#2563EB"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="선택 포인트 : " FontSize="11" Foreground="#64748B"/>
                    <TextBlock Text="{Binding SelectedPointText}" FontSize="11" FontWeight="SemiBold" Foreground="#1F2937"/>
                </StackPanel>
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding AssignCommand}" Style="{StaticResource Btn}" IsEnabled="{Binding CanAssign}" Margin="0,0,8,0">
                        <TextBlock Text="ASSIGN" FontSize="11" FontWeight="SemiBold" Foreground="#1565C0"/>
                    </Button>
                    <Button Command="{Binding UnAssignCommand}" Style="{StaticResource Btn}" IsEnabled="{Binding CanUnAssign}">
                        <TextBlock Text="UN-ASSIGN" FontSize="11" FontWeight="SemiBold" Foreground="#C0392B"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <TextBlock Grid.Row="4" Text="{Binding Status}" FontSize="11" Foreground="#64748B"
                   Margin="2,8,0,0" TextTrimming="CharacterEllipsis"/>
    </Grid>
</UserControl>
