                                        <Button Command="{Binding CloseTypePanelCommand}" HorizontalAlignment="Right" Style="{StaticResource FlatButtonStyle}" Padding="16,7" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"><TextBlock Text="CLOSE" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/></Button>
