<UserControl x:Class="CMS5000.Views.Admin.RelayModuleControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctl="clr-namespace:CMS5000.Controls"
             Background="#F0F0F3">
    <UserControl.Resources>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/><Setter Property="Foreground" Value="#333333"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Input" TargetType="TextBox">
            <Setter Property="Background" Value="#FFFFFF"/><Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="BorderBrush" Value="#B8C0CC"/><Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5,4"/><Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Combo" TargetType="ComboBox">
            <Setter Property="Background" Value="#FFFFFF"/><Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="BorderBrush" Value="#B8C0CC"/><Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="24"/><Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="#FFFFFF" CornerRadius="3" BorderBrush="#9AA7BD" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="#EAF1FB"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bg" Property="Background" Value="#ECECEC"/><Setter TargetName="bg" Property="BorderBrush" Value="#D0D0D0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 헤더 -->
            <RowDefinition Height="*"/>     <!-- 릴레이 16채널 -->
            <RowDefinition Height="Auto"/>  <!-- 버튼 -->
        </Grid.RowDefinitions>

        <!-- ══ 헤더 ══ -->
        <Border Grid.Row="0" Background="#F7F8FA" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="3" Padding="12,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/><RowDefinition Height="8"/><RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/><ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/><ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/><ColumnDefinition Width="90"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="STATION ID" Style="{StaticResource Lbl}" Margin="0,0,8,0"/>
                <ctl:NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding StationId, Mode=OneWay}" IsEnabled="False"/>
                <TextBlock Grid.Row="0" Grid.Column="3" Text="RACK ID" Style="{StaticResource Lbl}" Margin="0,0,8,0"/>
                <ctl:NumericUpDown Grid.Row="0" Grid.Column="4" Value="{Binding RackId, Mode=OneWay}" IsEnabled="False"/>
                <TextBlock Grid.Row="0" Grid.Column="6" Text="MODULE ID" Style="{StaticResource Lbl}" Margin="0,0,8,0"/>
                <ctl:NumericUpDown Grid.Row="0" Grid.Column="7" Value="{Binding ModuleId}" Minimum="1" Maximum="255"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Name" Style="{StaticResource Lbl}" Margin="0,0,8,0"/>
                <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="4" Style="{StaticResource Input}"
                         Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Row="2" Grid.Column="6" Text="MODULE TYPE" Style="{StaticResource Lbl}" Margin="0,0,8,0"/>
                <ComboBox Grid.Row="2" Grid.Column="7" Style="{StaticResource Combo}"
                          ItemsSource="{Binding ModuleTypes}" SelectedItem="{Binding SelectedModuleType}" DisplayMemberPath="NicName"/>
            </Grid>
        </Border>

        <!-- ══ 릴레이 16채널 (8열 × 2행) ══ -->
        <ItemsControl Grid.Row="1" ItemsSource="{Binding Relays}" Margin="0,12">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><UniformGrid Columns="8"/></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#C8CDD6" BorderThickness="1" CornerRadius="3" Margin="3" Background="White">
                        <StackPanel Margin="6,8">
                            <TextBlock Text="{Binding Name, StringFormat='CH {0}'}" HorizontalAlignment="Center"
                                       FontSize="11" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,6"/>
                            <CheckBox IsChecked="{Binding Checked}" Content="Activity" HorizontalAlignment="Center"
                                      Foreground="#1F2937" FontSize="11" Margin="0,0,0,6"/>
                            <Button Content="Config" Style="{StaticResource Btn}" Height="90" IsEnabled="{Binding Checked}"
                                    Command="{Binding DataContext.ConfigCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- ══ 버튼 ══ -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <CheckBox Content="Activity" IsChecked="{Binding Activity}" Foreground="#1F2937" FontSize="12"
                      VerticalAlignment="Center" Margin="0,0,24,0"/>
            <Button Command="{Binding InsertCommand}" Style="{StaticResource Btn}" Padding="20,7" Margin="0,0,10,0">
                <TextBlock Text="INSERT" FontSize="12" FontWeight="SemiBold" Foreground="#1565C0"/>
            </Button>
            <Button Command="{Binding CancelCommand}" Style="{StaticResource Btn}" Padding="20,7">
                <TextBlock Text="CANCEL" FontSize="12" FontWeight="SemiBold" Foreground="#C0392B"/>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
